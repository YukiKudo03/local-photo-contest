<div class="fixed top-4 right-4 z-50 animate-bounce" data-controller="notification" data-notification-auto-dismiss-value="5000">
  <div class="bg-gradient-to-r from-yellow-400 to-orange-500 rounded-lg shadow-lg p-4 text-white max-w-sm">
    <div class="flex items-center">
      <svg class="h-8 w-8 mr-3" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
      <div>
        <p class="font-bold text-lg"><%= t('gamification.levels.level_up') %></p>
        <p class="text-sm"><%= t('gamification.levels.level_up_message', level: level) %></p>
      </div>
    </div>
  </div>
</div>
