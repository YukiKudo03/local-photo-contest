<!DOCTYPE html>
<html>
<head>
  <meta content="text/html; charset=UTF-8" http-equiv="Content-Type" />
  <style>
    body { font-family: sans-serif; line-height: 1.6; color: #333; }
    .container { max-width: 600px; margin: 0 auto; padding: 20px; }
    .header { background: #3b82f6; color: white; padding: 20px; text-align: center; }
    .content { padding: 20px; background: #f9fafb; }
    .comment-box { background: white; border-left: 4px solid #3b82f6; padding: 12px 16px; margin: 16px 0; }
    .button { display: inline-block; background: #3b82f6; color: white; padding: 12px 24px; text-decoration: none; border-radius: 6px; margin: 20px 0; }
    .footer { padding: 20px; font-size: 12px; color: #666; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1><%= t('mailers.notification.comment_posted.header') %></h1>
    </div>
    <div class="content">
      <p><%= t('mailers.common.greeting', name: @user.display_name) %></p>
      <p><%= t('mailers.notification.comment_posted.body', entry_title: @entry.title.presence || t('mailers.notification.comment_posted.untitled'), commenter: @comment.user.display_name) %></p>

      <div class="comment-box">
        <p><%= truncate(@comment.body, length: 200) %></p>
      </div>

      <p style="text-align: center;">
        <a href="<%= entry_url(@entry) %>" class="button"><%= t('mailers.notification.comment_posted.view_button') %></a>
      </p>
    </div>
    <div class="footer">
      <p><%= t('mailers.common.auto_sent') %></p>
      <p><a href="<%= @unsubscribe_url %>"><%= t('mailers.common.change_settings') %></a></p>
    </div>
  </div>
</body>
</html>
