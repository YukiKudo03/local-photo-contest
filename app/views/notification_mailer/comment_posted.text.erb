<%= t('mailers.notification.comment_posted.header') %>

<%= t('mailers.common.greeting', name: @user.display_name) %>

<%= t('mailers.notification.comment_posted.body', entry_title: @entry.title.presence || t('mailers.notification.comment_posted.untitled'), commenter: @comment.user.display_name) %>

<%= t('mailers.notification.comment_posted.comment_content') %>
<%= truncate(@comment.body, length: 200) %>

<%= t('mailers.notification.comment_posted.view_button') %>: <%= entry_url(@entry) %>

---
<%= t('mailers.common.auto_sent') %>
<%= t('mailers.common.change_settings') %>: <%= @unsubscribe_url %>
