<!DOCTYPE html>
<html>
<head>
  <meta content="text/html; charset=UTF-8" http-equiv="Content-Type" />
  <style>
    body { font-family: sans-serif; line-height: 1.6; color: #333; }
    .container { max-width: 600px; margin: 0 auto; padding: 20px; }
    .header { background: #3b82f6; color: white; padding: 20px; text-align: center; }
    .content { padding: 20px; background: #f9fafb; }
    .spot-info { background: white; border-radius: 8px; padding: 16px; margin: 12px 0; }
    .button { display: inline-block; background: #3b82f6; color: white; padding: 12px 24px; text-decoration: none; border-radius: 6px; margin: 20px 0; }
    .footer { padding: 20px; font-size: 12px; color: #666; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1><%= t('mailers.notification.spot_certification_request.header') %></h1>
    </div>
    <div class="content">
      <p><%= t('mailers.common.greeting', name: @user.display_name) %></p>
      <p><%= t('mailers.notification.spot_certification_request.body', contest_title: @contest.title) %></p>

      <div class="spot-info">
        <p><strong><%= t('mailers.notification.spot_certification_request.spot_name') %></strong> <%= @spot.name %></p>
        <% if @spot.address.present? %>
          <p><strong><%= t('mailers.notification.spot_certification_request.address') %></strong> <%= @spot.address %></p>
        <% end %>
        <% if @spot.description.present? %>
          <p><strong><%= t('mailers.notification.spot_certification_request.description') %></strong> <%= @spot.description %></p>
        <% end %>
        <p><strong><%= t('mailers.notification.spot_certification_request.category') %></strong> <%= @spot.category_name %></p>
      </div>

      <p style="text-align: center;">
        <a href="<%= organizers_contest_discovery_spots_url(@contest) %>" class="button"><%= t('mailers.notification.spot_certification_request.view_button') %></a>
      </p>
    </div>
    <div class="footer">
      <p><%= t('mailers.common.auto_sent') %></p>
      <p><a href="<%= @unsubscribe_url %>"><%= t('mailers.common.change_settings') %></a></p>
    </div>
  </div>
</body>
</html>
