<%= t('mailers.notification.entry_submitted.header') %>

<%= t('mailers.common.greeting', name: @user.display_name) %>

<%= t('mailers.notification.entry_submitted.body', contest_title: @contest.title) %>

<% if @entry.title.present? -%>
<%= t('mailers.notification.entry_submitted.work_title') %> <%= @entry.title %>

<% end -%>
<%= t('mailers.notification.entry_submitted.view_button') %>: <%= entry_url(@entry) %>

<%= t('mailers.notification.entry_submitted.encouragement') %>

