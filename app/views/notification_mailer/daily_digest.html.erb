<!DOCTYPE html>
<html>
<head>
  <meta content="text/html; charset=UTF-8" http-equiv="Content-Type" />
  <style>
    body { font-family: sans-serif; line-height: 1.6; color: #333; }
    .container { max-width: 600px; margin: 0 auto; padding: 20px; }
    .header { background: #3b82f6; color: white; padding: 20px; text-align: center; }
    .content { padding: 20px; background: #f9fafb; }
    .contest-section { background: white; border-radius: 8px; padding: 16px; margin: 12px 0; }
    .contest-title { font-weight: bold; color: #1f2937; margin-bottom: 8px; }
    .entry-item { padding: 4px 0; font-size: 14px; color: #4b5563; }
    .button { display: inline-block; background: #3b82f6; color: white; padding: 12px 24px; text-decoration: none; border-radius: 6px; margin: 20px 0; }
    .footer { padding: 20px; font-size: 12px; color: #666; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1><%= t('mailers.notification.daily_digest.header') %></h1>
    </div>
    <div class="content">
      <p><%= t('mailers.common.greeting', name: @user.display_name) %></p>
      <p><%= t('mailers.notification.daily_digest.body') %></p>

      <% @contests_with_entries.each do |contest, entries| %>
        <div class="contest-section">
          <div class="contest-title"><%= contest.title %>(<%= t('mailers.notification.daily_digest.entries_count', count: entries.size) %>)</div>
          <% entries.first(5).each do |entry| %>
            <div class="entry-item">・<%= entry.title.presence || t('mailers.notification.daily_digest.untitled') %> — <%= entry.user.display_name %></div>
          <% end %>
          <% if entries.size > 5 %>
            <div class="entry-item">...<%= t('mailers.notification.daily_digest.more_entries', count: entries.size - 5) %></div>
          <% end %>
        </div>
      <% end %>

      <p style="text-align: center;">
        <a href="<%= organizers_dashboard_url %>" class="button"><%= t('mailers.notification.daily_digest.view_button') %></a>
      </p>
    </div>
    <div class="footer">
      <p><%= t('mailers.common.auto_sent') %></p>
      <p><a href="<%= @unsubscribe_url %>"><%= t('mailers.common.change_settings') %></a></p>
    </div>
  </div>
</body>
</html>
