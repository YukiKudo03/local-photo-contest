<%= t('mailers.notification.daily_digest.header') %>

<%= t('mailers.common.greeting', name: @user.display_name) %>

<%= t('mailers.notification.daily_digest.body') %>

<% @contests_with_entries.each do |contest, entries| -%>
■ <%= contest.title %>(<%= t('mailers.notification.daily_digest.entries_count', count: entries.size) %>)
<% entries.first(5).each do |entry| -%>
  ・<%= entry.title.presence || t('mailers.notification.daily_digest.untitled') %> — <%= entry.user.display_name %>
<% end -%>
<% if entries.size > 5 -%>
  ...<%= t('mailers.notification.daily_digest.more_entries', count: entries.size - 5) %>
<% end -%>

<% end -%>
<%= t('mailers.notification.daily_digest.view_button') %>: <%= organizers_dashboard_url %>

---
<%= t('mailers.common.auto_sent') %>
<%= t('mailers.common.change_settings') %>: <%= @unsubscribe_url %>
