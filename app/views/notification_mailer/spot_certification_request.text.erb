<%= t('mailers.notification.spot_certification_request.header') %>

<%= t('mailers.common.greeting', name: @user.display_name) %>

<%= t('mailers.notification.spot_certification_request.body', contest_title: @contest.title) %>

<%= t('mailers.notification.spot_certification_request.spot_name') %> <%= @spot.name %>
<% if @spot.address.present? -%>
<%= t('mailers.notification.spot_certification_request.address') %> <%= @spot.address %>
<% end -%>
<% if @spot.description.present? -%>
<%= t('mailers.notification.spot_certification_request.description') %> <%= @spot.description %>
<% end -%>
<%= t('mailers.notification.spot_certification_request.category') %> <%= @spot.category_name %>

<%= t('mailers.notification.spot_certification_request.view_button') %>: <%= organizers_contest_discovery_spots_url(@contest) %>

---
<%= t('mailers.common.auto_sent') %>
<%= t('mailers.common.change_settings') %>: <%= @unsubscribe_url %>
