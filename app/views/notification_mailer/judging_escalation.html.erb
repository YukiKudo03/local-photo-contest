<!DOCTYPE html>
<html>
<head>
  <meta content="text/html; charset=UTF-8" http-equiv="Content-Type" />
  <style>
    body { font-family: sans-serif; line-height: 1.6; color: #333; }
    .container { max-width: 600px; margin: 0 auto; padding: 20px; }
    .header { background: #ef4444; color: white; padding: 20px; text-align: center; }
    .content { padding: 20px; background: #f9fafb; }
    .button { display: inline-block; background: #3b82f6; color: white; padding: 12px 24px; text-decoration: none; border-radius: 6px; margin: 20px 0; }
    .footer { padding: 20px; font-size: 12px; color: #666; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1><%= t('mailers.notification.judging_escalation.header') %></h1>
    </div>
    <div class="content">
      <p><%= t('mailers.common.greeting', name: @organizer.display_name) %></p>
      <p><%= t('mailers.notification.judging_escalation.body', contest_title: @contest.title, judge_name: @judge.display_name) %></p>
      <p><%= t('mailers.notification.judging_escalation.progress', rate: @progress) %></p>
      <p><%= t('mailers.notification.judging_escalation.suggestion') %></p>

      <p style="text-align: center;">
        <a href="<%= organizers_contest_url(@contest) %>" class="button"><%= t('mailers.notification.judging_escalation.view_button') %></a>
      </p>
    </div>
    <div class="footer">
      <p><%= t('mailers.common.auto_sent') %></p>
      <p><a href="<%= @unsubscribe_url %>"><%= t('mailers.common.change_settings') %></a></p>
    </div>
  </div>
</body>
</html>
