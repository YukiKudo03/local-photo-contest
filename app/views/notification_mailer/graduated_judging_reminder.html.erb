<!DOCTYPE html>
<html>
<head>
  <meta content="text/html; charset=UTF-8" http-equiv="Content-Type" />
  <style>
    body { font-family: sans-serif; line-height: 1.6; color: #333; }
    .container { max-width: 600px; margin: 0 auto; padding: 20px; }
    .header { color: white; padding: 20px; text-align: center; }
    .header-warning { background: #3b82f6; }
    .header-urgent { background: #f59e0b; }
    .header-final { background: #ef4444; }
    .content { padding: 20px; background: #f9fafb; }
    .progress { background: #e5e7eb; border-radius: 8px; height: 12px; margin: 12px 0; overflow: hidden; }
    .progress-bar { background: #3b82f6; height: 100%; border-radius: 8px; }
    .button { display: inline-block; background: #3b82f6; color: white; padding: 12px 24px; text-decoration: none; border-radius: 6px; margin: 20px 0; }
    .footer { padding: 20px; font-size: 12px; color: #666; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header header-<%= @urgency %>">
      <h1><%= t("mailers.notification.graduated_judging_reminder.#{@urgency}.header") %></h1>
    </div>
    <div class="content">
      <p><%= t('mailers.common.greeting', name: @user.display_name) %></p>
      <p><%= t("mailers.notification.graduated_judging_reminder.#{@urgency}.body", contest_title: @contest.title) %></p>

      <p><%= t('mailers.notification.graduated_judging_reminder.progress', rate: @progress) %></p>
      <div class="progress">
        <div class="progress-bar" style="width: <%= @progress %>%"></div>
      </div>

      <p style="text-align: center;">
        <a href="<%= my_judge_assignment_url(@contest_judge) %>" class="button"><%= t('mailers.notification.graduated_judging_reminder.view_button') %></a>
      </p>
    </div>
    <div class="footer">
      <p><%= t('mailers.common.auto_sent') %></p>
      <p><a href="<%= @unsubscribe_url %>"><%= t('mailers.common.change_settings') %></a></p>
    </div>
  </div>
</body>
</html>
