<!DOCTYPE html>
<html>
<head>
  <meta content="text/html; charset=UTF-8" http-equiv="Content-Type" />
  <style>
    body { font-family: sans-serif; line-height: 1.6; color: #333; }
    .container { max-width: 600px; margin: 0 auto; padding: 20px; }
    .header { background: #3b82f6; color: white; padding: 20px; text-align: center; }
    .content { padding: 20px; background: #f9fafb; }
    .button { display: inline-block; background: #3b82f6; color: white; padding: 12px 24px; text-decoration: none; border-radius: 6px; margin: 20px 0; }
    .footer { padding: 20px; font-size: 12px; color: #666; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1><%= t('mailers.judge_invitation.invite.header') %></h1>
    </div>
    <div class="content">
      <p><%= t('mailers.judge_invitation.invite.greeting') %></p>

      <p><%= t('mailers.judge_invitation.invite.body', contest_title: @contest.title) %></p>

      <% if @contest.theme.present? %>
        <p><strong><%= t('mailers.judge_invitation.invite.theme') %></strong> <%= @contest.theme %></p>
      <% end %>

      <p><%= t('mailers.judge_invitation.invite.instruction') %></p>

      <p style="text-align: center;">
        <a href="<%= @accept_url %>" class="button"><%= t('mailers.judge_invitation.invite.view_button') %></a>
      </p>

      <p><%= t('mailers.judge_invitation.invite.expiry', days: JudgeInvitation::TOKEN_EXPIRY_DAYS) %></p>

      <p><%= t('mailers.judge_invitation.invite.contact') %></p>
    </div>
    <div class="footer">
      <p><%= t('mailers.common.auto_sent_ignore') %></p>
    </div>
  </div>
</body>
</html>
