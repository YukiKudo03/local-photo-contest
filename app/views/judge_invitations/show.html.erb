<div class="min-h-screen bg-gray-100 flex items-center justify-center py-12 px-4">
  <div class="max-w-md w-full bg-white rounded-lg shadow-lg overflow-hidden">
    <div class="bg-blue-600 px-6 py-8 text-center">
      <h1 class="text-2xl font-bold text-white"><%= t('judge_invitations.show.title') %></h1>
    </div>

    <div class="p-6">
      <% if @invitation.expired? %>
        <div class="bg-yellow-50 border border-yellow-200 rounded-md p-4 mb-6">
          <p class="text-yellow-800"><%= t('judge_invitations.show.expired') %></p>
        </div>
      <% elsif @invitation.accepted? %>
        <div class="bg-green-50 border border-green-200 rounded-md p-4 mb-6">
          <p class="text-green-800"><%= t('judge_invitations.show.accepted') %></p>
        </div>
      <% elsif @invitation.declined? %>
        <div class="bg-gray-50 border border-gray-200 rounded-md p-4 mb-6">
          <p class="text-gray-800"><%= t('judge_invitations.show.declined') %></p>
        </div>
      <% end %>

      <div class="mb-6">
        <h2 class="text-xl font-semibold text-gray-900 mb-2"><%= @contest.title %></h2>
        <% if @contest.theme.present? %>
          <p class="text-gray-600"><strong><%= t('judge_invitations.show.theme') %></strong> <%= @contest.theme %></p>
        <% end %>
        <% if @contest.description.present? %>
          <p class="text-gray-600 mt-2"><%= truncate(@contest.description, length: 200) %></p>
        <% end %>
      </div>

      <div class="mb-6 p-4 bg-gray-50 rounded-md">
        <p class="text-sm text-gray-600">
          <strong><%= t('judge_invitations.show.invitation_email') %></strong> <%= @invitation.email %><br>
          <strong><%= t('judge_invitations.show.invitation_date') %></strong> <%= l(@invitation.invited_at, format: :long) %>
        </p>
      </div>

      <% if @invitation.pending? && !@invitation.expired? %>
        <div class="space-y-3">
          <% if user_signed_in? %>
            <%= button_to t('judge_invitations.show.accept'), accept_judge_invitation_path(@invitation.token),
                method: :post,
                class: "w-full bg-blue-600 text-white py-3 px-4 rounded-md hover:bg-blue-700 font-semibold" %>
          <% else %>
            <%= link_to t('judge_invitations.show.login_to_accept'), new_user_session_path(redirect_to: judge_invitation_path(@invitation.token)),
                class: "block w-full bg-blue-600 text-white py-3 px-4 rounded-md hover:bg-blue-700 font-semibold text-center" %>
            <p class="text-sm text-gray-500 text-center mt-2">
              <%= t('judge_invitations.show.signup_prompt_html', link: link_to(t('judge_invitations.show.signup_link'), new_user_registration_path, class: "text-blue-600 hover:text-blue-800")) %>
            </p>
          <% end %>

          <%= button_to t('judge_invitations.show.decline'), decline_judge_invitation_path(@invitation.token),
              method: :post,
              data: { turbo_confirm: t('judge_invitations.show.decline_confirm') },
              class: "w-full bg-gray-200 text-gray-700 py-3 px-4 rounded-md hover:bg-gray-300 font-semibold" %>
        </div>
      <% else %>
        <%= link_to t('judge_invitations.show.back_to_top'), root_path,
            class: "block w-full bg-gray-200 text-gray-700 py-3 px-4 rounded-md hover:bg-gray-300 font-semibold text-center" %>
      <% end %>
    </div>
  </div>
</div>
