<div class="min-h-screen bg-gray-100 flex items-center justify-center py-12 px-4">
  <div class="max-w-md w-full bg-white rounded-lg shadow-lg overflow-hidden">
    <div class="bg-blue-600 px-6 py-8 text-center">
      <h1 class="text-2xl font-bold text-white">審査員への招待</h1>
    </div>

    <div class="p-6">
      <% if @invitation.expired? %>
        <div class="bg-yellow-50 border border-yellow-200 rounded-md p-4 mb-6">
          <p class="text-yellow-800">この招待は有効期限が切れています。主催者に連絡して再招待をリクエストしてください。</p>
        </div>
      <% elsif @invitation.accepted? %>
        <div class="bg-green-50 border border-green-200 rounded-md p-4 mb-6">
          <p class="text-green-800">この招待は既に承諾されています。</p>
        </div>
      <% elsif @invitation.declined? %>
        <div class="bg-gray-50 border border-gray-200 rounded-md p-4 mb-6">
          <p class="text-gray-800">この招待は辞退されています。</p>
        </div>
      <% end %>

      <div class="mb-6">
        <h2 class="text-xl font-semibold text-gray-900 mb-2"><%= @contest.title %></h2>
        <% if @contest.theme.present? %>
          <p class="text-gray-600"><strong>テーマ:</strong> <%= @contest.theme %></p>
        <% end %>
        <% if @contest.description.present? %>
          <p class="text-gray-600 mt-2"><%= truncate(@contest.description, length: 200) %></p>
        <% end %>
      </div>

      <div class="mb-6 p-4 bg-gray-50 rounded-md">
        <p class="text-sm text-gray-600">
          <strong>招待メール:</strong> <%= @invitation.email %><br>
          <strong>招待日:</strong> <%= l(@invitation.invited_at, format: :long) %>
        </p>
      </div>

      <% if @invitation.pending? && !@invitation.expired? %>
        <div class="space-y-3">
          <% if user_signed_in? %>
            <%= button_to "審査員として参加する", accept_judge_invitation_path(@invitation.token),
                method: :post,
                class: "w-full bg-blue-600 text-white py-3 px-4 rounded-md hover:bg-blue-700 font-semibold" %>
          <% else %>
            <%= link_to "ログインして参加する", new_user_session_path(redirect_to: judge_invitation_path(@invitation.token)),
                class: "block w-full bg-blue-600 text-white py-3 px-4 rounded-md hover:bg-blue-700 font-semibold text-center" %>
            <p class="text-sm text-gray-500 text-center mt-2">
              アカウントをお持ちでない場合は <%= link_to "新規登録", new_user_registration_path, class: "text-blue-600 hover:text-blue-800" %> してください
            </p>
          <% end %>

          <%= button_to "辞退する", decline_judge_invitation_path(@invitation.token),
              method: :post,
              data: { turbo_confirm: "招待を辞退しますか？" },
              class: "w-full bg-gray-200 text-gray-700 py-3 px-4 rounded-md hover:bg-gray-300 font-semibold" %>
        </div>
      <% else %>
        <%= link_to "トップページに戻る", root_path,
            class: "block w-full bg-gray-200 text-gray-700 py-3 px-4 rounded-md hover:bg-gray-300 font-semibold text-center" %>
      <% end %>
    </div>
  </div>
</div>
