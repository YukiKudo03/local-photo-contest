<% content_for :title, t('admin.users.index.title') %>

<div class="sm:flex sm:items-center mb-6">
  <div class="sm:flex-auto">
    <h1 class="text-2xl font-bold text-gray-900"><%= t('admin.users.index.title') %></h1>
    <p class="mt-1 text-sm text-gray-500"><%= t('admin.users.index.subtitle') %></p>
  </div>
</div>

<!-- Search and Filter -->
<div class="bg-white shadow rounded-lg p-4 mb-6">
  <%= form_with url: admin_users_path, method: :get, local: true, class: "sm:flex sm:items-center gap-4" do |form| %>
    <div class="flex-1">
      <%= form.text_field :q, value: params[:q], placeholder: t('admin.users.index.search_placeholder'),
          class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>
    <div class="mt-3 sm:mt-0">
      <%= form.select :role, [[t('admin.users.index.all_roles'), ""], [t('admin.users.index.participant'), "participant"], [t('admin.users.index.organizer'), "organizer"], [t('admin.users.index.admin'), "admin"]],
          { selected: params[:role] },
          class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>
    <div class="mt-3 sm:mt-0">
      <%= form.submit t('admin.users.index.search'), class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
    </div>
  <% end %>
</div>

<!-- Users Table -->
<div class="bg-white shadow overflow-hidden sm:rounded-lg">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t('admin.users.index.user') %></th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t('admin.users.index.role') %></th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t('admin.users.index.status') %></th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t('admin.users.index.registered_at') %></th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t('admin.users.index.last_login') %></th>
        <th scope="col" class="relative px-6 py-3"><span class="sr-only"><%= t('admin.users.index.actions') %></span></th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% @users.each do |user| %>
        <tr>
          <td class="px-6 py-4 whitespace-nowrap">
            <div class="flex items-center">
              <div class="flex-shrink-0 h-10 w-10 rounded-full bg-indigo-100 flex items-center justify-center">
                <span class="text-indigo-600 font-medium"><%= user.initial %></span>
              </div>
              <div class="ml-4">
                <div class="text-sm font-medium text-gray-900"><%= user.display_name %></div>
                <div class="text-sm text-gray-500"><%= user.email %></div>
              </div>
            </div>
          </td>
          <td class="px-6 py-4 whitespace-nowrap">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
              <%= user.admin? ? 'bg-red-100 text-red-800' : user.organizer? ? 'bg-blue-100 text-blue-800' : 'bg-gray-100 text-gray-800' %>">
              <%= user.admin? ? t('admin.users.index.admin') : user.organizer? ? t('admin.users.index.organizer') : t('admin.users.index.participant') %>
            </span>
          </td>
          <td class="px-6 py-4 whitespace-nowrap">
            <% if user.access_locked? %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                <%= t('admin.users.index.suspended') %>
              </span>
            <% elsif !user.confirmed? %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                <%= t('admin.users.index.unconfirmed') %>
              </span>
            <% else %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                <%= t('admin.users.index.active') %>
              </span>
            <% end %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
            <%= l(user.created_at, format: :short) %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
            <%= user.last_sign_in_at ? l(user.last_sign_in_at, format: :short) : "-" %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
            <%= link_to t('admin.users.index.details'), admin_user_path(user), class: "text-indigo-600 hover:text-indigo-900" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<!-- Pagination -->
<% if @users.respond_to?(:total_pages) && @users.total_pages > 1 %>
  <div class="mt-6">
    <%= paginate @users %>
  </div>
<% end %>
