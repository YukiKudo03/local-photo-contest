<% content_for :title, "コンテスト管理" %>

<div class="sm:flex sm:items-center mb-6">
  <div class="sm:flex-auto">
    <h1 class="text-2xl font-bold text-gray-900">コンテスト管理</h1>
    <p class="mt-1 text-sm text-gray-500">システム内の全コンテストを管理できます</p>
  </div>
</div>

<!-- Search and Filter -->
<div class="bg-white shadow rounded-lg p-4 mb-6">
  <%= form_with url: admin_contests_path, method: :get, local: true, class: "sm:flex sm:items-center gap-4" do |form| %>
    <div class="flex-1">
      <%= form.text_field :q, value: params[:q], placeholder: "コンテスト名で検索...",
          class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>
    <div class="mt-3 sm:mt-0">
      <%= form.select :status, [["すべてのステータス", ""], ["下書き", "draft"], ["応募受付中", "accepting_entries"], ["終了", "finished"]],
          { selected: params[:status] },
          class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>
    <div class="mt-3 sm:mt-0">
      <%= form.submit "検索", class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
    </div>
  <% end %>
</div>

<!-- Contests Table -->
<div class="bg-white shadow overflow-hidden sm:rounded-lg">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">コンテスト</th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">主催者</th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">応募数</th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ステータス</th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">作成日</th>
        <th scope="col" class="relative px-6 py-3"><span class="sr-only">操作</span></th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% @contests.each do |contest| %>
        <tr>
          <td class="px-6 py-4 whitespace-nowrap">
            <div class="text-sm font-medium text-gray-900"><%= contest.title %></div>
            <div class="text-sm text-gray-500"><%= truncate(contest.theme, length: 50) %></div>
          </td>
          <td class="px-6 py-4 whitespace-nowrap">
            <%= link_to contest.user.display_name, admin_user_path(contest.user), class: "text-sm text-indigo-600 hover:text-indigo-900" %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
            <%= contest.entries.count %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
              <%= case contest.status
                  when 'draft' then 'bg-gray-100 text-gray-800'
                  when 'accepting_entries' then 'bg-green-100 text-green-800'
                  when 'finished' then 'bg-blue-100 text-blue-800'
                  else 'bg-gray-100 text-gray-800'
                  end %>">
              <%= case contest.status
                  when 'draft' then '下書き'
                  when 'accepting_entries' then '応募受付中'
                  when 'finished' then '終了'
                  else contest.status
                  end %>
            </span>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
            <%= contest.created_at.strftime("%Y/%m/%d") %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
            <%= link_to "詳細", admin_contest_path(contest), class: "text-indigo-600 hover:text-indigo-900" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<!-- Pagination -->
<% if @contests.respond_to?(:total_pages) && @contests.total_pages > 1 %>
  <div class="mt-6">
    <%= paginate @contests %>
  </div>
<% end %>
