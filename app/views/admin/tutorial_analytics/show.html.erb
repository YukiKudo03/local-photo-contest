<% content_for :title, t('admin.tutorial_analytics.show.title') %>

<div class="mb-8">
  <h1 class="text-2xl font-bold text-gray-900"><%= t('admin.tutorial_analytics.show.title') %></h1>
  <p class="mt-1 text-sm text-gray-500"><%= t('admin.tutorial_analytics.show.subtitle') %></p>
</div>

<!-- Summary Stats -->
<div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4 mb-8">
  <div class="bg-white overflow-hidden shadow rounded-lg">
    <div class="p-5">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <svg class="h-6 w-6 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
        </div>
        <div class="ml-5 w-0 flex-1">
          <dl>
            <dt class="text-sm font-medium text-gray-500 truncate"><%= t('admin.tutorial_analytics.show.users_started') %></dt>
            <dd class="flex items-baseline">
              <div class="text-2xl font-semibold text-gray-900"><%= number_with_delimiter(@stats[:users_started]) %></div>
              <div class="ml-2 text-sm text-gray-500">/ <%= number_with_delimiter(@stats[:total_users]) %> <%= t('admin.tutorial_analytics.show.users_unit') %></div>
            </dd>
          </dl>
        </div>
      </div>
    </div>
  </div>

  <div class="bg-white overflow-hidden shadow rounded-lg">
    <div class="p-5">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <svg class="h-6 w-6 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div class="ml-5 w-0 flex-1">
          <dl>
            <dt class="text-sm font-medium text-gray-500 truncate"><%= t('admin.tutorial_analytics.show.completion_rate') %></dt>
            <dd class="flex items-baseline">
              <div class="text-2xl font-semibold text-green-600"><%= @stats[:completion_rate] %>%</div>
              <div class="ml-2 text-sm text-gray-500"><%= number_with_delimiter(@stats[:completed]) %> <%= t('admin.tutorial_analytics.show.completed') %></div>
            </dd>
          </dl>
        </div>
      </div>
    </div>
  </div>

  <div class="bg-white overflow-hidden shadow rounded-lg">
    <div class="p-5">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <svg class="h-6 w-6 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7" />
          </svg>
        </div>
        <div class="ml-5 w-0 flex-1">
          <dl>
            <dt class="text-sm font-medium text-gray-500 truncate"><%= t('admin.tutorial_analytics.show.skip_rate') %></dt>
            <dd class="flex items-baseline">
              <div class="text-2xl font-semibold text-amber-600"><%= @stats[:skip_rate] %>%</div>
              <div class="ml-2 text-sm text-gray-500"><%= number_with_delimiter(@stats[:skipped]) %> <%= t('admin.tutorial_analytics.show.skipped') %></div>
            </dd>
          </dl>
        </div>
      </div>
    </div>
  </div>

  <div class="bg-white overflow-hidden shadow rounded-lg">
    <div class="p-5">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <svg class="h-6 w-6 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div class="ml-5 w-0 flex-1">
          <dl>
            <dt class="text-sm font-medium text-gray-500 truncate"><%= t('admin.tutorial_analytics.show.avg_completion_time') %></dt>
            <dd class="text-2xl font-semibold text-gray-900">
              <% if @stats[:avg_completion_time] > 0 %>
                <%= @stats[:avg_completion_time] / 60 %><%= t('admin.tutorial_analytics.show.minutes') %><%= @stats[:avg_completion_time] % 60 %><%= t('admin.tutorial_analytics.show.seconds') %>
              <% else %>
                -
              <% end %>
            </dd>
          </dl>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Charts Section -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
  <!-- Daily Stats Chart -->
  <div class="bg-white shadow rounded-lg p-6">
    <h3 class="text-lg font-medium text-gray-900 mb-4"><%= t('admin.tutorial_analytics.show.daily_chart') %></h3>
    <div class="h-64" data-controller="chart" data-chart-type-value="line" data-chart-data-value="<%= @daily_stats.to_json %>">
      <canvas data-chart-target="canvas"></canvas>
    </div>
    <div class="mt-4 flex justify-center gap-6 text-sm">
      <span class="flex items-center gap-2">
        <span class="w-3 h-3 rounded-full bg-blue-500"></span>
        <%= t('admin.tutorial_analytics.show.legend_started') %>
      </span>
      <span class="flex items-center gap-2">
        <span class="w-3 h-3 rounded-full bg-green-500"></span>
        <%= t('admin.tutorial_analytics.show.legend_completed') %>
      </span>
      <span class="flex items-center gap-2">
        <span class="w-3 h-3 rounded-full bg-amber-500"></span>
        <%= t('admin.tutorial_analytics.show.legend_skipped') %>
      </span>
    </div>
  </div>

  <!-- Completion by Type -->
  <div class="bg-white shadow rounded-lg p-6">
    <h3 class="text-lg font-medium text-gray-900 mb-4"><%= t('admin.tutorial_analytics.show.completion_by_type') %></h3>
    <div class="space-y-4">
      <% @completion_by_type.each do |data| %>
        <div>
          <div class="flex justify-between mb-1">
            <span class="text-sm font-medium text-gray-700"><%= tutorial_type_label(data[:tutorial_type]) %></span>
            <span class="text-sm text-gray-500">
              <%= data[:completed] %> / <%= data[:total] %> (<%= data[:completion_rate] %>%)
            </span>
          </div>
          <div class="w-full bg-gray-200 rounded-full h-2">
            <div class="bg-green-500 h-2 rounded-full transition-all duration-500" style="width: <%= data[:completion_rate] %>%"></div>
          </div>
        </div>
      <% end %>
      <% if @completion_by_type.empty? %>
        <p class="text-gray-500 text-center py-4"><%= t('admin.tutorial_analytics.show.no_data') %></p>
      <% end %>
    </div>
  </div>
</div>

<!-- Detailed Stats -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <!-- Completion by Role -->
  <div class="bg-white shadow rounded-lg">
    <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
      <h3 class="text-lg font-medium text-gray-900"><%= t('admin.tutorial_analytics.show.completion_by_role') %></h3>
    </div>
    <ul class="divide-y divide-gray-200">
      <% @completion_by_role.each do |data| %>
        <li class="px-4 py-4">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-gray-900"><%= data[:role]&.humanize || t('admin.tutorial_analytics.show.unknown_role') %></p>
              <p class="text-sm text-gray-500"><%= data[:user_count] %> <%= t('admin.tutorial_analytics.show.users_unit') %></p>
            </div>
            <div class="text-right">
              <p class="text-sm font-semibold <%= data[:completion_rate] >= 70 ? 'text-green-600' : data[:completion_rate] >= 40 ? 'text-amber-600' : 'text-red-600' %>">
                <%= data[:completion_rate] %>%
              </p>
              <p class="text-xs text-gray-500"><%= data[:completed] %> / <%= data[:progress_count] %></p>
            </div>
          </div>
        </li>
      <% end %>
      <% if @completion_by_role.empty? %>
        <li class="px-4 py-8 text-center text-gray-500"><%= t('admin.tutorial_analytics.show.no_data') %></li>
      <% end %>
    </ul>
  </div>

  <!-- Recent Completions -->
  <div class="bg-white shadow rounded-lg">
    <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
      <h3 class="text-lg font-medium text-gray-900"><%= t('admin.tutorial_analytics.show.recent_completions') %></h3>
    </div>
    <ul class="divide-y divide-gray-200">
      <% @recent_completions.each do |progress| %>
        <li class="px-4 py-3">
          <div class="flex items-center justify-between">
            <div class="min-w-0">
              <p class="text-sm font-medium text-gray-900 truncate">
                <%= progress.user.display_name %>
              </p>
              <p class="text-xs text-gray-500">
                <%= tutorial_type_label(progress.tutorial_type) %>
              </p>
            </div>
            <span class="text-xs text-gray-400">
              <%= t('admin.tutorial_analytics.show.time_ago', time: time_ago_in_words(progress.completed_at)) %>
            </span>
          </div>
        </li>
      <% end %>
      <% if @recent_completions.empty? %>
        <li class="px-4 py-8 text-center text-gray-500"><%= t('admin.tutorial_analytics.show.no_data') %></li>
      <% end %>
    </ul>
  </div>

  <!-- Skip Analysis -->
  <div class="bg-white shadow rounded-lg">
    <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
      <h3 class="text-lg font-medium text-gray-900"><%= t('admin.tutorial_analytics.show.skip_analysis') %></h3>
      <p class="mt-1 text-xs text-gray-500"><%= t('admin.tutorial_analytics.show.skip_analysis_description') %></p>
    </div>
    <ul class="divide-y divide-gray-200">
      <% @skip_analysis.each do |data| %>
        <li class="px-4 py-3">
          <div class="flex items-center justify-between">
            <div class="min-w-0">
              <p class="text-sm font-medium text-gray-900">
                <%= tutorial_type_label(data.tutorial_type) %>
              </p>
              <p class="text-xs text-gray-500">
                <%= t('admin.tutorial_analytics.show.step', step_id: data.current_step_id) %>
              </p>
            </div>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800">
              <%= t('admin.tutorial_analytics.show.times', count: data.skip_count) %>
            </span>
          </div>
        </li>
      <% end %>
      <% if @skip_analysis.empty? %>
        <li class="px-4 py-8 text-center text-gray-500">
          <%= t('admin.tutorial_analytics.show.no_skip_data') %>
        </li>
      <% end %>
    </ul>
  </div>
</div>
