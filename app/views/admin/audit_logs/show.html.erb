<% content_for :title, t('admin.audit_logs.show.title') %>

<div class="mb-6">
  <%= link_to t('admin.audit_logs.show.back'), admin_audit_logs_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
</div>

<div class="bg-white shadow overflow-hidden sm:rounded-lg">
  <div class="px-4 py-5 sm:px-6">
    <h3 class="text-lg leading-6 font-medium text-gray-900"><%= t('admin.audit_logs.show.heading') %></h3>
  </div>
  <div class="border-t border-gray-200">
    <dl>
      <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
        <dt class="text-sm font-medium text-gray-500"><%= t('admin.audit_logs.show.timestamp') %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2"><%= l(@audit_log.created_at, format: :long) %></dd>
      </div>
      <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
        <dt class="text-sm font-medium text-gray-500"><%= t('admin.audit_logs.show.user') %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
          <% if @audit_log.user %>
            <%= link_to @audit_log.user.display_name, admin_user_path(@audit_log.user), class: "text-indigo-600 hover:text-indigo-900" %>
            (<%= @audit_log.user.email %>)
          <% else %>
            -
          <% end %>
        </dd>
      </div>
      <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
        <dt class="text-sm font-medium text-gray-500"><%= t('admin.audit_logs.show.action') %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
            <%= case @audit_log.action
                when /delete|reject|suspend/ then 'bg-red-100 text-red-800'
                when /approve|unsuspend/ then 'bg-green-100 text-green-800'
                when /change|update/ then 'bg-yellow-100 text-yellow-800'
                else 'bg-gray-100 text-gray-800'
                end %>">
            <%= @audit_log.action_name %>
          </span>
        </dd>
      </div>
      <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
        <dt class="text-sm font-medium text-gray-500"><%= t('admin.audit_logs.show.target') %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
          <%= @audit_log.target_type %> #<%= @audit_log.target_id %>
          <% if @audit_log.target %>
            <br><span class="text-gray-500"><%= t('admin.audit_logs.show.target_exists') %></span>
          <% else %>
            <br><span class="text-gray-500"><%= t('admin.audit_logs.show.target_deleted') %></span>
          <% end %>
        </dd>
      </div>
      <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
        <dt class="text-sm font-medium text-gray-500"><%= t('admin.audit_logs.show.ip_address') %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2"><%= @audit_log.ip_address || "-" %></dd>
      </div>
      <% if @audit_log.details.present? %>
        <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-500"><%= t('admin.audit_logs.show.details') %></dt>
          <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
            <pre class="bg-gray-100 p-4 rounded-md overflow-auto"><%= JSON.pretty_generate(@audit_log.details) %></pre>
          </dd>
        </div>
      <% end %>
    </dl>
  </div>
</div>
