<% content_for :title, t('admin.audit_logs.index.title') %>

<div class="sm:flex sm:items-center mb-6">
  <div class="sm:flex-auto">
    <h1 class="text-2xl font-bold text-gray-900"><%= t('admin.audit_logs.index.title') %></h1>
    <p class="mt-1 text-sm text-gray-500"><%= t('admin.audit_logs.index.subtitle') %></p>
  </div>
</div>

<!-- Filters -->
<div class="bg-white shadow rounded-lg p-4 mb-6">
  <%= form_with url: admin_audit_logs_path, method: :get, local: true, class: "grid grid-cols-1 sm:grid-cols-4 gap-4" do |form| %>
    <div>
      <%= form.select :action_type, [[t('admin.audit_logs.index.all_actions'), ""]] + AuditLog::ACTIONS.map { |a| [a.humanize, a] },
          { selected: params[:action_type] },
          class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>
    <div>
      <%= form.date_field :from, value: params[:from], placeholder: t('admin.audit_logs.index.from_date'),
          class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>
    <div>
      <%= form.date_field :to, value: params[:to], placeholder: t('admin.audit_logs.index.to_date'),
          class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>
    <div>
      <%= form.submit t('admin.audit_logs.index.filter'), class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 w-full justify-center" %>
    </div>
  <% end %>
</div>

<!-- Logs Table -->
<div class="bg-white shadow overflow-hidden sm:rounded-lg">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t('admin.audit_logs.index.timestamp') %></th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t('admin.audit_logs.index.user') %></th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t('admin.audit_logs.index.action') %></th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t('admin.audit_logs.index.target') %></th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t('admin.audit_logs.index.ip_address') %></th>
        <th scope="col" class="relative px-6 py-3"><span class="sr-only"><%= t('admin.audit_logs.index.details') %></span></th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% @audit_logs.each do |log| %>
        <tr>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
            <%= l(log.created_at, format: :short) %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap">
            <% if log.user %>
              <%= link_to log.user.display_name, admin_user_path(log.user), class: "text-sm text-indigo-600 hover:text-indigo-900" %>
            <% else %>
              <span class="text-sm text-gray-500">-</span>
            <% end %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
              <%= case log.action
                  when /delete|reject|suspend/ then 'bg-red-100 text-red-800'
                  when /approve|unsuspend/ then 'bg-green-100 text-green-800'
                  when /change|update/ then 'bg-yellow-100 text-yellow-800'
                  else 'bg-gray-100 text-gray-800'
                  end %>">
              <%= log.action_name %>
            </span>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
            <%= log.target_type %> #<%= log.target_id %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
            <%= log.ip_address || "-" %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
            <%= link_to t('admin.audit_logs.index.details'), admin_audit_log_path(log), class: "text-indigo-600 hover:text-indigo-900" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<% if @audit_logs.empty? %>
  <div class="text-center py-12 bg-white rounded-lg mt-6">
    <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
    </svg>
    <h3 class="mt-2 text-sm font-medium text-gray-900"><%= t('admin.audit_logs.index.no_logs') %></h3>
    <p class="mt-1 text-sm text-gray-500"><%= t('admin.audit_logs.index.no_logs_description') %></p>
  </div>
<% end %>

<!-- Pagination -->
<% if @audit_logs.respond_to?(:total_pages) && @audit_logs.total_pages > 1 %>
  <div class="mt-6">
    <%= paginate @audit_logs %>
  </div>
<% end %>
