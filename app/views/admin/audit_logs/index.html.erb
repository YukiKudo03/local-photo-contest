<% content_for :title, "監査ログ" %>

<div class="sm:flex sm:items-center mb-6">
  <div class="sm:flex-auto">
    <h1 class="text-2xl font-bold text-gray-900">監査ログ</h1>
    <p class="mt-1 text-sm text-gray-500">システムの重要な操作履歴を確認できます</p>
  </div>
</div>

<!-- Filters -->
<div class="bg-white shadow rounded-lg p-4 mb-6">
  <%= form_with url: admin_audit_logs_path, method: :get, local: true, class: "grid grid-cols-1 sm:grid-cols-4 gap-4" do |form| %>
    <div>
      <%= form.select :action_type, [["すべての操作", ""]] + AuditLog::ACTIONS.map { |a| [a.humanize, a] },
          { selected: params[:action_type] },
          class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>
    <div>
      <%= form.date_field :from, value: params[:from], placeholder: "開始日",
          class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>
    <div>
      <%= form.date_field :to, value: params[:to], placeholder: "終了日",
          class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>
    <div>
      <%= form.submit "フィルター", class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 w-full justify-center" %>
    </div>
  <% end %>
</div>

<!-- Logs Table -->
<div class="bg-white shadow overflow-hidden sm:rounded-lg">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">日時</th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ユーザー</th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">操作</th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">対象</th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">IPアドレス</th>
        <th scope="col" class="relative px-6 py-3"><span class="sr-only">詳細</span></th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% @audit_logs.each do |log| %>
        <tr>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
            <%= log.created_at.strftime("%Y/%m/%d %H:%M:%S") %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap">
            <% if log.user %>
              <%= link_to log.user.display_name, admin_user_path(log.user), class: "text-sm text-indigo-600 hover:text-indigo-900" %>
            <% else %>
              <span class="text-sm text-gray-500">-</span>
            <% end %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
              <%= case log.action
                  when /delete|reject|suspend/ then 'bg-red-100 text-red-800'
                  when /approve|unsuspend/ then 'bg-green-100 text-green-800'
                  when /change|update/ then 'bg-yellow-100 text-yellow-800'
                  else 'bg-gray-100 text-gray-800'
                  end %>">
              <%= log.action_name %>
            </span>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
            <%= log.target_type %> #<%= log.target_id %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
            <%= log.ip_address || "-" %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
            <%= link_to "詳細", admin_audit_log_path(log), class: "text-indigo-600 hover:text-indigo-900" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<% if @audit_logs.empty? %>
  <div class="text-center py-12 bg-white rounded-lg mt-6">
    <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
    </svg>
    <h3 class="mt-2 text-sm font-medium text-gray-900">ログがありません</h3>
    <p class="mt-1 text-sm text-gray-500">検索条件に該当するログがありません</p>
  </div>
<% end %>

<!-- Pagination -->
<% if @audit_logs.respond_to?(:total_pages) && @audit_logs.total_pages > 1 %>
  <div class="mt-6">
    <%= paginate @audit_logs %>
  </div>
<% end %>
