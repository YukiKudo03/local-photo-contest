<%= form_with model: [:admin, category], local: true do |form| %>
  <% if category.errors.any? %>
    <div class="rounded-md bg-red-50 p-4 mb-6">
      <div class="flex">
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800"><%= t('admin.categories.form.error_title') %></h3>
          <ul class="mt-2 text-sm text-red-700 list-disc list-inside">
            <% category.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <div class="space-y-6">
    <div>
      <%= form.label :name, t('admin.categories.form.name_label'), class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= form.label :description, t('admin.categories.form.description_label'), class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_area :description, rows: 3, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= form.label :position, t('admin.categories.form.position_label'), class: "block text-sm font-medium text-gray-700" %>
      <%= form.number_field :position, class: "mt-1 block w-32 rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div class="flex justify-end space-x-3">
      <%= link_to t('admin.categories.form.cancel'), admin_categories_path, class: "px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md shadow-sm hover:bg-gray-50" %>
      <%= form.submit category.persisted? ? t('admin.categories.form.submit_update') : t('admin.categories.form.submit_create'), class: "px-4 py-2 text-sm font-medium text-white bg-indigo-600 border border-transparent rounded-md shadow-sm hover:bg-indigo-700 cursor-pointer" %>
    </div>
  </div>
<% end %>
