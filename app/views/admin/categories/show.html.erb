<div class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
  <h1 class="text-2xl font-bold text-gray-900 mb-6"><%= @category.name %></h1>

  <div class="bg-white shadow overflow-hidden sm:rounded-lg mb-6">
    <div class="px-4 py-5 sm:px-6">
      <h3 class="text-lg leading-6 font-medium text-gray-900"><%= t('admin.categories.show.details', default: 'カテゴリ詳細') %></h3>
    </div>
    <div class="border-t border-gray-200 px-4 py-5 sm:px-6">
      <dl class="grid grid-cols-1 gap-x-4 gap-y-4 sm:grid-cols-2">
        <div>
          <dt class="text-sm font-medium text-gray-500"><%= t('activerecord.attributes.category.name', default: '名前') %></dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @category.name %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500"><%= t('activerecord.attributes.category.description', default: '説明') %></dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @category.description %></dd>
        </div>
      </dl>
    </div>
  </div>

  <% if @contests.any? %>
    <h2 class="text-xl font-semibold text-gray-900 mb-4"><%= t('admin.categories.show.contests', default: '関連コンテスト') %></h2>
    <div class="bg-white shadow overflow-hidden sm:rounded-md">
      <ul class="divide-y divide-gray-200">
        <% @contests.each do |contest| %>
          <li class="px-4 py-4">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm font-medium text-indigo-600"><%= contest.title %></p>
                <p class="text-sm text-gray-500"><%= contest.user&.name %></p>
              </div>
              <div class="text-sm text-gray-500">
                <%= l(contest.created_at, format: :short) %>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mt-6">
    <%= link_to t('admin.categories.show.back', default: 'カテゴリ一覧に戻る'), admin_categories_path, class: "text-indigo-600 hover:text-indigo-800" %>
  </div>
</div>
