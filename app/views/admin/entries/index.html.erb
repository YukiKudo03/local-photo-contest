<% content_for :title, t('admin.entries.index.title') %>

<div class="sm:flex sm:items-center mb-6">
  <div class="sm:flex-auto">
    <h1 class="text-2xl font-bold text-gray-900"><%= t('admin.entries.index.title') %></h1>
    <p class="mt-1 text-sm text-gray-500"><%= t('admin.entries.index.subtitle') %></p>
  </div>
</div>

<div data-controller="bulk-select">
  <%# Bulk Actions Bar %>
  <div data-bulk-select-target="actions" class="hidden mb-4 p-4 bg-indigo-50 rounded-lg flex items-center gap-4">
    <span class="text-sm text-indigo-700">
      <span data-bulk-select-target="count">0</span><%= t('admin.entries.index.selected') %>
    </span>
    <form data-bulk-select-target="form" method="post" data-turbo="false">
      <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
      <button type="submit" data-action="click->bulk-select#submitAction" data-bulk-action="<%= bulk_approve_admin_entries_path %>"
              class="px-3 py-1.5 text-sm font-medium text-white bg-green-600 hover:bg-green-700 rounded-md">
        <%= t('admin.entries.index.approve_selected') %>
      </button>
      <button type="submit" data-action="click->bulk-select#submitAction" data-bulk-action="<%= bulk_reject_admin_entries_path %>"
              class="px-3 py-1.5 text-sm font-medium text-white bg-red-600 hover:bg-red-700 rounded-md ml-2">
        <%= t('admin.entries.index.reject_selected') %>
      </button>
    </form>
  </div>

  <div class="bg-white shadow overflow-hidden sm:rounded-lg">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left">
            <input type="checkbox" data-bulk-select-target="selectAll" data-action="change->bulk-select#toggleAll"
                   class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
          </th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t('admin.entries.index.entry') %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t('admin.entries.index.contest') %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t('admin.entries.index.user') %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t('admin.entries.index.status') %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t('admin.entries.index.submitted_at') %></th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @entries.each do |entry| %>
          <tr>
            <td class="px-6 py-4">
              <input type="checkbox" value="<%= entry.id %>" data-bulk-select-target="checkbox"
                     data-action="change->bulk-select#toggle" name="entry_ids[]"
                     class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
              <%= entry.title.presence || t('admin.entries.index.untitled') %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= entry.contest.title %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= entry.user.display_name %></td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                <%= entry.moderation_hidden? ? 'bg-red-100 text-red-800' : 'bg-yellow-100 text-yellow-800' %>">
                <%= entry.moderation_status.humanize %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= l(entry.created_at, format: :short) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if @entries.respond_to?(:total_pages) && @entries.total_pages > 1 %>
    <div class="mt-6"><%= paginate @entries %></div>
  <% end %>
</div>
