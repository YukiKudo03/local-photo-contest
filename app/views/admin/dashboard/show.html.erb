<% content_for :title, t('admin.dashboard.title') %>

<%# チュートリアル: 管理者オンボーディング %>
<%= render "tutorials/welcome_modal", tutorial_type: "admin_onboarding" if defined?(should_show_tutorial?) && should_show_tutorial?("admin_onboarding") %>
<%= render "tutorials/tutorial_container", tutorial_type: "admin_onboarding", auto_start: false if defined?(should_show_tutorial?) %>

<div class="mb-8 flex items-center justify-between">
  <div>
    <h1 class="text-2xl font-bold text-gray-900"><%= t('admin.dashboard.title') %></h1>
    <p class="mt-1 text-sm text-gray-500"><%= t('admin.dashboard.subtitle') %></p>
  </div>
  <%= render "tutorials/help_button", tutorial_type: "admin_onboarding" if defined?(render) %>
</div>

<!-- Stats Cards -->
<div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4 mb-8" data-tutorial="admin-stats">
  <div class="bg-white overflow-hidden shadow rounded-lg">
    <div class="p-5">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <svg class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
        </div>
        <div class="ml-5 w-0 flex-1">
          <dl>
            <dt class="text-sm font-medium text-gray-500 truncate"><%= t('admin.dashboard.total_users_label') %></dt>
            <dd class="flex items-baseline">
              <div class="text-2xl font-semibold text-gray-900"><%= number_with_delimiter(@stats[:total_users]) %></div>
              <div class="ml-2 flex items-baseline text-sm font-semibold text-green-600">
                +<%= @stats[:users_today] %> <%= t('admin.dashboard.today') %>
              </div>
            </dd>
          </dl>
        </div>
      </div>
    </div>
  </div>

  <div class="bg-white overflow-hidden shadow rounded-lg">
    <div class="p-5">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <svg class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
          </svg>
        </div>
        <div class="ml-5 w-0 flex-1">
          <dl>
            <dt class="text-sm font-medium text-gray-500 truncate"><%= t('admin.dashboard.total_contests_label') %></dt>
            <dd class="flex items-baseline">
              <div class="text-2xl font-semibold text-gray-900"><%= number_with_delimiter(@stats[:total_contests]) %></div>
              <div class="ml-2 flex items-baseline text-sm font-semibold text-blue-600">
                <%= @stats[:active_contests] %> <%= t('admin.dashboard.active') %>
              </div>
            </dd>
          </dl>
        </div>
      </div>
    </div>
  </div>

  <div class="bg-white overflow-hidden shadow rounded-lg">
    <div class="p-5">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <svg class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
        <div class="ml-5 w-0 flex-1">
          <dl>
            <dt class="text-sm font-medium text-gray-500 truncate"><%= t('admin.dashboard.total_entries_label') %></dt>
            <dd class="flex items-baseline">
              <div class="text-2xl font-semibold text-gray-900"><%= number_with_delimiter(@stats[:total_entries]) %></div>
              <div class="ml-2 flex items-baseline text-sm font-semibold text-green-600">
                +<%= @stats[:entries_today] %> <%= t('admin.dashboard.today') %>
              </div>
            </dd>
          </dl>
        </div>
      </div>
    </div>
  </div>

  <div class="bg-white overflow-hidden shadow rounded-lg">
    <div class="p-5">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <svg class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
        </div>
        <div class="ml-5 w-0 flex-1">
          <dl>
            <dt class="text-sm font-medium text-gray-500 truncate"><%= t('admin.dashboard.pending_moderation') %></dt>
            <dd class="flex items-baseline">
              <div class="text-2xl font-semibold <%= @stats[:pending_moderation] > 0 ? 'text-amber-600' : 'text-gray-900' %>">
                <%= number_with_delimiter(@stats[:pending_moderation]) %>
              </div>
            </dd>
          </dl>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Charts Section -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8" data-tutorial="admin-charts">
  <!-- User Growth Chart -->
  <div class="bg-white shadow rounded-lg p-6">
    <h3 class="text-lg font-medium text-gray-900 mb-4"><%= t('admin.dashboard.user_registrations_chart') %></h3>
    <div class="h-64" data-controller="chart" data-chart-type-value="line" data-chart-data-value="<%= @user_stats.to_json %>">
      <canvas data-chart-target="canvas"></canvas>
    </div>
  </div>

  <!-- Entry Growth Chart -->
  <div class="bg-white shadow rounded-lg p-6">
    <h3 class="text-lg font-medium text-gray-900 mb-4"><%= t('admin.dashboard.entries_chart') %></h3>
    <div class="h-64" data-controller="chart" data-chart-type-value="line" data-chart-data-value="<%= @entry_stats.to_json %>">
      <canvas data-chart-target="canvas"></canvas>
    </div>
  </div>
</div>

<!-- Recent Activity -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6" data-tutorial="admin-activity">
  <!-- Recent Users -->
  <div class="bg-white shadow rounded-lg">
    <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
      <h3 class="text-lg font-medium text-gray-900"><%= t('admin.dashboard.recent_users') %></h3>
    </div>
    <ul class="divide-y divide-gray-200">
      <% @recent_users.each do |user| %>
        <li class="px-4 py-4">
          <div class="flex items-center space-x-3">
            <div class="flex-shrink-0 h-10 w-10 rounded-full bg-indigo-100 flex items-center justify-center">
              <span class="text-indigo-600 font-medium"><%= user.initial %></span>
            </div>
            <div class="flex-1 min-w-0">
              <%= link_to admin_user_path(user), class: "text-sm font-medium text-gray-900 hover:text-indigo-600" do %>
                <%= user.display_name %>
              <% end %>
              <p class="text-sm text-gray-500"><%= user.email %></p>
            </div>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
              <%= user.admin? ? 'bg-red-100 text-red-800' : user.organizer? ? 'bg-blue-100 text-blue-800' : 'bg-gray-100 text-gray-800' %>">
              <%= user.role.humanize %>
            </span>
          </div>
        </li>
      <% end %>
    </ul>
    <div class="px-4 py-3 bg-gray-50 text-right">
      <%= link_to t('admin.dashboard.view_all'), admin_users_path, class: "text-sm font-medium text-indigo-600 hover:text-indigo-500" %>
    </div>
  </div>

  <!-- Recent Contests -->
  <div class="bg-white shadow rounded-lg">
    <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
      <h3 class="text-lg font-medium text-gray-900"><%= t('admin.dashboard.recent_contests') %></h3>
    </div>
    <ul class="divide-y divide-gray-200">
      <% @recent_contests.each do |contest| %>
        <li class="px-4 py-4">
          <div class="flex items-center justify-between">
            <div class="min-w-0 flex-1">
              <%= link_to admin_contest_path(contest), class: "text-sm font-medium text-gray-900 hover:text-indigo-600 truncate block" do %>
                <%= contest.title %>
              <% end %>
              <p class="text-sm text-gray-500"><%= contest.user.display_name %></p>
            </div>
            <span class="ml-2 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
              <%= contest.accepting_entries? ? 'bg-green-100 text-green-800' : contest.finished? ? 'bg-gray-100 text-gray-800' : 'bg-yellow-100 text-yellow-800' %>">
              <%= contest.status.humanize %>
            </span>
          </div>
        </li>
      <% end %>
    </ul>
    <div class="px-4 py-3 bg-gray-50 text-right">
      <%= link_to t('admin.dashboard.view_all'), admin_contests_path, class: "text-sm font-medium text-indigo-600 hover:text-indigo-500" %>
    </div>
  </div>

  <!-- Recent Entries -->
  <div class="bg-white shadow rounded-lg">
    <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
      <h3 class="text-lg font-medium text-gray-900"><%= t('admin.dashboard.recent_entries') %></h3>
    </div>
    <ul class="divide-y divide-gray-200">
      <% @recent_entries.each do |entry| %>
        <li class="px-4 py-4">
          <div class="flex items-center space-x-3">
            <% if entry.photo.attached? %>
              <%= image_tag entry.photo.variant(resize_to_fill: [40, 40]), alt: entry.title.presence || t('admin.dashboard.entry_image_alt'), class: "h-10 w-10 rounded object-cover", loading: "lazy" %>
            <% else %>
              <div class="h-10 w-10 rounded bg-gray-100 flex items-center justify-center">
                <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
            <% end %>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-gray-900 truncate"><%= entry.title.presence || t('admin.dashboard.untitled') %></p>
              <p class="text-sm text-gray-500 truncate"><%= entry.contest.title %></p>
            </div>
          </div>
        </li>
      <% end %>
    </ul>
  </div>
</div>
