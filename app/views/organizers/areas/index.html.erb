<%# チュートリアル: エリア管理 %>
<%= render "tutorials/tutorial_container", tutorial_type: "area_management", auto_start: should_show_tutorial?("area_management") if defined?(should_show_tutorial?) %>

<!-- Page Header -->
<div class="mb-8 flex items-center justify-between">
  <div>
    <h1 class="text-2xl font-bold text-gray-900"><%= t('organizers.areas.index.title') %></h1>
    <p class="mt-1 text-sm text-gray-500"><%= t('organizers.areas.index.subtitle') %></p>
  </div>
  <div class="flex items-center gap-3">
    <%= render "tutorials/help_button", tutorial_type: "area_management" %>
    <%= link_to new_organizers_area_path, data: { tutorial: "new-area-button" }, class: "inline-flex items-center px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg transition-colors" do %>
      <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
      </svg>
      <%= t('organizers.areas.index.new_area') %>
    <% end %>
  </div>
</div>

<!-- Area Grid -->
<% if @areas.any? %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% @areas.each do |area| %>
      <%= link_to organizers_area_path(area), class: "block bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow" do %>
        <!-- Map Preview or Placeholder -->
        <div class="aspect-video bg-gray-100 flex items-center justify-center">
          <% if area.center_coordinates %>
            <div class="w-full h-full relative">
              <div class="absolute inset-0 bg-gradient-to-br from-blue-50 to-indigo-100 flex items-center justify-center">
                <svg class="h-12 w-12 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
            </div>
          <% else %>
            <svg class="h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
            </svg>
          <% end %>
        </div>

        <div class="p-4">
          <!-- Area Name -->
          <h3 class="text-lg font-semibold text-gray-900 line-clamp-1"><%= area.name %></h3>

          <!-- Address -->
          <% if area.full_address.present? %>
            <p class="mt-1 text-sm text-gray-500 line-clamp-1 flex items-center">
              <svg class="mr-1 h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <%= area.full_address %>
            </p>
          <% end %>

          <!-- Stats -->
          <div class="mt-3 flex items-center space-x-4 text-xs text-gray-400">
            <span class="flex items-center">
              <svg class="mr-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
              </svg>
              <%= t('organizers.areas.index.contests_count') %>: <%= area.contests.count %>
            </span>
            <% if area.has_boundary? %>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                <%= t('organizers.areas.index.boundary_set') %>
              </span>
            <% end %>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <!-- Empty State -->
  <div class="text-center py-12 bg-white rounded-xl shadow-sm border border-gray-100">
    <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
    </svg>
    <h3 class="mt-4 text-lg font-medium text-gray-900"><%= t('organizers.areas.index.no_areas') %></h3>
    <p class="mt-2 text-sm text-gray-500"><%= t('organizers.areas.index.create_first') %></p>
    <div class="mt-6">
      <%= link_to new_organizers_area_path, class: "inline-flex items-center px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg transition-colors" do %>
        <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        <%= t('organizers.areas.index.new_area') %>
      <% end %>
    </div>
  </div>
<% end %>
