<%= form_with model: [:organizers, area], class: "space-y-6" do |f| %>
  <% if area.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <div class="flex">
        <svg class="h-5 w-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            <%= t('organizers.shared.errors_title', count: area.errors.count) %>
          </h3>
          <ul class="mt-2 text-sm text-red-700 list-disc list-inside">
            <% area.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100">
      <h2 class="text-lg font-semibold text-gray-900"><%= t('organizers.contests.form.basic_info') %></h2>
    </div>
    <div class="p-6 space-y-6">
      <!-- Name -->
      <div>
        <%= f.label :name, t('organizers.areas.form.name_label'), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :name, placeholder: t('organizers.areas.form.name_placeholder'), class: "w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors" %>
        <p class="mt-1 text-xs text-gray-500"><%= t('organizers.areas.form.name_hint') %></p>
      </div>

      <!-- Description -->
      <div>
        <%= f.label :description, t('organizers.areas.form.description_label'), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_area :description, rows: 3, placeholder: t('organizers.areas.form.description_placeholder'), class: "w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors resize-none" %>
        <p class="mt-1 text-xs text-gray-500"><%= t('organizers.areas.form.description_hint') %></p>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100">
      <h2 class="text-lg font-semibold text-gray-900"><%= t('organizers.areas.form.address_title') %></h2>
    </div>
    <div class="p-6 space-y-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Prefecture -->
        <div>
          <%= f.label :prefecture, t('organizers.areas.form.prefecture_label'), class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.select :prefecture,
            options_for_select([
              ["北海道", "北海道"],
              ["青森県", "青森県"], ["岩手県", "岩手県"], ["宮城県", "宮城県"], ["秋田県", "秋田県"], ["山形県", "山形県"], ["福島県", "福島県"],
              ["茨城県", "茨城県"], ["栃木県", "栃木県"], ["群馬県", "群馬県"], ["埼玉県", "埼玉県"], ["千葉県", "千葉県"], ["東京都", "東京都"], ["神奈川県", "神奈川県"],
              ["新潟県", "新潟県"], ["富山県", "富山県"], ["石川県", "石川県"], ["福井県", "福井県"], ["山梨県", "山梨県"], ["長野県", "長野県"],
              ["岐阜県", "岐阜県"], ["静岡県", "静岡県"], ["愛知県", "愛知県"],
              ["三重県", "三重県"], ["滋賀県", "滋賀県"], ["京都府", "京都府"], ["大阪府", "大阪府"], ["兵庫県", "兵庫県"], ["奈良県", "奈良県"], ["和歌山県", "和歌山県"],
              ["鳥取県", "鳥取県"], ["島根県", "島根県"], ["岡山県", "岡山県"], ["広島県", "広島県"], ["山口県", "山口県"],
              ["徳島県", "徳島県"], ["香川県", "香川県"], ["愛媛県", "愛媛県"], ["高知県", "高知県"],
              ["福岡県", "福岡県"], ["佐賀県", "佐賀県"], ["長崎県", "長崎県"], ["熊本県", "熊本県"], ["大分県", "大分県"], ["宮崎県", "宮崎県"], ["鹿児島県", "鹿児島県"],
              ["沖縄県", "沖縄県"]
            ], area.prefecture),
            { include_blank: t('organizers.areas.form.prefecture_placeholder') },
            class: "w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors"
          %>
          <p class="mt-1 text-xs text-gray-500"><%= t('organizers.areas.form.optional') %></p>
        </div>

        <!-- City -->
        <div>
          <%= f.label :city, t('organizers.areas.form.city_label'), class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :city, placeholder: t('organizers.areas.form.city_placeholder'), class: "w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors" %>
          <p class="mt-1 text-xs text-gray-500"><%= t('organizers.areas.form.city_hint') %></p>
        </div>

        <!-- Address -->
        <div>
          <%= f.label :address, t('organizers.areas.form.address_label'), class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :address, placeholder: t('organizers.areas.form.address_placeholder'), class: "w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors" %>
          <p class="mt-1 text-xs text-gray-500"><%= t('organizers.areas.form.address_hint') %></p>
        </div>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100">
      <h2 class="text-lg font-semibold text-gray-900"><%= t('organizers.areas.form.coordinates_title') %></h2>
      <p class="mt-1 text-sm text-gray-500"><%= t('organizers.areas.form.coordinates_hint') %></p>
    </div>
    <div class="p-6 space-y-4">
      <!-- Map for coordinate selection -->
      <div data-controller="coordinate-picker"
           data-coordinate-picker-latitude-value="<%= area.latitude || 35.6812 %>"
           data-coordinate-picker-longitude-value="<%= area.longitude || 139.7671 %>"
           data-coordinate-picker-zoom-value="13"
           class="space-y-4">
        <div data-coordinate-picker-target="container" class="map-container map-container-md rounded-lg"></div>

        <!-- Coordinate display -->
        <div class="flex items-center space-x-4">
          <div class="flex-1">
            <label class="block text-sm font-medium text-gray-700 mb-1"><%= t('organizers.areas.form.selected_coordinates') %></label>
            <div data-coordinate-picker-target="display" class="coordinate-display">
              <% if area.latitude.present? && area.longitude.present? %>
                <%= t('organizers.areas.form.latitude') %>: <%= area.latitude %>, <%= t('organizers.areas.form.longitude') %>: <%= area.longitude %>
              <% else %>
                <%= t('organizers.areas.form.click_map') %>
              <% end %>
            </div>
          </div>
          <button type="button"
                  data-action="coordinate-picker#clear"
                  class="px-4 py-2 text-sm text-gray-600 hover:text-gray-900 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
            <%= t('organizers.areas.form.clear') %>
          </button>
        </div>

        <!-- Hidden fields for coordinates -->
        <%= f.hidden_field :latitude, data: { coordinate_picker_target: "latitudeInput" } %>
        <%= f.hidden_field :longitude, data: { coordinate_picker_target: "longitudeInput" } %>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100">
      <h2 class="text-lg font-semibold text-gray-900"><%= t('organizers.areas.form.boundary_title') %></h2>
      <p class="mt-1 text-sm text-gray-500"><%= t('organizers.areas.form.boundary_hint') %></p>
    </div>
    <div class="p-6">
      <div>
        <%= f.label :boundary_geojson, t('organizers.areas.form.geojson_label'), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_area :boundary_geojson, rows: 5, placeholder: '{"type": "Polygon", "coordinates": [[...]]}', class: "w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors font-mono text-sm" %>
        <p class="mt-1 text-xs text-gray-500"><%= t('organizers.areas.form.geojson_hint') %></p>
      </div>
    </div>
  </div>

  <!-- Form Actions -->
  <div class="flex items-center justify-end space-x-4">
    <%= link_to t('organizers.areas.form.cancel'), area.persisted? ? organizers_area_path(area) : organizers_areas_path, class: "px-6 py-3 border border-gray-300 rounded-lg text-gray-700 font-medium hover:bg-gray-50 transition-colors" %>
    <%= f.submit area.persisted? ? t('organizers.areas.form.submit_update') : t('organizers.areas.form.submit_create'), class: "px-6 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg cursor-pointer transition-colors" %>
  </div>
<% end %>
