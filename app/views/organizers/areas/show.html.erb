<!-- Page Header -->
<div class="mb-8">
  <div class="flex items-center justify-between">
    <div>
      <%= link_to organizers_areas_path, class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700 mb-2" do %>
        <svg class="mr-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        <%= t('organizers.areas.show.back') %>
      <% end %>
      <h1 class="text-2xl font-bold text-gray-900"><%= @area.name %></h1>
    </div>
    <div class="flex items-center space-x-3">
      <% if @area.has_boundary? %>
        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
          <%= t('organizers.areas.index.boundary_set') %>
        </span>
      <% end %>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <!-- Main Content -->
  <div class="lg:col-span-2 space-y-6">
    <!-- Map Preview -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100">
        <h2 class="text-lg font-semibold text-gray-900"><%= t('organizers.areas.show.map') %></h2>
      </div>
      <div class="p-4">
        <% if @area.center_coordinates %>
          <div data-controller="map"
               data-map-latitude-value="<%= @area.center_coordinates[0] %>"
               data-map-longitude-value="<%= @area.center_coordinates[1] %>"
               data-map-zoom-value="15"
               <% if @area.has_boundary? %>
               data-map-boundary-geojson-value="<%= @area.boundary_geojson %>"
               <% end %>
               data-map-interactive-value="false"
               class="map-container map-container-md">
            <div data-map-target="container" class="w-full h-full"></div>
          </div>
        <% else %>
          <div class="aspect-video bg-gray-100 rounded-lg flex items-center justify-center">
            <div class="text-center">
              <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <p class="mt-2 text-sm text-gray-400"><%= t('organizers.areas.show.no_coordinates') %></p>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Area Details -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100">
        <h2 class="text-lg font-semibold text-gray-900"><%= t('organizers.areas.show.details') %></h2>
      </div>
      <div class="p-6 space-y-6">
        <% if @area.full_address.present? %>
          <div>
            <dt class="text-sm font-medium text-gray-500"><%= t('organizers.spots.form.address_label') %></dt>
            <dd class="mt-1 text-gray-900"><%= @area.full_address %></dd>
          </div>
        <% end %>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          <div>
            <dt class="text-sm font-medium text-gray-500"><%= t('organizers.areas.show.prefecture') %></dt>
            <dd class="mt-1 text-gray-900">
              <%= @area.prefecture.presence || tag.span(t('organizers.contests.show.not_set'), class: 'text-gray-400') %>
            </dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500"><%= t('organizers.areas.show.city') %></dt>
            <dd class="mt-1 text-gray-900">
              <%= @area.city.presence || tag.span(t('organizers.contests.show.not_set'), class: 'text-gray-400') %>
            </dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500"><%= t('organizers.areas.show.street') %></dt>
            <dd class="mt-1 text-gray-900">
              <%= @area.address.presence || tag.span(t('organizers.contests.show.not_set'), class: 'text-gray-400') %>
            </dd>
          </div>
        </div>

        <% if @area.description.present? %>
          <div>
            <dt class="text-sm font-medium text-gray-500"><%= t('organizers.areas.form.description_label') %></dt>
            <dd class="mt-1 text-gray-900 whitespace-pre-wrap"><%= @area.description %></dd>
          </div>
        <% end %>

        <% if @area.center_coordinates %>
          <div>
            <dt class="text-sm font-medium text-gray-500"><%= t('organizers.areas.show.coordinates') %></dt>
            <dd class="mt-1">
              <span class="coordinate-display">
                <%= t('organizers.areas.show.latitude') %>: <%= @area.latitude %>, <%= t('organizers.areas.show.longitude') %>: <%= @area.longitude %>
              </span>
            </dd>
          </div>
        <% end %>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 pt-4 border-t border-gray-100">
          <div>
            <dt class="text-sm font-medium text-gray-500"><%= t('organizers.areas.show.created_at') %></dt>
            <dd class="mt-1 text-gray-900"><%= l(@area.created_at, format: :long) %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500"><%= t('organizers.areas.show.updated_at') %></dt>
            <dd class="mt-1 text-gray-900"><%= l(@area.updated_at, format: :long) %></dd>
          </div>
        </div>
      </div>
    </div>

    <!-- Associated Contests -->
    <% if @area.contests.any? %>
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100">
          <h2 class="text-lg font-semibold text-gray-900"><%= t('organizers.areas.show.related_contests') %></h2>
        </div>
        <div class="divide-y divide-gray-100">
          <% @area.contests.each do |contest| %>
            <%= link_to organizers_contest_path(contest), class: "block px-6 py-4 hover:bg-gray-50 transition-colors" do %>
              <div class="flex items-center justify-between">
                <div>
                  <p class="font-medium text-gray-900"><%= contest.title %></p>
                  <p class="text-sm text-gray-500"><%= contest.theme %></p>
                </div>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= contest.published? ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800' %>">
<%= contest.published? ? t('organizers.contests.index.published') : t('organizers.contests.index.draft') %>
                </span>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Sidebar Actions -->
  <div class="space-y-6">
    <!-- Action Buttons -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100">
        <h2 class="text-lg font-semibold text-gray-900"><%= t('organizers.contests.show.actions') %></h2>
      </div>
      <div class="p-6 space-y-3">
        <%= link_to edit_organizers_area_path(@area), class: "flex items-center w-full p-3 rounded-lg border border-gray-200 hover:border-indigo-300 hover:bg-indigo-50 transition-colors group" do %>
          <div class="w-10 h-10 bg-indigo-100 rounded-lg flex items-center justify-center group-hover:bg-indigo-200 transition-colors">
            <svg class="h-5 w-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
            </svg>
          </div>
          <div class="ml-3">
<p class="text-sm font-medium text-gray-900"><%= t('organizers.areas.show.edit') %></p>
            <p class="text-xs text-gray-500"><%= t('organizers.areas.show.edit_desc') %></p>
          </div>
        <% end %>

        <% if @area.contests.empty? %>
          <%= button_to organizers_area_path(@area), method: :delete, data: { turbo_confirm: t('organizers.areas.show.delete_confirm') }, class: "flex items-center w-full p-3 rounded-lg border border-gray-200 hover:border-red-300 hover:bg-red-50 transition-colors group" do %>
            <div class="w-10 h-10 bg-red-100 rounded-lg flex items-center justify-center group-hover:bg-red-200 transition-colors">
              <svg class="h-5 w-5 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
              </svg>
            </div>
            <div class="ml-3 text-left">
<p class="text-sm font-medium text-gray-900"><%= t('organizers.areas.show.delete') %></p>
              <p class="text-xs text-gray-500"><%= t('organizers.areas.show.delete_desc') %></p>
            </div>
          <% end %>
        <% else %>
          <div class="flex items-center w-full p-3 rounded-lg border border-gray-200 bg-gray-50 cursor-not-allowed">
            <div class="w-10 h-10 bg-gray-100 rounded-lg flex items-center justify-center">
              <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
              </svg>
            </div>
            <div class="ml-3">
<p class="text-sm font-medium text-gray-400"><%= t('organizers.areas.show.delete') %></p>
              <p class="text-xs text-gray-400"><%= t('organizers.areas.show.cannot_delete') %></p>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Stats -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100">
        <h2 class="text-lg font-semibold text-gray-900"><%= t('organizers.areas.show.statistics') %></h2>
      </div>
      <div class="p-6">
        <div class="space-y-4">
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-500"><%= t('organizers.areas.show.related_contests') %></span>
            <span class="text-lg font-semibold text-gray-900"><%= @area.contests.count %></span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-500"><%= t('organizers.areas.show.boundary_setting') %></span>
            <span class="text-sm font-medium <%= @area.has_boundary? ? 'text-green-600' : 'text-gray-400' %>">
<%= @area.has_boundary? ? t('organizers.areas.show.configured') : t('organizers.contests.show.not_set') %>
            </span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-500"><%= t('organizers.areas.show.coordinates') %></span>
            <span class="text-sm font-medium <%= @area.center_coordinates ? 'text-green-600' : 'text-gray-400' %>">
<%= @area.center_coordinates ? t('organizers.areas.show.configured') : t('organizers.contests.show.not_set') %>
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
