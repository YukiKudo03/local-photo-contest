<!-- Page Header -->
<div class="mb-8">
  <%= link_to organizers_contest_spots_path(@contest), class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700 mb-2" do %>
    <svg class="mr-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
    </svg>
    <%= t('organizers.spots.new.back') %>
  <% end %>
  <h1 class="text-2xl font-bold text-gray-900"><%= t('organizers.spots.merge.title') %></h1>
  <p class="mt-1 text-sm text-gray-500"><%= t('organizers.spots.merge.subtitle') %></p>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
  <!-- Source Spot Info -->
  <div class="mb-6 p-4 bg-amber-50 border border-amber-200 rounded-lg">
    <h2 class="text-lg font-semibold text-amber-800 mb-2"><%= t('organizers.spots.merge.source_spot') %></h2>
    <div class="flex items-center space-x-4">
      <div class="flex-shrink-0 h-12 w-12 rounded-lg bg-amber-100 flex items-center justify-center">
        <svg class="h-6 w-6 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
      </div>
      <div>
        <p class="text-lg font-medium text-gray-900"><%= @spot.name %></p>
        <p class="text-sm text-gray-500"><%= @spot.category_name %> | <%= @spot.address.presence || t('organizers.contests.show.not_set') %></p>
      </div>
    </div>
  </div>

  <!-- Preview Info -->
  <div class="mb-6 p-4 bg-blue-50 border border-blue-200 rounded-lg">
    <h3 class="text-sm font-semibold text-blue-800 mb-2"><%= t('organizers.spots.merge.data_to_move') %></h3>
    <ul class="text-sm text-blue-700 space-y-1">
      <li><%= t('organizers.spots.merge.entries_move', count: @entries_count) %></li>
      <li><%= t('organizers.spots.merge.votes_move', count: @votes_count) %></li>
    </ul>
  </div>

  <!-- Merge Form -->
  <%= form_with url: merge_organizers_contest_spot_path(@contest, @spot), method: :post, class: "space-y-6" do |f| %>
    <div>
      <%= label_tag :primary_spot_id, t('organizers.spots.merge.target_spot'), class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= select_tag :primary_spot_id,
          options_from_collection_for_select(@available_spots, :id, :name),
          prompt: t('organizers.spots.merge.select_target'),
          class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500",
          required: true %>
      <p class="mt-1 text-sm text-gray-500"><%= t('organizers.spots.merge.target_hint') %></p>
    </div>

    <div class="flex items-center justify-end space-x-4">
      <%= link_to t('organizers.spots.form.cancel'), organizers_contest_spots_path(@contest),
          class: "px-4 py-2 text-sm font-medium text-gray-700 hover:text-gray-900" %>
      <%= submit_tag t('organizers.spots.merge.execute'),
          class: "px-6 py-2 bg-amber-600 hover:bg-amber-700 text-white font-medium rounded-lg transition-colors cursor-pointer",
          data: { turbo_confirm: t('organizers.spots.merge.confirm', name: @spot.name) } %>
    </div>
  <% end %>
</div>
