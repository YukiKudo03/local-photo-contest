<!-- Page Header -->
<div class="mb-8">
  <%= link_to organizers_contest_spots_path(@contest), class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700 mb-2" do %>
    <svg class="mr-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
    </svg>
    スポット一覧に戻る
  <% end %>
  <h1 class="text-2xl font-bold text-gray-900">スポット編集</h1>
  <p class="mt-1 text-sm text-gray-500"><%= @spot.name %> の情報を編集します</p>
</div>

<%= render "form", spot: @spot %>
