<!-- Page Header -->
<div class="mb-8">
  <h1 class="text-2xl font-bold text-gray-900"><%= t('organizers.contest_templates.new.title') %></h1>
  <p class="mt-1 text-sm text-gray-500"><%= t('organizers.contest_templates.new.subtitle', title: @contest.title) %></p>
</div>

<div class="max-w-2xl">
  <%= form_with model: @template, url: organizers_contest_templates_path(contest_id: @contest.id), class: "space-y-6" do |form| %>
    <% if @template.errors.any? %>
      <div class="rounded-md bg-red-50 p-4">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-red-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800"><%= t('organizers.contest_templates.new.errors') %></h3>
            <ul class="mt-2 text-sm text-red-700 list-disc list-inside">
              <% @template.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Template Name -->
    <div>
      <%= form.label :name, t('organizers.contest_templates.new.name_label'), class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500", placeholder: t('organizers.contest_templates.new.name_placeholder') %>
      <p class="mt-1 text-xs text-gray-500"><%= t('organizers.contest_templates.new.name_hint') %></p>
    </div>

    <!-- Preview of saved settings -->
    <div class="bg-gray-50 rounded-lg p-4">
      <h3 class="text-sm font-medium text-gray-900 mb-3"><%= t('organizers.contest_templates.new.saved_settings') %></h3>
      <dl class="grid grid-cols-1 gap-3 sm:grid-cols-2 text-sm">
        <div>
          <dt class="font-medium text-gray-500"><%= t('organizers.contest_templates.new.theme') %></dt>
          <dd class="text-gray-900"><%= @contest.theme.presence || t('organizers.contests.show.not_set') %></dd>
        </div>
        <div>
          <dt class="font-medium text-gray-500"><%= t('organizers.contest_templates.new.description') %></dt>
          <dd class="text-gray-900 line-clamp-2"><%= @contest.description.presence || t('organizers.contests.show.not_set') %></dd>
        </div>
        <div>
          <dt class="font-medium text-gray-500"><%= t('organizers.contest_templates.new.judging_method') %></dt>
          <dd class="text-gray-900">
            <%= case @contest.judging_method
                when "judge_only" then t('organizers.contest_templates.index.judge_only')
                when "vote_only" then t('organizers.contest_templates.index.vote_only')
                when "hybrid" then t('organizers.contest_templates.index.hybrid') + " (#{@contest.judge_weight}%)"
                end %>
          </dd>
        </div>
        <div>
          <dt class="font-medium text-gray-500"><%= t('organizers.contest_templates.new.prize_count') %></dt>
          <dd class="text-gray-900"><%= @contest.prize_count || 3 %><%= t('organizers.contest_templates.new.people_unit') %></dd>
        </div>
        <div>
          <dt class="font-medium text-gray-500"><%= t('organizers.contest_templates.new.moderation') %></dt>
          <dd class="text-gray-900"><%= @contest.moderation_enabled? ? t('organizers.contest_templates.new.moderation_enabled', threshold: @contest.moderation_threshold) : t('organizers.contest_templates.new.moderation_disabled') %></dd>
        </div>
        <div>
          <dt class="font-medium text-gray-500"><%= t('organizers.contest_templates.new.spot_required') %></dt>
          <dd class="text-gray-900"><%= @contest.require_spot? ? t('organizers.contest_templates.new.required') : t('organizers.contest_templates.new.optional') %></dd>
        </div>
        <div>
          <dt class="font-medium text-gray-500"><%= t('organizers.contest_templates.new.category') %></dt>
          <dd class="text-gray-900"><%= @contest.category&.name || t('organizers.contests.show.not_set') %></dd>
        </div>
        <div>
          <dt class="font-medium text-gray-500"><%= t('organizers.contest_templates.new.area') %></dt>
          <dd class="text-gray-900"><%= @contest.area&.name || t('organizers.contests.show.not_set') %></dd>
        </div>
      </dl>
      <p class="mt-3 text-xs text-gray-500"><%= t('organizers.contest_templates.new.note') %></p>
    </div>

    <!-- Form Actions -->
    <div class="flex items-center justify-end space-x-4">
      <%= link_to t('organizers.contest_templates.new.cancel'), organizers_contest_path(@contest), class: "text-sm font-medium text-gray-600 hover:text-gray-700" %>
      <%= form.submit t('organizers.contest_templates.new.submit'), class: "inline-flex items-center px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg transition-colors cursor-pointer" %>
    </div>
  <% end %>
</div>
