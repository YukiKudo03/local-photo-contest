<!-- Page Header -->
<div class="mb-8">
  <div class="flex items-center justify-between">
    <div>
      <%= link_to organizers_contests_path, class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700 mb-2" do %>
        <svg class="mr-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        <%= t('organizers.contests.show.back') %>
      <% end %>
      <h1 class="text-2xl font-bold text-gray-900"><%= @contest.title %></h1>
    </div>
    <div class="flex items-center space-x-3">
      <% case @contest.status %>
      <% when "draft" %>
        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-gray-100 text-gray-800">
          <%= t('organizers.contests.index.draft') %>
        </span>
      <% when "published" %>
        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
          <%= t('organizers.contests.index.published') %>
        </span>
      <% when "finished" %>
        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800">
          <%= t('organizers.contests.index.finished') %>
        </span>
      <% end %>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <!-- Main Content -->
  <div class="lg:col-span-2 space-y-6">
    <!-- Thumbnail -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="aspect-video bg-gray-100 flex items-center justify-center">
        <% if @contest.thumbnail.attached? %>
          <%= image_tag @contest.thumbnail, alt: @contest.title, class: "w-full h-full object-cover" %>
        <% else %>
          <div class="text-center">
            <svg class="mx-auto h-16 w-16 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <p class="mt-2 text-sm text-gray-400"><%= t('organizers.contests.show.no_thumbnail') %></p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Contest Details -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100">
        <h2 class="text-lg font-semibold text-gray-900"><%= t('organizers.contests.show.contest_info') %></h2>
      </div>
      <div class="p-6 space-y-6">
        <% if @contest.theme.present? %>
          <div>
            <dt class="text-sm font-medium text-gray-500"><%= t('organizers.contests.show.theme') %></dt>
            <dd class="mt-1 text-gray-900"><%= @contest.theme %></dd>
          </div>
        <% end %>

        <% if @contest.description.present? %>
          <div>
            <dt class="text-sm font-medium text-gray-500"><%= t('organizers.contests.show.description') %></dt>
            <dd class="mt-1 text-gray-900 whitespace-pre-wrap"><%= @contest.description %></dd>
          </div>
        <% end %>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div>
            <dt class="text-sm font-medium text-gray-500"><%= t('organizers.contests.form.entry_start_label') %></dt>
            <dd class="mt-1 text-gray-900">
              <% if @contest.entry_start_at.present? %>
                <%= l(@contest.entry_start_at, format: :long) %>
              <% else %>
<span class="text-gray-400"><%= t('organizers.contests.show.not_set') %></span>
              <% end %>
            </dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500"><%= t('organizers.contests.form.entry_end_label') %></dt>
            <dd class="mt-1 text-gray-900">
              <% if @contest.entry_end_at.present? %>
                <%= l(@contest.entry_end_at, format: :long) %>
              <% else %>
<span class="text-gray-400"><%= t('organizers.contests.show.not_set') %></span>
              <% end %>
            </dd>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div>
            <dt class="text-sm font-medium text-gray-500"><%= t('organizers.contests.show.created_at') %></dt>
            <dd class="mt-1 text-gray-900"><%= l(@contest.created_at, format: :long) %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500"><%= t('organizers.contests.show.updated_at') %></dt>
            <dd class="mt-1 text-gray-900"><%= l(@contest.updated_at, format: :long) %></dd>
          </div>
        </div>
      </div>
    </div>

    <!-- Area Information -->
    <% if @contest.area.present? %>
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100">
          <h2 class="text-lg font-semibold text-gray-900"><%= t('organizers.contests.show.area') %></h2>
        </div>
        <div class="p-6 space-y-4">
          <div>
            <dt class="text-sm font-medium text-gray-500"><%= t('organizers.areas.form.name_label') %></dt>
            <dd class="mt-1">
              <%= link_to @contest.area.name, organizers_area_path(@contest.area), class: "text-indigo-600 hover:text-indigo-800 font-medium" %>
            </dd>
          </div>

          <% if @contest.area.full_address.present? %>
            <div>
              <dt class="text-sm font-medium text-gray-500"><%= t('organizers.spots.form.address_label') %></dt>
              <dd class="mt-1 text-gray-900"><%= @contest.area.full_address %></dd>
            </div>
          <% end %>

          <% if @contest.require_spot %>
            <div class="flex items-center">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800">
                <%= t('organizers.contests.show.spot_required') %>
              </span>
            </div>
          <% end %>

          <% if @contest.area.center_coordinates %>
            <div>
              <dt class="text-sm font-medium text-gray-500 mb-2"><%= t('organizers.contests.show.map_preview') %></dt>
              <dd>
                <div data-controller="map"
                     data-map-latitude-value="<%= @contest.area.latitude %>"
                     data-map-longitude-value="<%= @contest.area.longitude %>"
                     data-map-zoom-value="14"
                     data-map-boundary-geojson-value="<%= @contest.area.boundary_geojson %>"
                     data-map-interactive-value="false">
                  <div data-map-target="container" class="map-container map-container-sm rounded-lg"></div>
                </div>
              </dd>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Sidebar Actions -->
  <div class="space-y-6">
    <!-- Action Buttons -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100">
        <h2 class="text-lg font-semibold text-gray-900"><%= t('organizers.contests.show.actions') %></h2>
      </div>
      <div class="p-6 space-y-3">
        <%= link_to edit_organizers_contest_path(@contest), class: "flex items-center w-full p-3 rounded-lg border border-gray-200 hover:border-indigo-300 hover:bg-indigo-50 transition-colors group" do %>
          <div class="w-10 h-10 bg-indigo-100 rounded-lg flex items-center justify-center group-hover:bg-indigo-200 transition-colors">
            <svg class="h-5 w-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
            </svg>
          </div>
          <div class="ml-3">
<p class="text-sm font-medium text-gray-900"><%= t('organizers.contests.show.edit') %></p>
            <p class="text-xs text-gray-500"><%= t('organizers.contests.show.edit_desc') %></p>
          </div>
        <% end %>

        <%= link_to organizers_contest_entries_path(@contest), class: "flex items-center w-full p-3 rounded-lg border border-gray-200 hover:border-purple-300 hover:bg-purple-50 transition-colors group" do %>
          <div class="w-10 h-10 bg-purple-100 rounded-lg flex items-center justify-center group-hover:bg-purple-200 transition-colors">
            <svg class="h-5 w-5 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <div class="ml-3">
<p class="text-sm font-medium text-gray-900"><%= t('organizers.contests.show.entries_section') %></p>
            <p class="text-xs text-gray-500"><%= t('organizers.contests.show.entries_count', count: @contest.entries.count) %></p>
          </div>
        <% end %>

        <% if @contest.moderation_enabled? %>
          <% moderation_count = @contest.entries.needs_moderation_review.count %>
          <%= link_to organizers_contest_moderation_index_path(@contest), class: "flex items-center w-full p-3 rounded-lg border border-gray-200 hover:border-amber-300 hover:bg-amber-50 transition-colors group" do %>
            <div class="w-10 h-10 bg-amber-100 rounded-lg flex items-center justify-center group-hover:bg-amber-200 transition-colors relative">
              <svg class="h-5 w-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
              <% if moderation_count > 0 %>
                <span class="absolute -top-1 -right-1 flex h-5 w-5 items-center justify-center rounded-full bg-red-500 text-xs font-medium text-white">
                  <%= moderation_count > 9 ? '9+' : moderation_count %>
                </span>
              <% end %>
            </div>
            <div class="ml-3">
              <p class="text-sm font-medium text-gray-900"><%= t('organizers.contests.show.moderation') %></p>
              <p class="text-xs text-gray-500">
                <% if moderation_count > 0 %>
                  <span class="text-amber-600 font-medium"><%= t('organizers.contests.show.pending_review', count: moderation_count) %></span>
                <% else %>
<%= t('organizers.contests.show.all_reviewed') %>
                <% end %>
              </p>
            </div>
          <% end %>
        <% end %>

        <%= link_to organizers_contest_spots_path(@contest), class: "flex items-center w-full p-3 rounded-lg border border-gray-200 hover:border-teal-300 hover:bg-teal-50 transition-colors group" do %>
          <div class="w-10 h-10 bg-teal-100 rounded-lg flex items-center justify-center group-hover:bg-teal-200 transition-colors">
            <svg class="h-5 w-5 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div class="ml-3">
<p class="text-sm font-medium text-gray-900"><%= t('organizers.spots.index.title') %></p>
            <p class="text-xs text-gray-500"><%= t('organizers.contests.show.spots', count: @contest.spots.count) %></p>
          </div>
        <% end %>

        <% discovery_pending_count = @contest.spots.pending_certification.count %>
        <%= link_to organizers_contest_discovery_spots_path(@contest), class: "flex items-center w-full p-3 rounded-lg border border-gray-200 hover:border-amber-300 hover:bg-amber-50 transition-colors group" do %>
          <div class="w-10 h-10 bg-amber-100 rounded-lg flex items-center justify-center group-hover:bg-amber-200 transition-colors relative">
            <svg class="h-5 w-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <% if discovery_pending_count > 0 %>
              <span class="absolute -top-1 -right-1 flex h-5 w-5 items-center justify-center rounded-full bg-red-500 text-xs font-medium text-white">
                <%= discovery_pending_count > 9 ? '9+' : discovery_pending_count %>
              </span>
            <% end %>
          </div>
          <div class="ml-3">
            <p class="text-sm font-medium text-gray-900"><%= t('organizers.discovery_spots.index.title') %></p>
            <p class="text-xs text-gray-500">
              <% if discovery_pending_count > 0 %>
<span class="text-amber-600 font-medium"><%= t('organizers.contests.show.pending_review', count: discovery_pending_count) %></span>
              <% else %>
                <%= t('organizers.contests.show.all_reviewed') %>
              <% end %>
            </p>
          </div>
        <% end %>

        <%= link_to organizers_contest_discovery_challenges_path(@contest), class: "flex items-center w-full p-3 rounded-lg border border-gray-200 hover:border-violet-300 hover:bg-violet-50 transition-colors group" do %>
          <div class="w-10 h-10 bg-violet-100 rounded-lg flex items-center justify-center group-hover:bg-violet-200 transition-colors">
            <svg class="h-5 w-5 text-violet-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
            </svg>
          </div>
          <div class="ml-3">
<p class="text-sm font-medium text-gray-900"><%= t('organizers.discovery_challenges.index.title') %></p>
            <p class="text-xs text-gray-500"><%= t('organizers.contests.show.challenges_count', count: @contest.discovery_challenges.count) %></p>
          </div>
        <% end %>

        <%= link_to organizers_contest_statistics_path(@contest), class: "flex items-center w-full p-3 rounded-lg border border-gray-200 hover:border-emerald-300 hover:bg-emerald-50 transition-colors group" do %>
          <div class="w-10 h-10 bg-emerald-100 rounded-lg flex items-center justify-center group-hover:bg-emerald-200 transition-colors">
            <svg class="h-5 w-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <div class="ml-3">
<p class="text-sm font-medium text-gray-900"><%= t('organizers.contests.show.statistics') %></p>
            <p class="text-xs text-gray-500"><%= t('organizers.contests.show.statistics_desc') %></p>
          </div>
        <% end %>

        <%= link_to new_organizers_contest_template_path(contest_id: @contest.id), class: "flex items-center w-full p-3 rounded-lg border border-gray-200 hover:border-slate-300 hover:bg-slate-50 transition-colors group" do %>
          <div class="w-10 h-10 bg-slate-100 rounded-lg flex items-center justify-center group-hover:bg-slate-200 transition-colors">
            <svg class="h-5 w-5 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <div class="ml-3">
<p class="text-sm font-medium text-gray-900"><%= t('organizers.contests.show.save_as_template') %></p>
            <p class="text-xs text-gray-500"><%= t('organizers.contests.show.save_template_desc') %></p>
          </div>
        <% end %>

        <%= link_to edit_organizers_contest_judging_settings_path(@contest), class: "flex items-center w-full p-3 rounded-lg border border-gray-200 hover:border-orange-300 hover:bg-orange-50 transition-colors group" do %>
          <div class="w-10 h-10 bg-orange-100 rounded-lg flex items-center justify-center group-hover:bg-orange-200 transition-colors">
            <svg class="h-5 w-5 text-orange-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
            </svg>
          </div>
          <div class="ml-3">
            <p class="text-sm font-medium text-gray-900"><%= t('organizers.judging_settings.edit.title') %></p>
            <p class="text-xs text-gray-500">
              <%= t("activerecord.attributes.contest.judging_methods.#{@contest.judging_method}", default: @contest.judging_method) %>
            </p>
          </div>
        <% end %>

        <%= link_to organizers_contest_judge_invitations_path(@contest), class: "flex items-center w-full p-3 rounded-lg border border-gray-200 hover:border-cyan-300 hover:bg-cyan-50 transition-colors group" do %>
          <div class="w-10 h-10 bg-cyan-100 rounded-lg flex items-center justify-center group-hover:bg-cyan-200 transition-colors">
            <svg class="h-5 w-5 text-cyan-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <div class="ml-3">
<p class="text-sm font-medium text-gray-900"><%= t('organizers.contest_judges.index.title') %></p>
            <p class="text-xs text-gray-500"><%= t('organizers.contests.show.judges_count', count: @contest.contest_judges.count) %></p>
          </div>
        <% end %>

        <% if @contest.finished? || @contest.results_announced? %>
          <%= link_to preview_organizers_contest_results_path(@contest), class: "flex items-center w-full p-3 rounded-lg border border-gray-200 hover:border-pink-300 hover:bg-pink-50 transition-colors group" do %>
            <div class="w-10 h-10 bg-pink-100 rounded-lg flex items-center justify-center group-hover:bg-pink-200 transition-colors">
              <svg class="h-5 w-5 text-pink-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
            </div>
            <div class="ml-3">
              <p class="text-sm font-medium text-gray-900"><%= t('organizers.results.preview.title') %></p>
              <p class="text-xs text-gray-500">
                <% if @contest.results_announced? %>
                  <%= t('organizers.contests.show.results_announced') %>
                <% else %>
                  <%= t('organizers.contests.show.ranking_preview') %>
                <% end %>
              </p>
            </div>
          <% end %>
        <% end %>

        <% if @contest.draft? %>
          <%= button_to publish_organizers_contest_path(@contest), method: :patch, data: { turbo_confirm: t('organizers.contests.show.publish_confirm') }, class: "flex items-center w-full p-3 rounded-lg border border-gray-200 hover:border-green-300 hover:bg-green-50 transition-colors group" do %>
            <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center group-hover:bg-green-200 transition-colors">
              <svg class="h-5 w-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
            </div>
            <div class="ml-3 text-left">
<p class="text-sm font-medium text-gray-900"><%= t('organizers.contests.show.publish') %></p>
              <p class="text-xs text-gray-500"><%= t('organizers.contests.show.publish_desc') %></p>
            </div>
          <% end %>
        <% end %>

        <% if @contest.published? %>
          <%= button_to finish_organizers_contest_path(@contest), method: :patch, data: { turbo_confirm: t('organizers.contests.show.finish_confirm') }, class: "flex items-center w-full p-3 rounded-lg border border-gray-200 hover:border-blue-300 hover:bg-blue-50 transition-colors group" do %>
            <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center group-hover:bg-blue-200 transition-colors">
              <svg class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="ml-3 text-left">
<p class="text-sm font-medium text-gray-900"><%= t('organizers.contests.show.finish') %></p>
              <p class="text-xs text-gray-500"><%= t('organizers.contests.show.finish_desc') %></p>
            </div>
          <% end %>
        <% end %>

        <% if @contest.finished? && !@contest.results_announced? %>
          <%= button_to announce_results_organizers_contest_path(@contest), method: :patch, data: { turbo_confirm: t('organizers.contests.show.announce_confirm') }, class: "flex items-center w-full p-3 rounded-lg border border-gray-200 hover:border-yellow-300 hover:bg-yellow-50 transition-colors group" do %>
            <div class="w-10 h-10 bg-yellow-100 rounded-lg flex items-center justify-center group-hover:bg-yellow-200 transition-colors">
              <svg class="h-5 w-5 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
              </svg>
            </div>
            <div class="ml-3 text-left">
<p class="text-sm font-medium text-gray-900"><%= t('organizers.contests.show.announce_results') %></p>
              <p class="text-xs text-gray-500"><%= t('organizers.contests.show.announce_desc') %></p>
            </div>
          <% end %>
        <% end %>

        <% if @contest.results_announced? %>
          <%= link_to contest_results_path(@contest), class: "flex items-center w-full p-3 rounded-lg border border-gray-200 hover:border-yellow-300 hover:bg-yellow-50 transition-colors group", target: "_blank" do %>
            <div class="w-10 h-10 bg-yellow-100 rounded-lg flex items-center justify-center group-hover:bg-yellow-200 transition-colors">
              <svg class="h-5 w-5 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
              </svg>
            </div>
            <div class="ml-3 text-left">
<p class="text-sm font-medium text-gray-900"><%= t('organizers.contests.show.view_results') %></p>
              <p class="text-xs text-gray-500"><%= t('organizers.contests.show.view_results_desc') %></p>
            </div>
          <% end %>
        <% end %>

        <% unless @contest.published? %>
          <%= button_to organizers_contest_path(@contest), method: :delete, data: { turbo_confirm: t('organizers.contests.show.delete_confirm') }, class: "flex items-center w-full p-3 rounded-lg border border-gray-200 hover:border-red-300 hover:bg-red-50 transition-colors group" do %>
            <div class="w-10 h-10 bg-red-100 rounded-lg flex items-center justify-center group-hover:bg-red-200 transition-colors">
              <svg class="h-5 w-5 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
              </svg>
            </div>
            <div class="ml-3 text-left">
<p class="text-sm font-medium text-gray-900"><%= t('organizers.contests.show.delete_contest') %></p>
              <p class="text-xs text-gray-500"><%= t('organizers.contests.show.delete_desc') %></p>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- Status Info -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100">
        <h2 class="text-lg font-semibold text-gray-900"><%= t('organizers.contests.show.status') %></h2>
      </div>
      <div class="p-6">
        <div class="space-y-4">
          <div class="flex items-center">
            <% if @contest.accepting_entries? %>
              <span class="flex h-3 w-3 relative">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-3 w-3 bg-green-500"></span>
              </span>
              <span class="ml-3 text-sm text-gray-700"><%= t('organizers.contests.show.accepting_entries') %></span>
            <% else %>
              <span class="inline-flex rounded-full h-3 w-3 bg-gray-300"></span>
              <span class="ml-3 text-sm text-gray-500"><%= t('organizers.contests.show.not_accepting_entries') %></span>
            <% end %>
          </div>
          <div class="flex items-center">
            <% if @contest.results_announced? %>
              <span class="inline-flex rounded-full h-3 w-3 bg-yellow-500"></span>
              <span class="ml-3 text-sm text-gray-700"><%= t('organizers.contests.show.results_announced') %></span>
            <% elsif @contest.finished? %>
              <span class="inline-flex rounded-full h-3 w-3 bg-blue-300"></span>
              <span class="ml-3 text-sm text-gray-500"><%= t('organizers.contests.show.results_not_announced') %></span>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
