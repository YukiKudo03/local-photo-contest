<div class="container mx-auto px-4 py-8">
  <div class="mb-6">
    <%= link_to "← コンテスト詳細に戻る", organizers_contest_path(@contest), class: "text-blue-600 hover:text-blue-800" %>
  </div>

  <h1 class="text-2xl font-bold mb-6">結果発表管理: <%= @contest.title %></h1>

  <!-- ステータス表示 -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
    <div class="bg-white rounded-lg shadow p-4">
      <p class="text-sm text-gray-500">コンテストステータス</p>
      <p class="text-lg font-semibold">
        <% if @contest.finished? %>
          <span class="text-green-600">終了</span>
        <% elsif @contest.published? %>
          <span class="text-yellow-600">公開中</span>
        <% else %>
          <span class="text-gray-600">下書き</span>
        <% end %>
      </p>
    </div>
    <div class="bg-white rounded-lg shadow p-4">
      <p class="text-sm text-gray-500">審査員採点完了率</p>
      <p class="text-lg font-semibold"><%= @judge_completion_rate %>%</p>
    </div>
    <div class="bg-white rounded-lg shadow p-4">
      <p class="text-sm text-gray-500">応募作品数</p>
      <p class="text-lg font-semibold"><%= @contest.entries.count %>件</p>
    </div>
  </div>

  <!-- 警告メッセージ -->
  <% if @warnings.any? %>
    <div class="bg-yellow-50 border border-yellow-200 rounded-md p-4 mb-6">
      <h3 class="font-semibold text-yellow-800 mb-2">警告</h3>
      <ul class="list-disc list-inside text-yellow-700">
        <% @warnings.each do |warning| %>
          <li><%= warning %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- 結果発表済みの場合 -->
  <% if @contest.results_announced? %>
    <div class="bg-green-50 border border-green-200 rounded-md p-4 mb-6">
      <p class="text-green-800">
        <strong>結果発表済み:</strong>
        <%= l(@contest.results_announced_at, format: :long) %>
        |
        <%= link_to "結果ページを確認", contest_results_path(@contest), class: "text-green-600 hover:text-green-800 underline", target: "_blank" %>
      </p>
    </div>
  <% end %>

  <!-- 暫定ランキング -->
  <div class="bg-white rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center">
      <h2 class="text-lg font-semibold">
        <% if @contest.results_announced? %>確定ランキング<% else %>暫定ランキング<% end %>
      </h2>
      <% unless @contest.results_announced? %>
        <%= button_to "ランキングを再計算", calculate_organizers_contest_results_path(@contest),
            method: :post,
            class: "text-blue-600 hover:text-blue-800 text-sm" %>
      <% end %>
    </div>

    <% if @rankings.any? %>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 py-3 text-left text-sm font-semibold text-gray-700">順位</th>
              <th class="px-4 py-3 text-left text-sm font-semibold text-gray-700">作品</th>
              <th class="px-4 py-3 text-left text-sm font-semibold text-gray-700">投稿者</th>
              <th class="px-4 py-3 text-right text-sm font-semibold text-gray-700">総合スコア</th>
              <% if @contest.judging_judge_only? || @contest.judging_hybrid? %>
                <th class="px-4 py-3 text-right text-sm font-semibold text-gray-700">審査員スコア</th>
              <% end %>
              <% if @contest.judging_vote_only? || @contest.judging_hybrid? %>
                <th class="px-4 py-3 text-right text-sm font-semibold text-gray-700">投票数</th>
              <% end %>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <% @rankings.each do |ranking| %>
              <% entry = ranking[:entry] %>
              <tr class="<%= ranking[:rank] <= (@contest.prize_count || 3) ? 'bg-yellow-50' : '' %>">
                <td class="px-4 py-3">
                  <% if ranking[:rank] <= 3 %>
                    <span class="inline-flex items-center justify-center w-8 h-8 rounded-full <%= rank_badge_class(ranking[:rank]) %>">
                      <%= ranking[:rank] %>
                    </span>
                  <% else %>
                    <span class="text-gray-600"><%= ranking[:rank] %></span>
                  <% end %>
                </td>
                <td class="px-4 py-3">
                  <div class="flex items-center">
                    <% if entry.photo.attached? %>
                      <%= image_tag entry.photo.variant(resize_to_fill: [48, 48]), alt: entry.title.presence || "フォトコンテスト応募作品", class: "w-12 h-12 rounded object-cover mr-3" %>
                    <% end %>
                    <div>
                      <p class="font-medium"><%= entry.title.presence || "無題" %></p>
                    </div>
                  </div>
                </td>
                <td class="px-4 py-3 text-gray-600"><%= entry.user.email %></td>
                <td class="px-4 py-3 text-right font-semibold"><%= number_with_precision(ranking[:total_score], precision: 2) %></td>
                <% if @contest.judging_judge_only? || @contest.judging_hybrid? %>
                  <td class="px-4 py-3 text-right"><%= number_with_precision(ranking[:judge_score], precision: 2) %></td>
                <% end %>
                <% if @contest.judging_vote_only? || @contest.judging_hybrid? %>
                  <td class="px-4 py-3 text-right"><%= ranking[:vote_count] %></td>
                <% end %>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="px-6 py-8 text-center text-gray-500">
        ランキングデータがありません
      </div>
    <% end %>
  </div>

  <!-- 結果発表ボタン -->
  <% if @can_announce %>
    <div class="mt-8 p-6 bg-white rounded-lg shadow">
      <h2 class="text-lg font-semibold mb-4">結果を発表</h2>
      <p class="text-gray-600 mb-4">
        結果を発表すると、参加者と一般ユーザーがランキングを閲覧できるようになります。
        この操作は取り消せません。
      </p>
      <%= button_to "結果を発表する", announce_organizers_contest_results_path(@contest),
          method: :post,
          data: { turbo_confirm: "結果を発表しますか？この操作は取り消せません。" },
          class: "bg-green-600 text-white py-2 px-6 rounded-md hover:bg-green-700 cursor-pointer" %>
    </div>
  <% elsif !@contest.finished? %>
    <div class="mt-8 p-6 bg-gray-50 rounded-lg">
      <p class="text-gray-600">
        結果を発表するには、まずコンテストを終了してください。
      </p>
      <%= link_to "コンテスト管理に戻る", organizers_contest_path(@contest), class: "text-blue-600 hover:text-blue-800" %>
    </div>
  <% end %>
</div>
