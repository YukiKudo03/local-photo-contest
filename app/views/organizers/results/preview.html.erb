<div class="container mx-auto px-4 py-8">
  <div class="mb-6">
    <%= link_to t('organizers.results.preview.back'), organizers_contest_path(@contest), class: "text-blue-600 hover:text-blue-800" %>
  </div>

  <h1 class="text-2xl font-bold mb-6"><%= t('organizers.results.preview.title') %>: <%= @contest.title %></h1>

  <!-- ステータス表示 -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
    <div class="bg-white rounded-lg shadow p-4">
      <p class="text-sm text-gray-500"><%= t('organizers.results.preview.contest_status') %></p>
      <p class="text-lg font-semibold">
        <% if @contest.finished? %>
          <span class="text-green-600"><%= t('organizers.results.preview.finished') %></span>
        <% elsif @contest.published? %>
          <span class="text-yellow-600"><%= t('organizers.results.preview.published') %></span>
        <% else %>
          <span class="text-gray-600"><%= t('organizers.results.preview.draft') %></span>
        <% end %>
      </p>
    </div>
    <div class="bg-white rounded-lg shadow p-4">
      <p class="text-sm text-gray-500"><%= t('organizers.results.preview.judge_completion') %></p>
      <p class="text-lg font-semibold"><%= @judge_completion_rate %>%</p>
    </div>
    <div class="bg-white rounded-lg shadow p-4">
      <p class="text-sm text-gray-500"><%= t('organizers.results.preview.entries_count') %></p>
      <p class="text-lg font-semibold"><%= t('organizers.results.preview.entries_with_count', count: @contest.entries.count) %></p>
    </div>
  </div>

  <!-- 警告メッセージ -->
  <% if @warnings.any? %>
    <div class="bg-yellow-50 border border-yellow-200 rounded-md p-4 mb-6">
      <h3 class="font-semibold text-yellow-800 mb-2"><%= t('organizers.results.preview.warnings') %></h3>
      <ul class="list-disc list-inside text-yellow-700">
        <% @warnings.each do |warning| %>
          <li><%= warning %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- 結果発表済みの場合 -->
  <% if @contest.results_announced? %>
    <div class="bg-green-50 border border-green-200 rounded-md p-4 mb-6">
      <p class="text-green-800">
        <strong><%= t('organizers.results.preview.results_announced') %>:</strong>
        <%= l(@contest.results_announced_at, format: :long) %>
        |
        <%= link_to t('organizers.results.preview.view_results_page'), contest_results_path(@contest), class: "text-green-600 hover:text-green-800 underline", target: "_blank" %>
      </p>
    </div>
  <% end %>

  <!-- ランキングが古い場合の警告 -->
  <% if @preview_data[:rankings_outdated] %>
    <div class="bg-orange-50 border border-orange-200 rounded-md p-4 mb-6">
      <div class="flex items-center">
        <svg class="h-5 w-5 text-orange-600 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <p class="text-orange-800 font-medium"><%= t('organizers.results.preview.rankings_outdated') %></p>
      </div>
      <p class="mt-2 text-orange-700 text-sm">
        <%= t('organizers.results.preview.rankings_outdated_desc') %>
      </p>
    </div>
  <% end %>

  <!-- <%= t('organizers.results.preview.provisional_rankings') %> -->
  <div class="bg-white rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center">
      <h2 class="text-lg font-semibold">
        <% if @contest.results_announced? %>
          <%= t('organizers.results.preview.final_rankings') %>
        <% else %>
          <%= t('organizers.results.preview.provisional_rankings') %>
          <% if @preview_data[:rankings_outdated] %>
            <span class="ml-2 text-xs font-normal text-orange-600 bg-orange-100 px-2 py-1 rounded"><%= t('organizers.results.preview.needs_recalculation') %></span>
          <% end %>
        <% end %>
      </h2>
      <% unless @contest.results_announced? %>
        <%= button_to t('organizers.results.preview.recalculate'), calculate_organizers_contest_results_path(@contest),
            method: :post,
            class: "bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700 text-sm" %>
      <% end %>
    </div>

    <% if @rankings.any? %>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 py-3 text-left text-sm font-semibold text-gray-700"><%= t('organizers.results.preview.rank') %></th>
              <th class="px-4 py-3 text-left text-sm font-semibold text-gray-700"><%= t('organizers.results.preview.entry') %></th>
              <th class="px-4 py-3 text-left text-sm font-semibold text-gray-700"><%= t('organizers.results.preview.submitter') %></th>
              <th class="px-4 py-3 text-right text-sm font-semibold text-gray-700"><%= t('organizers.results.preview.total_score') %></th>
              <% if @contest.judging_judge_only? || @contest.judging_hybrid? %>
                <th class="px-4 py-3 text-right text-sm font-semibold text-gray-700"><%= t('organizers.results.preview.judge_score') %></th>
              <% end %>
              <% if @contest.judging_vote_only? || @contest.judging_hybrid? %>
                <th class="px-4 py-3 text-right text-sm font-semibold text-gray-700"><%= t('organizers.results.preview.vote_count') %></th>
              <% end %>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <% @rankings.each do |ranking| %>
              <% entry = ranking[:entry] %>
              <tr class="<%= ranking[:rank] <= (@contest.prize_count || 3) ? 'bg-yellow-50' : '' %>">
                <td class="px-4 py-3">
                  <% if ranking[:rank] <= 3 %>
                    <span class="inline-flex items-center justify-center w-8 h-8 rounded-full <%= rank_badge_class(ranking[:rank]) %>">
                      <%= ranking[:rank] %>
                    </span>
                  <% else %>
                    <span class="text-gray-600"><%= ranking[:rank] %></span>
                  <% end %>
                </td>
                <td class="px-4 py-3">
                  <div class="flex items-center">
                    <% if entry.photo.attached? %>
                      <%= image_tag entry.photo.variant(resize_to_fill: [48, 48]), alt: entry.title.presence || t('organizers.dashboard.untitled'), class: "w-12 h-12 rounded object-cover mr-3", loading: "lazy" %>
                    <% end %>
                    <div>
                      <p class="font-medium"><%= entry.title.presence || t('organizers.dashboard.untitled') %></p>
                    </div>
                  </div>
                </td>
                <td class="px-4 py-3 text-gray-600"><%= entry.user.email %></td>
                <td class="px-4 py-3 text-right font-semibold"><%= number_with_precision(ranking[:total_score], precision: 2) %></td>
                <% if @contest.judging_judge_only? || @contest.judging_hybrid? %>
                  <td class="px-4 py-3 text-right"><%= number_with_precision(ranking[:judge_score], precision: 2) %></td>
                <% end %>
                <% if @contest.judging_vote_only? || @contest.judging_hybrid? %>
                  <td class="px-4 py-3 text-right"><%= ranking[:vote_count] %></td>
                <% end %>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="px-6 py-8 text-center text-gray-500">
        <%= t('organizers.results.preview.no_rankings') %>
      </div>
    <% end %>
  </div>

  <!-- 結果発表ボタン -->
  <% if @can_announce %>
    <div class="mt-8 p-6 bg-white rounded-lg shadow">
      <h2 class="text-lg font-semibold mb-4"><%= t('organizers.results.preview.announce_title') %></h2>
      <p class="text-gray-600 mb-4">
        <%= t('organizers.results.preview.announce_desc') %>
      </p>
      <%= button_to t('organizers.results.preview.announce_button'), announce_organizers_contest_results_path(@contest),
          method: :post,
          data: { turbo_confirm: t('organizers.results.preview.announce_confirm') },
          class: "bg-green-600 text-white py-2 px-6 rounded-md hover:bg-green-700 cursor-pointer" %>
    </div>
  <% elsif !@contest.finished? %>
    <div class="mt-8 p-6 bg-gray-50 rounded-lg">
      <p class="text-gray-600">
        <%= t('organizers.results.preview.finish_first') %>
      </p>
      <%= link_to t('organizers.results.preview.back_to_contest'), organizers_contest_path(@contest), class: "text-blue-600 hover:text-blue-800" %>
    </div>
  <% end %>
</div>
