<!-- Page Header -->
<div class="mb-8">
  <%= link_to organizers_contest_path(@contest), class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700 mb-2" do %>
    <svg class="mr-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
    </svg>
    コンテスト詳細に戻る
  <% end %>
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">発掘スポット審査</h1>
      <p class="mt-1 text-sm text-gray-500"><%= @contest.title %></p>
    </div>
    <div class="text-right">
      <p class="text-2xl font-bold <%= @pending_count > 0 ? 'text-amber-600' : 'text-green-600' %>"><%= @pending_count %></p>
      <p class="text-sm text-gray-500">件の審査待ち</p>
    </div>
  </div>
</div>

<!-- Tabs -->
<div class="mb-6 border-b border-gray-200">
  <nav class="-mb-px flex space-x-8" aria-label="Tabs">
    <button type="button" data-tab="pending" class="tab-button border-indigo-500 text-indigo-600 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm">
      審査待ち (<%= @pending_count %>)
    </button>
    <button type="button" data-tab="certified" class="tab-button border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm">
      認定済み (<%= @certified_spots.count %>)
    </button>
    <button type="button" data-tab="rejected" class="tab-button border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm">
      却下 (<%= @rejected_spots.count %>)
    </button>
  </nav>
</div>

<!-- Pending Spots Tab -->
<div id="pending-tab" class="tab-content">
  <% if @pending_spots.any? %>
    <div class="space-y-4" id="pending-spots">
      <% @pending_spots.each do |spot| %>
        <%= turbo_frame_tag dom_id(spot) do %>
          <%= render "spot", spot: spot, status: :pending %>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12 bg-white rounded-xl shadow-sm border border-gray-100">
      <svg class="mx-auto h-12 w-12 text-green-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <h3 class="mt-4 text-lg font-medium text-gray-900">審査待ちのスポットはありません</h3>
      <p class="mt-2 text-sm text-gray-500">すべての発掘スポットは審査済みです</p>
    </div>
  <% end %>
</div>

<!-- Certified Spots Tab -->
<div id="certified-tab" class="tab-content hidden">
  <% if @certified_spots.any? %>
    <div class="space-y-4">
      <% @certified_spots.each do |spot| %>
        <%= render "spot", spot: spot, status: :certified %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12 bg-white rounded-xl shadow-sm border border-gray-100">
      <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      <h3 class="mt-4 text-lg font-medium text-gray-900">認定済みのスポットはありません</h3>
    </div>
  <% end %>
</div>

<!-- Rejected Spots Tab -->
<div id="rejected-tab" class="tab-content hidden">
  <% if @rejected_spots.any? %>
    <div class="space-y-4">
      <% @rejected_spots.each do |spot| %>
        <%= render "spot", spot: spot, status: :rejected %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12 bg-white rounded-xl shadow-sm border border-gray-100">
      <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
      <h3 class="mt-4 text-lg font-medium text-gray-900">却下されたスポットはありません</h3>
    </div>
  <% end %>
</div>

<!-- Reject Modal -->
<div id="reject-modal" class="hidden fixed inset-0 bg-gray-500 bg-opacity-75 flex items-center justify-center z-50">
  <div class="bg-white rounded-lg shadow-xl max-w-md w-full mx-4">
    <div class="p-6">
      <h3 class="text-lg font-medium text-gray-900 mb-4">スポットを却下</h3>
      <%= form_with url: "#", method: :patch, id: "reject-form", class: "space-y-4" do |f| %>
        <div>
          <label for="rejection-reason" class="block text-sm font-medium text-gray-700">却下理由</label>
          <textarea id="rejection-reason" name="reason" rows="3" required
            class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm"
            placeholder="却下理由を入力してください..."></textarea>
        </div>
        <div class="flex justify-end gap-3">
          <button type="button" onclick="closeRejectModal()" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50">
            キャンセル
          </button>
          <button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-red-600 border border-transparent rounded-lg hover:bg-red-700">
            却下する
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
  // Tab switching
  document.querySelectorAll('.tab-button').forEach(button => {
    button.addEventListener('click', () => {
      // Update button styles
      document.querySelectorAll('.tab-button').forEach(b => {
        b.classList.remove('border-indigo-500', 'text-indigo-600');
        b.classList.add('border-transparent', 'text-gray-500');
      });
      button.classList.remove('border-transparent', 'text-gray-500');
      button.classList.add('border-indigo-500', 'text-indigo-600');

      // Show/hide tab content
      const tab = button.dataset.tab;
      document.querySelectorAll('.tab-content').forEach(content => {
        content.classList.add('hidden');
      });
      document.getElementById(tab + '-tab').classList.remove('hidden');
    });
  });

  // Reject modal
  function openRejectModal(spotId, rejectUrl) {
    const modal = document.getElementById('reject-modal');
    const form = document.getElementById('reject-form');
    form.action = rejectUrl;
    modal.classList.remove('hidden');
  }

  function closeRejectModal() {
    document.getElementById('reject-modal').classList.add('hidden');
    document.getElementById('rejection-reason').value = '';
  }
</script>
