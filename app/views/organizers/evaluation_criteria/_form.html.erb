<%= form_with model: [@contest, criterion], url: criterion.persisted? ? organizers_contest_evaluation_criterium_path(@contest, criterion) : organizers_contest_evaluation_criteria_path(@contest), class: "space-y-6" do |f| %>
  <% if criterion.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <div class="flex">
        <svg class="h-5 w-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            <%= pluralize(criterion.errors.count, "件のエラー") %>があります
          </h3>
          <ul class="mt-2 text-sm text-red-700 list-disc list-inside">
            <% criterion.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100">
      <h2 class="text-lg font-semibold text-gray-900">基準情報</h2>
    </div>
    <div class="p-6 space-y-6">
      <!-- Name -->
      <div>
        <%= f.label :name, "基準名", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :name, placeholder: "例：構図、色彩、テーマへの適合性", class: "w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors" %>
        <p class="mt-1 text-xs text-gray-500">50文字以内で入力してください（必須）</p>
      </div>

      <!-- Description -->
      <div>
        <%= f.label :description, "説明", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_area :description, rows: 3, placeholder: "この評価基準で何を評価するかを説明してください", class: "w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors resize-none" %>
        <p class="mt-1 text-xs text-gray-500">500文字以内（任意）</p>
      </div>

      <!-- Max Score -->
      <div>
        <%= f.label :max_score, "最大スコア", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.number_field :max_score, min: 1, max: 100, value: criterion.max_score || 10, class: "w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors" %>
        <p class="mt-1 text-xs text-gray-500">1〜100の整数（必須）</p>
      </div>

      <!-- Position -->
      <div>
        <%= f.label :position, "表示順", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.number_field :position, min: 1, class: "w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors" %>
        <p class="mt-1 text-xs text-gray-500">小さい数字が先に表示されます（任意、未入力時は自動設定）</p>
      </div>
    </div>
  </div>

  <!-- Form Actions -->
  <div class="flex items-center justify-end space-x-4">
    <%= link_to "キャンセル", organizers_contest_evaluation_criteria_path(@contest), class: "px-6 py-3 border border-gray-300 rounded-lg text-gray-700 font-medium hover:bg-gray-50 transition-colors" %>
    <%= f.submit criterion.persisted? ? "更新する" : "追加する", class: "px-6 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg cursor-pointer transition-colors" %>
  </div>
<% end %>
