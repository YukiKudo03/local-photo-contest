<div class="container mx-auto px-4 py-8">
  <div class="mb-6">
    <%= link_to t('organizers.statistics.show.back'), organizers_contest_path(@contest), class: "text-blue-600 hover:text-blue-800" %>
  </div>

  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-900"><%= t('organizers.statistics.show.title') %></h1>
    <span class="text-gray-500"><%= @contest.title %></span>
  </div>

  <!-- サマリーカード -->
  <%= render "summary_cards", summary: @summary %>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- 左カラム -->
    <div>
      <!-- 応募数推移グラフ -->
      <%= render "entry_trend_chart",
                 daily_entries: @daily_entries,
                 weekly_entries: @weekly_entries,
                 show_weekly_option: @show_weekly_option %>

      <!-- 人気スポット -->
      <%= render "spot_chart", spot_rankings: @spot_rankings %>
    </div>

    <!-- 右カラム -->
    <div>
      <!-- 投票分析 -->
      <%= render "vote_analysis",
                 voting_started: @voting_started,
                 daily_votes: @daily_votes,
                 vote_summary: @vote_summary,
                 top_voted_entries: @top_voted_entries %>

      <!-- エリア別円グラフ -->
      <%= render "area_pie_chart", area_distribution: @area_distribution %>
    </div>
  </div>

  <!-- 高度な分析 -->
  <div class="mt-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4"><%= t('organizers.statistics.advanced.title') %></h2>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <%= render "participant_demographics",
                 repeater_rate: @repeater_rate,
                 new_participant_trend: @new_participant_trend,
                 cohort_analysis: @cohort_analysis %>
      <%= render "submission_heatmap", contest: @contest %>
    </div>
  </div>

  <!-- エリア間比較 -->
  <div class="mt-6 bg-white rounded-lg shadow p-6">
    <div class="flex justify-between items-center">
      <h2 class="text-lg font-semibold text-gray-900"><%= t('organizers.statistics.area_comparison.title') %></h2>
      <%= link_to t('organizers.statistics.area_comparison.view_detail'),
                  area_comparison_organizers_contest_statistics_path(@contest),
                  class: "text-blue-600 hover:text-blue-800 text-sm" %>
    </div>
  </div>

  <!-- PDFレポート -->
  <%= render "report_downloads", contest: @contest %>

  <!-- 発掘統計 -->
  <div class="mt-6">
    <%= render "discovery", contest: @contest %>
  </div>
</div>
