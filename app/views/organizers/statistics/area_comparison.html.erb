<div class="container mx-auto px-4 py-8">
  <div class="mb-6">
    <%= link_to t('organizers.statistics.show.back'), organizers_contest_statistics_path(@contest), class: "text-blue-600 hover:text-blue-800" %>
  </div>

  <h1 class="text-2xl font-bold text-gray-900 mb-6"><%= t('organizers.statistics.area_comparison.title') %></h1>

  <% if @area_comparison.empty? %>
    <div class="bg-white rounded-lg shadow p-6">
      <p class="text-sm text-gray-500"><%= t('organizers.statistics.area_comparison.no_areas') %></p>
    </div>
  <% else %>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
      <div class="bg-white rounded-lg shadow p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4"><%= t('organizers.statistics.area_comparison.entries') %> / <%= t('organizers.statistics.area_comparison.votes') %></h2>
        <%= bar_chart @area_comparison.map { |a| { name: a[:name], data: { t('organizers.statistics.area_comparison.entries') => a[:entries], t('organizers.statistics.area_comparison.votes') => a[:votes] } } } %>
      </div>

      <div class="bg-white rounded-lg shadow p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4"><%= t('organizers.statistics.area_comparison.distribution') %></h2>
        <% if @area_distribution.any? %>
          <%= pie_chart @area_distribution %>
        <% else %>
          <p class="text-sm text-gray-500"><%= t('organizers.statistics.area_comparison.no_areas') %></p>
        <% end %>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4"><%= t('organizers.statistics.area_comparison.score') %></h2>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">エリア</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t('organizers.statistics.area_comparison.entries') %></th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t('organizers.statistics.area_comparison.votes') %></th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t('organizers.statistics.area_comparison.participants') %></th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t('organizers.statistics.area_comparison.score') %></th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @area_comparison.sort_by { |a| -a[:score] }.each do |area| %>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900"><%= area[:name] %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 text-right"><%= area[:entries] %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 text-right"><%= area[:votes] %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 text-right"><%= area[:participants] %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold text-blue-600 text-right"><%= area[:score] %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>
</div>
