<%# Discovery Statistics Partial %>
<% discovery_stats = DiscoverySpotService.discovery_statistics(contest) %>

<div class="bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden">
  <div class="px-6 py-4 border-b border-gray-100">
    <h2 class="text-lg font-semibold text-gray-900">
      <svg class="inline-block w-5 h-5 mr-2 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      発掘統計
    </h2>
  </div>

  <div class="p-6">
    <!-- Spot Status Summary -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
      <div class="bg-gray-50 rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-gray-900"><%= discovery_stats[:total_spots] %></div>
        <div class="text-sm text-gray-500">総スポット数</div>
      </div>
      <div class="bg-blue-50 rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-blue-600"><%= discovery_stats[:organizer_created] %></div>
        <div class="text-sm text-gray-500">主催者作成</div>
      </div>
      <div class="bg-green-50 rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-green-600"><%= discovery_stats[:certified] %></div>
        <div class="text-sm text-gray-500">認定済み</div>
      </div>
      <div class="bg-amber-50 rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-amber-600"><%= discovery_stats[:pending_certification] %></div>
        <div class="text-sm text-gray-500">審査待ち</div>
      </div>
    </div>

    <!-- Discoverers and Votes -->
    <div class="grid grid-cols-2 gap-4 mb-6">
      <div class="border border-gray-200 rounded-lg p-4">
        <div class="flex items-center justify-between">
          <div>
            <div class="text-sm text-gray-500">アクティブ発掘者</div>
            <div class="text-xl font-bold text-gray-900"><%= discovery_stats[:active_discoverers] %> 人</div>
          </div>
          <svg class="w-8 h-8 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
        </div>
      </div>
      <div class="border border-gray-200 rounded-lg p-4">
        <div class="flex items-center justify-between">
          <div>
            <div class="text-sm text-gray-500">スポット投票数</div>
            <div class="text-xl font-bold text-gray-900"><%= discovery_stats[:total_spot_votes] %> 票</div>
          </div>
          <svg class="w-8 h-8 text-pink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
          </svg>
        </div>
      </div>
    </div>

    <!-- Top Voted Spots -->
    <% top_voted = discovery_stats[:top_voted_spots] %>
    <% if top_voted.any? %>
      <div class="mb-6">
        <h3 class="text-sm font-medium text-gray-700 mb-3">人気スポット TOP 5</h3>
        <div class="space-y-2">
          <% top_voted.first(5).each_with_index do |spot, index| %>
            <div class="flex items-center justify-between p-2 bg-gray-50 rounded">
              <div class="flex items-center min-w-0">
                <span class="w-6 h-6 rounded-full bg-indigo-100 text-indigo-800 text-xs font-bold flex items-center justify-center flex-shrink-0">
                  <%= index + 1 %>
                </span>
                <span class="ml-2 text-sm text-gray-900 truncate"><%= spot.name %></span>
              </div>
              <div class="flex items-center text-sm text-gray-500 flex-shrink-0">
                <svg class="w-4 h-4 text-pink-500 mr-1" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                </svg>
                <%= spot.votes_count %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Top Discoverers -->
    <% top_discoverers = discovery_stats[:top_discoverers] %>
    <% if top_discoverers.any? %>
      <div class="mb-6">
        <h3 class="text-sm font-medium text-gray-700 mb-3">トップ発掘者 TOP 5</h3>
        <div class="space-y-2">
          <% top_discoverers.first(5).each_with_index do |user, index| %>
            <div class="flex items-center justify-between p-2 bg-gray-50 rounded">
              <div class="flex items-center min-w-0">
                <span class="w-6 h-6 rounded-full bg-green-100 text-green-800 text-xs font-bold flex items-center justify-center flex-shrink-0">
                  <%= index + 1 %>
                </span>
                <span class="ml-2 text-sm text-gray-900 truncate"><%= user.name.presence || user.email.split('@').first %></span>
              </div>
              <span class="text-sm text-gray-500 flex-shrink-0"><%= user.discovery_count %> スポット</span>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Challenges Stats -->
    <% challenges = discovery_stats[:challenges_stats] %>
    <% if challenges.any? %>
      <div>
        <h3 class="text-sm font-medium text-gray-700 mb-3">発掘チャレンジ</h3>
        <div class="space-y-2">
          <% challenges.each do |challenge| %>
            <div class="flex items-center justify-between p-3 border border-gray-200 rounded-lg">
              <div class="min-w-0">
                <div class="text-sm font-medium text-gray-900 truncate"><%= challenge[:name] %></div>
                <div class="text-xs text-gray-500">
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%=
                    case challenge[:status]
                    when 'draft' then 'bg-gray-100 text-gray-800'
                    when 'active' then 'bg-green-100 text-green-800'
                    when 'finished' then 'bg-blue-100 text-blue-800'
                    end
                  %>">
                    <%=
                      case challenge[:status]
                      when 'draft' then '下書き'
                      when 'active' then '開催中'
                      when 'finished' then '終了'
                      end
                    %>
                  </span>
                </div>
              </div>
              <div class="text-right flex-shrink-0 ml-4">
                <div class="text-sm text-gray-900"><%= challenge[:entries_count] %> 応募</div>
                <div class="text-xs text-gray-500"><%= challenge[:discovered_spots_count] %> 発掘</div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
