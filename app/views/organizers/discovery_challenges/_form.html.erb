<%= form_with model: [@contest, challenge], url: challenge.persisted? ? organizers_contest_discovery_challenge_path(@contest, challenge) : organizers_contest_discovery_challenges_path(@contest), class: "space-y-6" do |f| %>
  <% if challenge.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <div class="flex">
        <svg class="h-5 w-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">入力内容に問題があります</h3>
          <ul class="mt-2 text-sm text-red-700 list-disc list-inside">
            <% challenge.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 space-y-6">
    <!-- Name -->
    <div>
      <%= f.label :name, "チャレンジ名", class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :name, class: "mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "例: 隠れた桜スポットを探せ！" %>
      <p class="mt-1 text-xs text-gray-500">最大100文字</p>
    </div>

    <!-- Theme -->
    <div>
      <%= f.label :theme, "テーマ", class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :theme, class: "mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "例: 春の花見スポット" %>
      <p class="mt-1 text-xs text-gray-500">参加者に伝える発掘テーマを入力してください</p>
    </div>

    <!-- Description -->
    <div>
      <%= f.label :description, "説明", class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_area :description, rows: 4, class: "mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "チャレンジの詳細な説明や参加方法を記載してください..." %>
    </div>

    <!-- Period -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <%= f.label :starts_at, "開始日時", class: "block text-sm font-medium text-gray-700" %>
        <%= f.datetime_local_field :starts_at, class: "mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
      </div>
      <div>
        <%= f.label :ends_at, "終了日時", class: "block text-sm font-medium text-gray-700" %>
        <%= f.datetime_local_field :ends_at, class: "mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
      </div>
    </div>
  </div>

  <!-- Actions -->
  <div class="flex items-center justify-end gap-3">
    <%= link_to "キャンセル", organizers_contest_discovery_challenges_path(@contest), class: "px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50" %>
    <%= f.submit challenge.persisted? ? "更新する" : "作成する", class: "px-4 py-2 text-sm font-medium text-white bg-indigo-600 border border-transparent rounded-lg hover:bg-indigo-700 cursor-pointer" %>
  </div>
<% end %>
