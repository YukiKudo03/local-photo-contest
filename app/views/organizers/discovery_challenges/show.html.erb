<!-- Page Header -->
<div class="mb-8">
  <%= link_to organizers_contest_discovery_challenges_path(@contest), class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700 mb-2" do %>
    <svg class="mr-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
    </svg>
    <%= t('organizers.discovery_challenges.new.back') %>
  <% end %>
  <div class="flex items-center justify-between">
    <div>
      <div class="flex items-center gap-3">
        <h1 class="text-2xl font-bold text-gray-900"><%= @challenge.name %></h1>
        <% case @challenge.status %>
        <% when "draft" %>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
            <%= t('organizers.contests.index.draft') %>
          </span>
        <% when "active" %>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
            <%= t('organizers.discovery_challenges.index.active') %>
          </span>
        <% when "finished" %>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
            <%= t('organizers.contests.index.finished') %>
          </span>
        <% end %>
      </div>
      <% if @challenge.theme.present? %>
        <p class="mt-1 text-sm text-indigo-600"><%= t('organizers.discovery_challenges.show.theme') %>: <%= @challenge.theme %></p>
      <% end %>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to edit_organizers_contest_discovery_challenge_path(@contest, @challenge), class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50" do %>
        <svg class="mr-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
        </svg>
        <%= t('organizers.areas.show.edit') %>
      <% end %>
    </div>
  </div>
</div>

<!-- Challenge Info -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
  <div class="lg:col-span-2 bg-white rounded-xl shadow-sm border border-gray-100 p-6">
    <h2 class="text-lg font-medium text-gray-900 mb-4"><%= t('organizers.discovery_challenges.show.details') %></h2>
    <% if @challenge.description.present? %>
      <div class="prose prose-sm max-w-none text-gray-600">
        <%= simple_format(@challenge.description) %>
      </div>
    <% else %>
      <p class="text-gray-500 text-sm"><%= t('organizers.discovery_challenges.show.no_description') %></p>
    <% end %>

    <% if @challenge.starts_at.present? || @challenge.ends_at.present? %>
      <div class="mt-4 pt-4 border-t border-gray-100">
        <h3 class="text-sm font-medium text-gray-700 mb-2"><%= t('organizers.discovery_challenges.show.period') %></h3>
        <p class="text-sm text-gray-600">
          <% if @challenge.starts_at.present? && @challenge.ends_at.present? %>
            <%= l(@challenge.starts_at, format: :long) %> 〜 <%= l(@challenge.ends_at, format: :long) %>
          <% elsif @challenge.starts_at.present? %>
            <%= l(@challenge.starts_at, format: :long) %> 〜
          <% elsif @challenge.ends_at.present? %>
            〜 <%= l(@challenge.ends_at, format: :long) %>
          <% end %>
        </p>
      </div>
    <% end %>
  </div>

  <!-- Stats -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6" data-testid="stats-section">
    <h2 class="text-lg font-medium text-gray-900 mb-4"><%= t('organizers.discovery_challenges.show.statistics') %></h2>
    <dl class="space-y-4">
      <div>
        <dt class="text-sm text-gray-500"><%= t('organizers.discovery_challenges.show.entries_count') %></dt>
        <dd class="mt-1 text-2xl font-semibold text-gray-900"><%= @challenge.entries_count %></dd>
      </div>
      <div>
        <dt class="text-sm text-gray-500"><%= t('organizers.discovery_challenges.show.spots_count') %></dt>
        <dd class="mt-1 text-2xl font-semibold text-gray-900"><%= @challenge.discovered_spots_count %></dd>
      </div>
      <div>
        <dt class="text-sm text-gray-500"><%= t('organizers.discovery_challenges.show.participants_count') %></dt>
        <dd class="mt-1 text-2xl font-semibold text-gray-900"><%= @challenge.entries.select(:user_id).distinct.count %></dd>
      </div>
    </dl>
  </div>
</div>

<!-- Recent Entries -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-8" data-testid="entries-section">
  <h2 class="text-lg font-medium text-gray-900 mb-4"><%= t('organizers.discovery_challenges.show.entries') %></h2>
  <% if @entries.any? %>
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-4">
      <% @entries.each do |entry| %>
        <div class="group relative">
          <div class="aspect-square rounded-lg overflow-hidden bg-gray-100">
            <% if entry.photo.attached? %>
              <%= image_tag entry.photo.variant(resize_to_fill: [200, 200]), alt: entry.title.presence || t('organizers.dashboard.untitled'), class: "w-full h-full object-cover", loading: "lazy" %>
            <% end %>
          </div>
          <div class="mt-2">
            <p class="text-xs text-gray-600 truncate"><%= entry.title.presence || t('organizers.dashboard.untitled') %></p>
            <p class="text-xs text-gray-400"><%= entry.user.display_name %></p>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-8">
      <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
      <p class="mt-2 text-sm text-gray-500"><%= t('organizers.discovery_challenges.show.no_entries') %></p>
    </div>
  <% end %>
</div>

<!-- Discovered Spots -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6" data-testid="spots-section">
  <h2 class="text-lg font-medium text-gray-900 mb-4"><%= t('organizers.discovery_challenges.show.discovered_spots') %></h2>
  <% if @discovered_spots.any? %>
    <div class="space-y-3">
      <% @discovered_spots.each do |spot| %>
        <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-lg bg-indigo-100 flex items-center justify-center">
              <svg class="h-5 w-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              </svg>
            </div>
            <div>
              <p class="text-sm font-medium text-gray-900"><%= spot.name %></p>
              <p class="text-xs text-gray-500">
                <%= t('organizers.discovery_spots.spot.discoverer') %>: <%= spot.discovered_by&.display_name || t('organizers.discovery_challenges.show.unknown') %>
              </p>
            </div>
          </div>
          <span class="inline-flex items-center px-2 py-1 rounded text-xs font-medium <%= spot.discovery_certified? ? 'bg-green-100 text-green-700' : 'bg-amber-100 text-amber-700' %>">
            <%= spot.discovery_status_name %>
          </span>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-8">
      <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
      </svg>
      <p class="mt-2 text-sm text-gray-500"><%= t('organizers.discovery_challenges.show.no_spots') %></p>
    </div>
  <% end %>
</div>
