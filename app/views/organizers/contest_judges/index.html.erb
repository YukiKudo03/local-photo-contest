<!-- Page Header -->
<div class="mb-8">
  <div class="flex items-center justify-between">
    <div>
      <%= link_to organizers_contest_path(@contest), class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700 mb-2" do %>
        <svg class="mr-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        <%= t('organizers.contest_judges.index.back', title: @contest.title) %>
      <% end %>
      <h1 class="text-2xl font-bold text-gray-900"><%= t('organizers.contest_judges.index.title') %></h1>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <!-- Current Judges List -->
  <div class="lg:col-span-2">
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100">
        <h2 class="text-lg font-semibold text-gray-900"><%= t('organizers.contest_judges.index.judges_list') %></h2>
      </div>
      <% if @judges.any? %>
        <!-- Overall Progress Summary -->
        <div class="px-6 py-4 bg-gray-50 border-b border-gray-100">
          <div class="flex items-center justify-between mb-2">
            <span class="text-sm font-medium text-gray-700"><%= t('organizers.contest_judges.index.overall_progress') %></span>
            <span class="text-sm font-semibold text-gray-900"><%= @contest.judge_completion_rate %>%</span>
          </div>
          <div class="w-full bg-gray-200 rounded-full h-2.5">
            <% completion_rate = @contest.judge_completion_rate %>
            <div class="h-2.5 rounded-full <%= completion_rate >= 100 ? 'bg-green-500' : completion_rate >= 50 ? 'bg-yellow-500' : 'bg-red-500' %>" style="width: <%= completion_rate %>%"></div>
          </div>
          <p class="mt-1 text-xs text-gray-500">
            <%= t('organizers.contest_judges.index.progress_desc', entries: @contest.entries.count, criteria: @contest.evaluation_criteria.count, judges: @judges.count) %>
          </p>
        </div>

        <ul class="divide-y divide-gray-100">
          <% @judges.each do |judge| %>
            <% progress = judge.evaluation_progress %>
            <% evaluated_entries = judge.judge_evaluations.select(:entry_id).distinct.count %>
            <% total_entries = @contest.entries.where.not(user_id: judge.user_id).count %>
            <li class="p-6">
              <div class="flex items-center justify-between mb-3">
                <div class="flex items-center">
                  <div class="w-10 h-10 bg-indigo-100 rounded-full flex items-center justify-center">
                    <svg class="h-5 w-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                  </div>
                  <div class="ml-4">
                    <p class="text-sm font-medium text-gray-900"><%= judge.user.email %></p>
                    <p class="text-xs text-gray-500">
                      <%= t('organizers.contest_judges.index.invited_at') %>: <%= judge.invited_at ? l(judge.invited_at, format: :long) : t('organizers.contests.show.not_set') %>
                    </p>
                  </div>
                </div>
                <div class="flex items-center space-x-4">
                  <div class="text-right">
                    <span class="text-lg font-semibold <%= progress >= 100 ? 'text-green-600' : progress >= 50 ? 'text-yellow-600' : 'text-red-600' %>">
                      <%= progress %>%
                    </span>
                    <p class="text-xs text-gray-500"><%= evaluated_entries %>/<%= total_entries %></p>
                  </div>
                  <% unless @contest.results_announced? %>
                    <%= button_to organizers_contest_judge_path(@contest, judge),
                        method: :delete,
                        data: { turbo_confirm: t('organizers.contest_judges.index.remove_confirm') },
                        class: "text-red-600 hover:text-red-800 text-sm font-medium" do %>
                      <%= t('organizers.areas.show.delete') %>
                    <% end %>
                  <% end %>
                </div>
              </div>
              <!-- Individual Progress Bar -->
              <div class="w-full bg-gray-200 rounded-full h-2">
                <div class="h-2 rounded-full <%= progress >= 100 ? 'bg-green-500' : progress >= 50 ? 'bg-yellow-500' : 'bg-red-500' %>" style="width: <%= progress %>%"></div>
              </div>
              <% if progress >= 100 %>
                <p class="mt-2 text-xs text-green-600 flex items-center">
                  <svg class="h-4 w-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  <%= t('organizers.contest_judges.index.evaluation_complete') %>
                </p>
              <% elsif progress > 0 %>
<p class="mt-2 text-xs text-yellow-600"><%= t('organizers.contest_judges.index.evaluating') %></p>
              <% else %>
<p class="mt-2 text-xs text-gray-500"><%= t('organizers.contest_judges.index.not_started') %></p>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="p-6 text-center text-gray-500">
          <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <p class="mt-2"><%= t('organizers.contest_judges.index.no_judges') %></p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Add Judge Form -->
  <div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100">
        <h2 class="text-lg font-semibold text-gray-900"><%= t('organizers.contest_judges.index.add_judge') %></h2>
      </div>
      <div class="p-6">
        <% if @contest.results_announced? %>
          <p class="text-sm text-gray-500"><%= t('organizers.contest_judges.index.cannot_change') %></p>
        <% elsif @available_users.any? %>
          <%= form_with url: organizers_contest_judges_path(@contest), method: :post, class: "space-y-4" do |f| %>
            <div>
              <label for="contest_judge_user_id" class="block text-sm font-medium text-gray-700 mb-1"><%= t('organizers.contest_judges.index.select_user') %></label>
              <select name="contest_judge[user_id]" id="contest_judge_user_id" required
                      class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                <option value=""><%= t('organizers.contest_judges.index.select_placeholder') %></option>
                <% @available_users.each do |user| %>
                  <option value="<%= user.id %>"><%= user.email %></option>
                <% end %>
              </select>
            </div>
            <button type="submit" class="w-full px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg transition-colors">
              <%= t('organizers.contest_judges.index.add_judge') %>
            </button>
          <% end %>
        <% else %>
          <p class="text-sm text-gray-500"><%= t('organizers.contest_judges.index.no_available_users') %></p>
        <% end %>
      </div>
    </div>

    <!-- Info Card -->
    <div class="mt-6 bg-blue-50 rounded-xl p-6">
      <div class="flex">
        <svg class="h-6 w-6 text-blue-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-blue-800"><%= t('organizers.contest_judges.index.about_judges') %></h3>
          <p class="mt-2 text-sm text-blue-700">
            <%= t('organizers.contest_judges.index.about_judges_desc') %>
          </p>
        </div>
      </div>
    </div>
  </div>
</div>
