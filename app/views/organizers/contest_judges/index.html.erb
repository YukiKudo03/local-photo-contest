<!-- Page Header -->
<div class="mb-8">
  <div class="flex items-center justify-between">
    <div>
      <%= link_to organizers_contest_path(@contest), class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700 mb-2" do %>
        <svg class="mr-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        <%= @contest.title %>に戻る
      <% end %>
      <h1 class="text-2xl font-bold text-gray-900">審査員管理</h1>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <!-- Current Judges List -->
  <div class="lg:col-span-2">
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100">
        <h2 class="text-lg font-semibold text-gray-900">審査員一覧</h2>
      </div>
      <% if @judges.any? %>
        <ul class="divide-y divide-gray-100">
          <% @judges.each do |judge| %>
            <li class="p-6 flex items-center justify-between">
              <div class="flex items-center">
                <div class="w-10 h-10 bg-indigo-100 rounded-full flex items-center justify-center">
                  <svg class="h-5 w-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                  </svg>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-900"><%= judge.user.email %></p>
                  <p class="text-xs text-gray-500">
                    招待日: <%= judge.invited_at&.strftime('%Y年%m月%d日 %H:%M') || '未設定' %>
                  </p>
                  <p class="text-xs text-gray-500">
                    評価進捗: <%= judge.evaluation_progress %>%
                  </p>
                </div>
              </div>
              <% unless @contest.results_announced? %>
                <%= button_to organizers_contest_judge_path(@contest, judge),
                    method: :delete,
                    data: { turbo_confirm: "この審査員を削除しますか？" },
                    class: "text-red-600 hover:text-red-800 text-sm font-medium" do %>
                  削除
                <% end %>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="p-6 text-center text-gray-500">
          <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <p class="mt-2">審査員がまだ登録されていません</p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Add Judge Form -->
  <div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100">
        <h2 class="text-lg font-semibold text-gray-900">審査員を追加</h2>
      </div>
      <div class="p-6">
        <% if @contest.results_announced? %>
          <p class="text-sm text-gray-500">結果発表後は審査員を変更できません。</p>
        <% elsif @available_users.any? %>
          <%= form_with url: organizers_contest_judges_path(@contest), method: :post, class: "space-y-4" do |f| %>
            <div>
              <label for="contest_judge_user_id" class="block text-sm font-medium text-gray-700 mb-1">ユーザーを選択</label>
              <select name="contest_judge[user_id]" id="contest_judge_user_id" required
                      class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                <option value="">選択してください</option>
                <% @available_users.each do |user| %>
                  <option value="<%= user.id %>"><%= user.email %></option>
                <% end %>
              </select>
            </div>
            <button type="submit" class="w-full px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg transition-colors">
              審査員を追加
            </button>
          <% end %>
        <% else %>
          <p class="text-sm text-gray-500">追加可能なユーザーがいません。</p>
        <% end %>
      </div>
    </div>

    <!-- Info Card -->
    <div class="mt-6 bg-blue-50 rounded-xl p-6">
      <div class="flex">
        <svg class="h-6 w-6 text-blue-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-blue-800">審査員について</h3>
          <p class="mt-2 text-sm text-blue-700">
            審査員として追加されたユーザーは、マイページから評価ダッシュボードにアクセスできます。
            各作品に対して設定された評価基準でスコアを付けることができます。
          </p>
        </div>
      </div>
    </div>
  </div>
</div>
