<!-- Page Header -->
<div class="mb-8">
  <%= link_to organizers_contest_path(@contest), class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700 mb-2" do %>
    <svg class="mr-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
    </svg>
    コンテスト詳細に戻る
  <% end %>
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">応募一覧</h1>
      <p class="mt-1 text-sm text-gray-500"><%= @contest.title %></p>
    </div>
    <div class="text-right">
      <p class="text-2xl font-bold text-indigo-600"><%= @entries.count %></p>
      <p class="text-sm text-gray-500">件の応募</p>
    </div>
  </div>
</div>

<% if @entries.any? %>
  <%
    # Prepare entries with spot coordinates for map display
    entries_with_spots = @entries.includes(:spot).select { |e| e.spot&.coordinates.present? }
    entries_markers = entries_with_spots.map { |e|
      {
        lat: e.spot.latitude.to_f,
        lng: e.spot.longitude.to_f,
        popup: {
          title: e.title.presence || "無題",
          subtitle: e.spot.name,
          description: e.user.email
        },
        entryId: e.id,
        entryPath: organizers_contest_entry_path(@contest, e)
      }
    }
    has_map_entries = entries_with_spots.any?

    # Map center
    if has_map_entries
      center_lat = @contest.area&.latitude || entries_with_spots.first.spot.latitude
      center_lng = @contest.area&.longitude || entries_with_spots.first.spot.longitude
    end
  %>

  <!-- View Toggle -->
  <div class="mb-4" data-controller="view-toggle">
    <div class="flex items-center justify-between">
      <div class="flex rounded-lg overflow-hidden border border-gray-300">
        <button type="button"
                data-view-toggle-target="listButton"
                data-action="click->view-toggle#showList"
                class="px-4 py-2 text-sm font-medium bg-indigo-600 text-white flex items-center">
          <svg class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
          </svg>
          リスト
        </button>
        <% if has_map_entries %>
          <button type="button"
                  data-view-toggle-target="mapButton"
                  data-action="click->view-toggle#showMap"
                  class="px-4 py-2 text-sm font-medium bg-white text-gray-700 hover:bg-gray-50 flex items-center">
            <svg class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
            </svg>
            マップ
          </button>
        <% end %>
      </div>

      <% if has_map_entries %>
        <p class="text-xs text-gray-500">
          <span class="font-medium"><%= entries_with_spots.count %></span>/<%= @entries.count %> 件がスポット付き
        </p>
      <% end %>
    </div>

    <!-- List View -->
    <div data-view-toggle-target="listView" class="mt-4">
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">写真</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">タイトル</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">応募者</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">スポット</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">応募日時</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">操作</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% @entries.each do |entry| %>
                <tr class="hover:bg-gray-50">
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="w-16 h-16 rounded-lg overflow-hidden bg-gray-100">
                      <% if entry.photo.attached? %>
                        <%= image_tag entry.photo.variant(resize_to_fill: [128, 128]), alt: entry.title.presence || "フォトコンテスト応募作品", class: "w-full h-full object-cover", loading: "lazy" %>
                      <% end %>
                    </div>
                  </td>
                  <td class="px-6 py-4">
                    <% if entry.title.present? %>
                      <div class="text-sm font-medium text-gray-900"><%= entry.title %></div>
                    <% else %>
                      <div class="text-sm text-gray-400">無題</div>
                    <% end %>
                    <% if entry.location.present? %>
                      <div class="text-xs text-gray-500"><%= entry.location %></div>
                    <% end %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="text-sm text-gray-900"><%= entry.user.email %></div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <% if entry.spot.present? %>
                      <span class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-teal-100 text-teal-800">
                        <%= entry.spot.name %>
                      </span>
                    <% else %>
                      <span class="text-xs text-gray-400">-</span>
                    <% end %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                    <%= entry.created_at.strftime('%Y/%m/%d %H:%M') %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                    <%= link_to "詳細", organizers_contest_entry_path(@contest, entry), class: "text-indigo-600 hover:text-indigo-900" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Map View -->
    <% if has_map_entries %>
      <div data-view-toggle-target="mapView" class="mt-4 hidden">
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden p-4">
          <div data-controller="entries-map"
               data-entries-map-entries-value="<%= entries_markers.to_json %>"
               data-entries-map-center-lat-value="<%= center_lat %>"
               data-entries-map-center-lng-value="<%= center_lng %>"
               <% if @contest.area&.boundary_geojson.present? %>data-entries-map-boundary-value="<%= @contest.area.boundary_geojson %>"<% end %>>
            <div data-entries-map-target="container" class="map-container map-container-lg rounded-lg"></div>
          </div>

          <div class="mt-4">
            <p class="text-xs text-gray-500 mb-2">マーカーをクリックして詳細を表示</p>
            <div class="flex flex-wrap gap-2">
              <% @contest.spots.ordered.each do |spot| %>
                <% spot_entry_count = entries_with_spots.count { |e| e.spot_id == spot.id } %>
                <span class="inline-flex items-center px-2 py-1 rounded text-xs <%= spot_entry_count > 0 ? 'bg-teal-100 text-teal-800' : 'bg-gray-100 text-gray-500' %>">
                  <%= spot.name %>
                  <span class="ml-1 font-medium">(<%= spot_entry_count %>)</span>
                </span>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <!-- Empty State -->
  <div class="text-center py-12 bg-white rounded-xl shadow-sm border border-gray-100">
    <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
    </svg>
    <h3 class="mt-4 text-lg font-medium text-gray-900">応募がありません</h3>
    <p class="mt-2 text-sm text-gray-500">まだこのコンテストへの応募はありません</p>
  </div>
<% end %>
