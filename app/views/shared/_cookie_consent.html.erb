<div data-controller="cookie-consent" data-turbo-permanent id="cookie-consent">
  <div data-cookie-consent-target="banner" class="hidden fixed bottom-0 inset-x-0 z-50 bg-white border-t border-gray-200 shadow-lg p-4 sm:p-6">
    <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-start sm:items-center gap-4">
      <div class="flex-1">
        <h3 class="text-sm font-semibold text-gray-900 mb-1"><%= t('gdpr.cookie_consent.title') %></h3>
        <p class="text-sm text-gray-600">
          <%= t('gdpr.cookie_consent.description') %>
          <%= link_to t('gdpr.cookie_consent.privacy_link'), privacy_policy_path, class: "text-indigo-600 hover:text-indigo-500 underline" %>
        </p>
      </div>
      <div class="flex flex-wrap gap-2">
        <button data-action="cookie-consent#acceptEssential" class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-md transition-colors">
          <%= t('gdpr.cookie_consent.essential_only') %>
        </button>
        <button data-action="cookie-consent#showCustom" class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-md transition-colors">
          <%= t('gdpr.cookie_consent.customize') %>
        </button>
        <button data-action="cookie-consent#acceptAll" class="px-4 py-2 text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-500 rounded-md transition-colors">
          <%= t('gdpr.cookie_consent.accept_all') %>
        </button>
      </div>
    </div>

    <!-- Custom panel -->
    <div data-cookie-consent-target="customPanel" class="hidden max-w-7xl mx-auto mt-4 pt-4 border-t border-gray-200">
      <div class="space-y-3">
        <label class="flex items-center gap-3">
          <input type="checkbox" checked disabled class="h-4 w-4 rounded text-indigo-600">
          <div>
            <span class="text-sm font-medium text-gray-900"><%= t('gdpr.cookie_consent.essential_title') %></span>
            <p class="text-xs text-gray-500"><%= t('gdpr.cookie_consent.essential_description') %></p>
          </div>
        </label>
        <label class="flex items-center gap-3">
          <input type="checkbox" data-cookie-type="analytics" class="h-4 w-4 rounded text-indigo-600">
          <div>
            <span class="text-sm font-medium text-gray-900"><%= t('gdpr.cookie_consent.analytics_title') %></span>
            <p class="text-xs text-gray-500"><%= t('gdpr.cookie_consent.analytics_description') %></p>
          </div>
        </label>
      </div>
      <div class="mt-4">
        <button data-action="cookie-consent#saveCustom" class="px-4 py-2 text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-500 rounded-md transition-colors">
          <%= t('gdpr.cookie_consent.save_preferences') %>
        </button>
      </div>
    </div>
  </div>
</div>
