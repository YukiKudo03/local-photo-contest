<% if notice.present? %>
  <div class="fixed top-4 right-4 z-50 max-w-md" data-controller="flash" data-flash-target="container">
    <div class="bg-white border-l-4 border-green-500 rounded-lg p-4 shadow-xl">
      <div class="flex items-start">
        <div class="flex-shrink-0">
          <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center">
            <svg class="h-5 w-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
        </div>
        <div class="ml-3 flex-1">
          <p class="text-sm font-semibold text-gray-900">成功</p>
          <p class="mt-1 text-sm text-gray-600"><%= notice %></p>
        </div>
        <div class="ml-4 flex-shrink-0">
          <button type="button" class="inline-flex text-gray-400 hover:text-gray-500 focus:outline-none transition-colors" data-action="flash#dismiss">
            <span class="sr-only">閉じる</span>
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
<% end %>

<% if alert.present? %>
  <div class="fixed top-4 right-4 z-50 max-w-md" data-controller="flash" data-flash-target="container">
    <div class="bg-white border-l-4 border-red-500 rounded-lg p-4 shadow-xl">
      <div class="flex items-start">
        <div class="flex-shrink-0">
          <div class="w-8 h-8 bg-red-100 rounded-full flex items-center justify-center">
            <svg class="h-5 w-5 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
          </div>
        </div>
        <div class="ml-3 flex-1">
          <p class="text-sm font-semibold text-gray-900">エラー</p>
          <p class="mt-1 text-sm text-gray-600"><%= alert %></p>
        </div>
        <div class="ml-4 flex-shrink-0">
          <button type="button" class="inline-flex text-gray-400 hover:text-gray-500 focus:outline-none transition-colors" data-action="flash#dismiss">
            <span class="sr-only">閉じる</span>
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
<% end %>

<style>
  @keyframes slide-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
  .animate-slide-in {
    animation: slide-in 0.3s ease-out;
  }
</style>
