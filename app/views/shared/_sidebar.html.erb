<aside class="w-full lg:w-64 bg-white border-r border-gray-200 lg:min-h-0">
  <nav class="p-4 space-y-1">
    <div class="px-3 py-2 text-xs font-semibold text-gray-500 uppercase tracking-wider">
      運営メニュー
    </div>

    <%= link_to organizers_dashboard_path, class: "group flex items-center px-3 py-2 text-sm font-medium rounded-md #{request.path == organizers_dashboard_path ? 'bg-indigo-50 text-indigo-600' : 'text-gray-700 hover:text-indigo-600 hover:bg-gray-50'}" do %>
      <svg class="mr-3 h-5 w-5 <%= request.path == organizers_dashboard_path ? 'text-indigo-600' : 'text-gray-400 group-hover:text-indigo-600' %>" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
      </svg>
      ダッシュボード
    <% end %>

    <div class="pt-4 px-3 py-2 text-xs font-semibold text-gray-500 uppercase tracking-wider">
      コンテスト管理
    </div>

    <%= link_to organizers_contests_path, data: { tutorial: "contests-link" }, class: "group flex items-center px-3 py-2 text-sm font-medium rounded-md #{request.path.start_with?(organizers_contests_path) && !request.path.include?('/new') ? 'bg-indigo-50 text-indigo-600' : 'text-gray-700 hover:text-indigo-600 hover:bg-gray-50'}" do %>
      <svg class="mr-3 h-5 w-5 <%= request.path.start_with?(organizers_contests_path) && !request.path.include?('/new') ? 'text-indigo-600' : 'text-gray-400 group-hover:text-indigo-600' %>" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
      </svg>
      コンテスト一覧
    <% end %>

    <%= link_to new_organizers_contest_path, data: { tutorial: "new-contest-button" }, class: "group flex items-center px-3 py-2 text-sm font-medium rounded-md #{request.path == new_organizers_contest_path ? 'bg-indigo-50 text-indigo-600' : 'text-gray-700 hover:text-indigo-600 hover:bg-gray-50'}" do %>
      <svg class="mr-3 h-5 w-5 <%= request.path == new_organizers_contest_path ? 'text-indigo-600' : 'text-gray-400 group-hover:text-indigo-600' %>" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
      </svg>
      新規コンテスト作成
    <% end %>

    <%= link_to organizers_contest_templates_path, data: { tutorial: "templates-link" }, class: "group flex items-center px-3 py-2 text-sm font-medium rounded-md #{request.path.start_with?(organizers_contest_templates_path) ? 'bg-indigo-50 text-indigo-600' : 'text-gray-700 hover:text-indigo-600 hover:bg-gray-50'}" do %>
      <svg class="mr-3 h-5 w-5 <%= request.path.start_with?(organizers_contest_templates_path) ? 'text-indigo-600' : 'text-gray-400 group-hover:text-indigo-600' %>" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      テンプレート
    <% end %>

    <div class="pt-4 px-3 py-2 text-xs font-semibold text-gray-500 uppercase tracking-wider">
      エリア・スポット
    </div>

    <%= link_to organizers_areas_path, data: { tutorial: "areas-link" }, class: "group flex items-center px-3 py-2 text-sm font-medium rounded-md #{request.path.start_with?(organizers_areas_path) ? 'bg-indigo-50 text-indigo-600' : 'text-gray-700 hover:text-indigo-600 hover:bg-gray-50'}" do %>
      <svg class="mr-3 h-5 w-5 <%= request.path.start_with?(organizers_areas_path) ? 'text-indigo-600' : 'text-gray-400 group-hover:text-indigo-600' %>" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
      </svg>
      エリア管理
    <% end %>

    <div class="pt-4 px-3 py-2 text-xs font-semibold text-gray-500 uppercase tracking-wider">
      写真管理
    </div>

    <a href="#" class="group flex items-center px-3 py-2 text-sm font-medium text-gray-400 rounded-md cursor-not-allowed" data-tutorial="entries-link">
      <svg class="mr-3 h-5 w-5 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
      投稿写真一覧
      <span class="ml-auto text-xs text-gray-400">準備中</span>
    </a>

    <a href="#" class="group flex items-center px-3 py-2 text-sm font-medium text-gray-400 rounded-md cursor-not-allowed" data-tutorial="moderation-link">
      <svg class="mr-3 h-5 w-5 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      モデレーション
      <span class="ml-auto text-xs text-gray-400">準備中</span>
    </a>

    <div class="pt-4 px-3 py-2 text-xs font-semibold text-gray-500 uppercase tracking-wider">
      審査・結果
    </div>

    <a href="#" class="group flex items-center px-3 py-2 text-sm font-medium text-gray-400 rounded-md cursor-not-allowed" data-tutorial="judges-link">
      <svg class="mr-3 h-5 w-5 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
      </svg>
      審査員管理
      <span class="ml-auto text-xs text-gray-400">準備中</span>
    </a>

    <a href="#" class="group flex items-center px-3 py-2 text-sm font-medium text-gray-400 rounded-md cursor-not-allowed" data-tutorial="statistics-link">
      <svg class="mr-3 h-5 w-5 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
      </svg>
      統計・分析
      <span class="ml-auto text-xs text-gray-400">準備中</span>
    </a>

    <a href="#" class="group flex items-center px-3 py-2 text-sm font-medium text-gray-400 rounded-md cursor-not-allowed" data-tutorial="results-link">
      <svg class="mr-3 h-5 w-5 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
      </svg>
      結果発表
      <span class="ml-auto text-xs text-gray-400">準備中</span>
    </a>

    <% if current_user.admin? %>
      <div class="pt-4 px-3 py-2 text-xs font-semibold text-gray-500 uppercase tracking-wider">
        管理者メニュー
      </div>

      <%= link_to admin_users_path, data: { tutorial: "admin-users-link" }, class: "group flex items-center px-3 py-2 text-sm font-medium rounded-md #{request.path.start_with?(admin_users_path) ? 'bg-indigo-50 text-indigo-600' : 'text-gray-700 hover:text-indigo-600 hover:bg-gray-50'}" do %>
        <svg class="mr-3 h-5 w-5 <%= request.path.start_with?(admin_users_path) ? 'text-indigo-600' : 'text-gray-400 group-hover:text-indigo-600' %>" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        ユーザー管理
      <% end %>

      <%= link_to admin_contests_path, data: { tutorial: "admin-contests-link" }, class: "group flex items-center px-3 py-2 text-sm font-medium rounded-md #{request.path.start_with?(admin_contests_path) ? 'bg-indigo-50 text-indigo-600' : 'text-gray-700 hover:text-indigo-600 hover:bg-gray-50'}" do %>
        <svg class="mr-3 h-5 w-5 <%= request.path.start_with?(admin_contests_path) ? 'text-indigo-600' : 'text-gray-400 group-hover:text-indigo-600' %>" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
        </svg>
        コンテスト管理
      <% end %>

      <%= link_to admin_categories_path, data: { tutorial: "admin-categories-link" }, class: "group flex items-center px-3 py-2 text-sm font-medium rounded-md #{request.path.start_with?(admin_categories_path) ? 'bg-indigo-50 text-indigo-600' : 'text-gray-700 hover:text-indigo-600 hover:bg-gray-50'}" do %>
        <svg class="mr-3 h-5 w-5 <%= request.path.start_with?(admin_categories_path) ? 'text-indigo-600' : 'text-gray-400 group-hover:text-indigo-600' %>" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
        </svg>
        カテゴリ管理
      <% end %>

      <%= link_to admin_audit_logs_path, data: { tutorial: "admin-audit-logs-link" }, class: "group flex items-center px-3 py-2 text-sm font-medium rounded-md #{request.path.start_with?(admin_audit_logs_path) ? 'bg-indigo-50 text-indigo-600' : 'text-gray-700 hover:text-indigo-600 hover:bg-gray-50'}" do %>
        <svg class="mr-3 h-5 w-5 <%= request.path.start_with?(admin_audit_logs_path) ? 'text-indigo-600' : 'text-gray-400 group-hover:text-indigo-600' %>" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
        </svg>
        監査ログ
      <% end %>
    <% end %>

    <div class="pt-4 px-3 py-2 text-xs font-semibold text-gray-500 uppercase tracking-wider">
      ヘルプ
    </div>

    <%= link_to help_guide_path(:organizer), class: "group flex items-center px-3 py-2 text-sm font-medium rounded-md #{request.path == help_guide_path(:organizer) ? 'bg-indigo-50 text-indigo-600' : 'text-gray-700 hover:text-indigo-600 hover:bg-gray-50'}" do %>
      <svg class="mr-3 h-5 w-5 <%= request.path == help_guide_path(:organizer) ? 'text-indigo-600' : 'text-gray-400 group-hover:text-indigo-600' %>" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      主催者ガイド
    <% end %>

    <%= link_to help_path, class: "group flex items-center px-3 py-2 text-sm font-medium rounded-md #{request.path == help_path ? 'bg-indigo-50 text-indigo-600' : 'text-gray-700 hover:text-indigo-600 hover:bg-gray-50'}" do %>
      <svg class="mr-3 h-5 w-5 <%= request.path == help_path ? 'text-indigo-600' : 'text-gray-400 group-hover:text-indigo-600' %>" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
      </svg>
      全マニュアル
    <% end %>
  </nav>
</aside>
