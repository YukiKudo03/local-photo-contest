<aside class="w-full lg:w-64 bg-white border-r border-gray-200 lg:min-h-0">
  <nav class="p-4 space-y-1">
    <div class="px-3 py-2 text-xs font-semibold text-gray-500 uppercase tracking-wider">
      運営メニュー
    </div>

    <%= link_to organizers_dashboard_path, class: "group flex items-center px-3 py-2 text-sm font-medium rounded-md #{request.path == organizers_dashboard_path ? 'bg-indigo-50 text-indigo-600' : 'text-gray-700 hover:text-indigo-600 hover:bg-gray-50'}" do %>
      <svg class="mr-3 h-5 w-5 <%= request.path == organizers_dashboard_path ? 'text-indigo-600' : 'text-gray-400 group-hover:text-indigo-600' %>" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
      </svg>
      ダッシュボード
    <% end %>

    <div class="pt-4 px-3 py-2 text-xs font-semibold text-gray-500 uppercase tracking-wider">
      コンテスト管理
    </div>

    <%= link_to organizers_contests_path, class: "group flex items-center px-3 py-2 text-sm font-medium rounded-md #{request.path.start_with?(organizers_contests_path) && !request.path.include?('/new') ? 'bg-indigo-50 text-indigo-600' : 'text-gray-700 hover:text-indigo-600 hover:bg-gray-50'}" do %>
      <svg class="mr-3 h-5 w-5 <%= request.path.start_with?(organizers_contests_path) && !request.path.include?('/new') ? 'text-indigo-600' : 'text-gray-400 group-hover:text-indigo-600' %>" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
      </svg>
      コンテスト一覧
    <% end %>

    <%= link_to new_organizers_contest_path, class: "group flex items-center px-3 py-2 text-sm font-medium rounded-md #{request.path == new_organizers_contest_path ? 'bg-indigo-50 text-indigo-600' : 'text-gray-700 hover:text-indigo-600 hover:bg-gray-50'}" do %>
      <svg class="mr-3 h-5 w-5 <%= request.path == new_organizers_contest_path ? 'text-indigo-600' : 'text-gray-400 group-hover:text-indigo-600' %>" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
      </svg>
      新規コンテスト作成
    <% end %>

    <%= link_to organizers_contest_templates_path, class: "group flex items-center px-3 py-2 text-sm font-medium rounded-md #{request.path.start_with?(organizers_contest_templates_path) ? 'bg-indigo-50 text-indigo-600' : 'text-gray-700 hover:text-indigo-600 hover:bg-gray-50'}" do %>
      <svg class="mr-3 h-5 w-5 <%= request.path.start_with?(organizers_contest_templates_path) ? 'text-indigo-600' : 'text-gray-400 group-hover:text-indigo-600' %>" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      テンプレート
    <% end %>

    <div class="pt-4 px-3 py-2 text-xs font-semibold text-gray-500 uppercase tracking-wider">
      写真管理
    </div>

    <a href="#" class="group flex items-center px-3 py-2 text-sm font-medium text-gray-400 rounded-md cursor-not-allowed">
      <svg class="mr-3 h-5 w-5 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
      投稿写真一覧
      <span class="ml-auto text-xs text-gray-400">準備中</span>
    </a>

    <a href="#" class="group flex items-center px-3 py-2 text-sm font-medium text-gray-400 rounded-md cursor-not-allowed">
      <svg class="mr-3 h-5 w-5 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      審査管理
      <span class="ml-auto text-xs text-gray-400">準備中</span>
    </a>

    <% if current_user.admin? %>
      <div class="pt-4 px-3 py-2 text-xs font-semibold text-gray-500 uppercase tracking-wider">
        管理者メニュー
      </div>

      <a href="#" class="group flex items-center px-3 py-2 text-sm font-medium text-gray-400 rounded-md cursor-not-allowed">
        <svg class="mr-3 h-5 w-5 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        ユーザー管理
        <span class="ml-auto text-xs text-gray-400">準備中</span>
      </a>

      <a href="#" class="group flex items-center px-3 py-2 text-sm font-medium text-gray-400 rounded-md cursor-not-allowed">
        <svg class="mr-3 h-5 w-5 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        システム設定
        <span class="ml-auto text-xs text-gray-400">準備中</span>
      </a>
    <% end %>
  </nav>
</aside>
