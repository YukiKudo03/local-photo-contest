<% share_data ||= {} %>
<% title = share_data[:title] || "Photo Contest" %>
<% text = share_data[:text] || title %>
<% url = share_data[:url] || request.original_url %>
<% hashtags = share_data[:hashtags] || [] %>

<div class="share-buttons" data-controller="share">
  <span class="text-xs font-medium text-gray-500 mr-2">共有:</span>

  <div class="inline-flex items-center gap-1">
    <!-- Twitter/X -->
    <a href="<%= twitter_share_url(text: text, url: url, hashtags: hashtags) %>"
       target="_blank"
       rel="noopener noreferrer"
       class="share-button share-twitter"
       title="Xで共有"
       data-action="click->share#trackShare"
       data-share-platform-param="twitter">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
      </svg>
    </a>

    <!-- Facebook -->
    <a href="<%= facebook_share_url(url: url) %>"
       target="_blank"
       rel="noopener noreferrer"
       class="share-button share-facebook"
       title="Facebookで共有"
       data-action="click->share#trackShare"
       data-share-platform-param="facebook">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
      </svg>
    </a>

    <!-- LINE -->
    <a href="<%= line_share_url(text: text, url: url) %>"
       target="_blank"
       rel="noopener noreferrer"
       class="share-button share-line"
       title="LINEで共有"
       data-action="click->share#trackShare"
       data-share-platform-param="line">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
        <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63h2.386c.349 0 .63.285.63.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63.349 0 .631.285.631.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/>
      </svg>
    </a>

    <!-- Copy Link -->
    <button type="button"
            class="share-button share-copy"
            title="リンクをコピー"
            data-action="click->share#copyLink"
            data-share-url-param="<%= url %>">
      <svg class="w-4 h-4 copy-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
      </svg>
      <svg class="w-4 h-4 check-icon hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
      </svg>
    </button>
  </div>
</div>

<style>
  .share-buttons {
    display: flex;
    align-items: center;
  }

  .share-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 6px;
    transition: all 0.15s ease;
  }

  .share-twitter {
    color: #1da1f2;
    background: #e8f5fd;
  }

  .share-twitter:hover {
    background: #1da1f2;
    color: white;
  }

  .share-facebook {
    color: #1877f2;
    background: #e7f0ff;
  }

  .share-facebook:hover {
    background: #1877f2;
    color: white;
  }

  .share-line {
    color: #00b900;
    background: #e6f9e6;
  }

  .share-line:hover {
    background: #00b900;
    color: white;
  }

  .share-copy {
    color: #6b7280;
    background: #f3f4f6;
    border: none;
    cursor: pointer;
  }

  .share-copy:hover {
    background: #e5e7eb;
    color: #374151;
  }

  .share-copy.copied {
    color: #10b981;
    background: #d1fae5;
  }
</style>
