<div class="container mx-auto max-w-4xl px-4 py-8">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900"><%= t('gamification.rankings.title') %></h1>
    <p class="mt-1 text-sm text-gray-500"><%= t('gamification.rankings.subtitle') %></p>
  </div>

  <% if @rankings.any? %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t('gamification.rankings.rank') %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t('gamification.rankings.user') %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t('gamification.rankings.level') %></th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t('gamification.rankings.points') %></th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @rankings.each_with_index do |ranked_user, index| %>
            <% rank = (@rankings.current_page - 1) * @rankings.limit_value + index + 1 %>
            <% is_current_user = user_signed_in? && ranked_user.id == current_user.id %>
            <tr class="<%= is_current_user ? 'bg-indigo-50 font-semibold' : 'hover:bg-gray-50' %>">
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                <% if rank <= 3 %>
                  <span class="inline-flex items-center justify-center w-8 h-8 rounded-full <%= rank == 1 ? 'bg-yellow-100 text-yellow-800' : rank == 2 ? 'bg-gray-100 text-gray-800' : 'bg-amber-100 text-amber-800' %> font-bold">
                    <%= rank %>
                  </span>
                <% else %>
                  <span class="ml-2"><%= rank %></span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center">
                  <div class="flex-shrink-0 h-8 w-8">
                    <% if ranked_user.avatar.attached? %>
                      <%= image_tag ranked_user.avatar.variant(resize_to_fill: [32, 32]), class: "h-8 w-8 rounded-full object-cover", loading: "lazy" %>
                    <% else %>
                      <div class="h-8 w-8 bg-indigo-100 rounded-full flex items-center justify-center">
                        <span class="text-sm font-bold text-indigo-600"><%= ranked_user.display_name.first.upcase %></span>
                      </div>
                    <% end %>
                  </div>
                  <div class="ml-3">
                    <p class="text-sm font-medium text-gray-900"><%= ranked_user.display_name %></p>
                  </div>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <%= render "shared/level_badge", level: ranked_user.level %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium text-gray-900">
                <%= number_with_delimiter(ranked_user.total_points) %> pt
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if @current_user_rank && !@rankings.map(&:id).include?(current_user.id) %>
      <div class="mt-4 p-4 bg-indigo-50 rounded-lg border border-indigo-100">
        <p class="text-sm text-indigo-700">
          <%= t('gamification.rankings.your_rank') %>: <strong>#<%= @current_user_rank %></strong>
          (<%= number_with_delimiter(current_user.total_points) %> pt)
        </p>
      </div>
    <% end %>

    <div class="mt-6">
      <%= paginate @rankings %>
    </div>
  <% else %>
    <div class="text-center py-12 bg-white rounded-xl shadow-sm border border-gray-100">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M18.75 4.236c.982.143 1.954.317 2.916.52A6.003 6.003 0 0016.27 9.728M18.75 4.236V4.5c0 2.108-.966 3.99-2.48 5.228m0 0a6.003 6.003 0 01-5.77 0" />
      </svg>
      <p class="mt-4 text-sm text-gray-500"><%= t('gamification.rankings.empty_state') %></p>
    </div>
  <% end %>
</div>
