<div class="container mx-auto max-w-4xl px-4 py-8">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900">
      <%= @period_type == :monthly ? t('gamification.season_rankings.monthly_title') : t('gamification.season_rankings.quarterly_title') %>
    </h1>
    <p class="mt-1 text-sm text-gray-500">
      <%= t('gamification.season_rankings.period_label') %>: <%= @summary[:period_label] %>
    </p>
  </div>

  <!-- Tab Navigation -->
  <div class="mb-6 border-b border-gray-200">
    <nav class="-mb-px flex space-x-8">
      <%= link_to t('gamification.season_rankings.tab_overall'), rankings_path, class: "border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm" %>
      <%= link_to t('gamification.season_rankings.tab_monthly'), monthly_rankings_path, class: "#{'border-indigo-500 text-indigo-600' if @period_type == :monthly} whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm" %>
      <%= link_to t('gamification.season_rankings.tab_quarterly'), quarterly_rankings_path, class: "#{'border-indigo-500 text-indigo-600' if @period_type == :quarterly} whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm" %>
    </nav>
  </div>

  <% if @rankings.any? %>
    <!-- Summary Stats -->
    <div class="grid grid-cols-2 gap-4 mb-6">
      <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-4 text-center">
        <div class="text-2xl font-bold text-indigo-600"><%= @summary[:total_participants] %></div>
        <div class="text-sm text-gray-500"><%= t('gamification.season_rankings.total_participants') %></div>
      </div>
      <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-4 text-center">
        <div class="text-2xl font-bold text-green-600"><%= number_with_delimiter(@summary[:total_points_awarded]) %></div>
        <div class="text-sm text-gray-500"><%= t('gamification.season_rankings.total_points') %></div>
      </div>
    </div>

    <!-- Rankings Table -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t('gamification.rankings.rank') %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t('gamification.rankings.user') %></th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t('gamification.rankings.points') %></th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @rankings.each do |entry| %>
            <% is_current_user = user_signed_in? && entry[:user].id == current_user.id %>
            <tr class="<%= is_current_user ? 'bg-indigo-50 font-semibold' : 'hover:bg-gray-50' %>">
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                <% if entry[:rank] <= 3 %>
                  <span class="inline-flex items-center justify-center w-8 h-8 rounded-full <%= entry[:rank] == 1 ? 'bg-yellow-100 text-yellow-800' : entry[:rank] == 2 ? 'bg-gray-100 text-gray-800' : 'bg-amber-100 text-amber-800' %> font-bold">
                    <%= entry[:rank] %>
                  </span>
                <% else %>
                  <span class="ml-2"><%= entry[:rank] %></span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center">
                  <div class="flex-shrink-0 h-8 w-8">
                    <% if entry[:user].avatar.attached? %>
                      <%= image_tag entry[:user].avatar.variant(resize_to_fill: [32, 32]), class: "h-8 w-8 rounded-full object-cover", loading: "lazy" %>
                    <% else %>
                      <div class="h-8 w-8 bg-indigo-100 rounded-full flex items-center justify-center">
                        <span class="text-sm font-bold text-indigo-600"><%= entry[:user].display_name.first.upcase %></span>
                      </div>
                    <% end %>
                  </div>
                  <div class="ml-3">
                    <p class="text-sm font-medium text-gray-900"><%= entry[:user].display_name %></p>
                  </div>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium text-gray-900">
                <%= number_with_delimiter(entry[:points]) %> pt
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <!-- Period Navigation -->
    <div class="mt-6 flex justify-between">
      <% if @period_type == :monthly %>
        <%= link_to t('gamification.season_rankings.previous_period'), monthly_rankings_path(year: (@date - 1.month).year, month: (@date - 1.month).month), class: "text-sm text-indigo-600 hover:text-indigo-800" %>
        <%= link_to t('gamification.season_rankings.next_period'), monthly_rankings_path(year: (@date + 1.month).year, month: (@date + 1.month).month), class: "text-sm text-indigo-600 hover:text-indigo-800" %>
      <% else %>
        <% prev_quarter_date = @date - 3.months %>
        <% next_quarter_date = @date + 3.months %>
        <% prev_q = ((prev_quarter_date.month - 1) / 3) + 1 %>
        <% next_q = ((next_quarter_date.month - 1) / 3) + 1 %>
        <%= link_to t('gamification.season_rankings.previous_period'), quarterly_rankings_path(year: prev_quarter_date.year, quarter: prev_q), class: "text-sm text-indigo-600 hover:text-indigo-800" %>
        <%= link_to t('gamification.season_rankings.next_period'), quarterly_rankings_path(year: next_quarter_date.year, quarter: next_q), class: "text-sm text-indigo-600 hover:text-indigo-800" %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12 bg-white rounded-xl shadow-sm border border-gray-100">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
      </svg>
      <p class="mt-4 text-sm text-gray-500"><%= t('gamification.season_rankings.empty_state') %></p>
    </div>
  <% end %>
</div>
