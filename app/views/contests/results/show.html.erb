<!-- Page Header -->
<div class="mb-8 text-center">
  <%= link_to contest_path(@contest), class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700 mb-4" do %>
    <svg class="mr-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
    </svg>
    コンテストに戻る
  <% end %>
  <h1 class="text-3xl font-bold text-gray-900"><%= @contest.title %></h1>
  <p class="mt-2 text-lg text-gray-600">コンテスト結果発表</p>
</div>

<!-- My Result (for logged in participants) -->
<% if @my_ranking %>
  <div class="mb-8 max-w-2xl mx-auto">
    <div class="bg-gradient-to-r from-indigo-500 to-purple-600 rounded-xl shadow-lg p-6 text-white">
      <h2 class="text-lg font-semibold mb-2">あなたの結果</h2>
      <div class="flex items-center justify-between">
        <div class="flex items-center">
          <div class="w-16 h-16 rounded-full flex items-center justify-center bg-white/20 text-3xl font-bold">
            <%= @my_ranking.rank %>
          </div>
          <div class="ml-4">
            <p class="text-xl font-semibold">
              <% if @my_ranking.prize? %>
                <%= rank_label(@my_ranking.rank) %>
              <% else %>
                <%= @my_ranking.rank %>位
              <% end %>
            </p>
            <p class="text-white/80">総合スコア: <%= number_with_precision(@my_ranking.total_score, precision: 2) %></p>
          </div>
        </div>
        <% if @my_ranking.prize? %>
          <%= render "shared/share_buttons", share_data: {
            url: contest_results_url(@contest),
            title: "#{@contest.title}で#{rank_label(@my_ranking.rank)}を受賞しました！",
            description: "フォトコンテスト「#{@contest.title}」で#{@my_ranking.rank}位を獲得しました。"
          } %>
        <% end %>
      </div>
      <% if @contest.show_detailed_scores && (@contest.judging_judge_only? || @contest.judging_hybrid?) %>
        <div class="mt-4 pt-4 border-t border-white/20">
          <p class="text-sm text-white/80">
            審査員スコア: <%= number_with_precision(@my_ranking.judge_score, precision: 2) %> |
            投票数: <%= @my_ranking.vote_count %>
          </p>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<!-- Top 3 Winners -->
<% if @prize_rankings.any? %>
  <div class="mb-12">
    <h2 class="text-2xl font-bold text-center text-gray-900 mb-8">入賞作品</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      <% @prize_rankings.limit(3).each do |ranking| %>
        <% entry = ranking.entry %>
        <div class="<%= ranking.rank == 1 ? 'md:col-span-3 md:max-w-2xl md:mx-auto' : '' %>">
          <div class="bg-white rounded-xl shadow-lg overflow-hidden border-2 <%=
            case ranking.rank
            when 1 then 'border-yellow-400'
            when 2 then 'border-gray-400'
            when 3 then 'border-amber-600'
            else 'border-transparent'
            end
          %>">
            <!-- Rank Badge -->
            <div class="relative">
              <div class="absolute top-4 left-4 z-10">
                <div class="w-12 h-12 rounded-full flex items-center justify-center shadow-lg <%=
                  case ranking.rank
                  when 1 then 'bg-yellow-400 text-yellow-900'
                  when 2 then 'bg-gray-300 text-gray-700'
                  when 3 then 'bg-amber-600 text-white'
                  else 'bg-gray-200 text-gray-600'
                  end
                %>">
                  <span class="text-lg font-bold"><%= ranking.rank %></span>
                </div>
              </div>

              <!-- Prize Label -->
              <div class="absolute top-4 right-4 z-10">
                <span class="px-3 py-1 rounded-full text-sm font-semibold <%=
                  case ranking.rank
                  when 1 then 'bg-yellow-100 text-yellow-800'
                  when 2 then 'bg-gray-100 text-gray-800'
                  when 3 then 'bg-amber-100 text-amber-800'
                  else 'bg-blue-100 text-blue-800'
                  end
                %>">
                  <%= rank_label(ranking.rank) %>
                </span>
              </div>

              <!-- Image -->
              <div class="aspect-[4/3] bg-gray-100">
                <% if entry.photo.attached? %>
                  <%= link_to entry_path(entry) do %>
                    <%= image_tag entry.photo, alt: entry.title.presence || "フォトコンテスト応募作品", class: "w-full h-full object-cover hover:opacity-90 transition-opacity" %>
                  <% end %>
                <% else %>
                  <div class="w-full h-full flex items-center justify-center">
                    <svg class="h-16 w-16 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                  </div>
                <% end %>
              </div>
            </div>

            <!-- Entry Info -->
            <div class="p-4">
              <h3 class="font-semibold text-gray-900 <%= ranking.rank == 1 ? 'text-xl' : 'text-lg' %>">
                <%= link_to entry.title.presence || "無題", entry_path(entry), class: "hover:text-indigo-600 transition-colors" %>
              </h3>
              <p class="text-sm text-gray-500 mt-1">by <%= entry.user.name.presence || entry.user.email %></p>
              <div class="flex items-center justify-between mt-3 text-sm text-gray-600">
                <div class="flex items-center">
                  <svg class="h-5 w-5 text-red-500 mr-1" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                  </svg>
                  <span class="font-medium"><%= ranking.vote_count %></span>
                  <span class="ml-1">票</span>
                </div>
                <span class="text-gray-400">スコア: <%= number_with_precision(ranking.total_score, precision: 1) %></span>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<!-- All Rankings -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden max-w-4xl mx-auto">
  <div class="px-6 py-4 border-b border-gray-100">
    <h2 class="text-lg font-semibold text-gray-900">全作品ランキング</h2>
  </div>

  <% if @all_rankings.any? %>
    <div class="divide-y divide-gray-100">
      <% @all_rankings.each do |ranking| %>
        <% entry = ranking.entry %>
        <div class="p-4 flex items-center hover:bg-gray-50 transition-colors <%= ranking.rank <= @contest.effective_prize_count ? 'bg-yellow-50' : '' %>">
          <!-- Rank -->
          <div class="w-12 text-center">
            <% if ranking.rank <= 3 %>
              <span class="inline-flex items-center justify-center w-8 h-8 rounded-full <%= rank_badge_class(ranking.rank) %>">
                <span class="font-bold"><%= ranking.rank %></span>
              </span>
            <% else %>
              <span class="text-gray-500 font-medium"><%= ranking.rank %></span>
            <% end %>
          </div>

          <!-- Thumbnail -->
          <div class="w-16 h-16 rounded-lg overflow-hidden bg-gray-100 flex-shrink-0 ml-2">
            <% if entry.photo.attached? %>
              <%= link_to entry_path(entry) do %>
                <%= image_tag entry.photo.variant(resize_to_fill: [64, 64]), alt: entry.title.presence || "フォトコンテスト応募作品", class: "w-full h-full object-cover" %>
              <% end %>
            <% else %>
              <div class="w-full h-full flex items-center justify-center">
                <svg class="h-6 w-6 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
            <% end %>
          </div>

          <!-- Entry Info -->
          <div class="flex-1 ml-4 min-w-0">
            <h3 class="font-medium text-gray-900 truncate">
              <%= link_to entry.title.presence || "無題", entry_path(entry), class: "hover:text-indigo-600 transition-colors" %>
              <% if ranking.prize? %>
                <span class="ml-2 px-2 py-0.5 text-xs rounded <%= rank_badge_class(ranking.rank) %>"><%= rank_label(ranking.rank) %></span>
              <% end %>
            </h3>
            <p class="text-sm text-gray-500">by <%= entry.user.name.presence || entry.user.email %></p>
          </div>

          <!-- Score -->
          <div class="flex items-center text-gray-600 ml-4 space-x-4">
            <% if @contest.judging_vote_only? || @contest.judging_hybrid? %>
              <div class="flex items-center">
                <svg class="h-5 w-5 text-red-500 mr-1" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                </svg>
                <span class="font-medium"><%= ranking.vote_count %></span>
              </div>
            <% end %>
            <span class="text-sm text-gray-400"><%= number_with_precision(ranking.total_score, precision: 1) %>pt</span>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="p-8 text-center">
      <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
      <p class="mt-4 text-gray-500">作品がありません</p>
    </div>
  <% end %>
</div>

<!-- Discovery Ranking -->
<div class="mt-8 max-w-4xl mx-auto">
  <%= render "contests/discovery_ranking", contest: @contest %>
</div>

<!-- Results Announcement Date -->
<div class="mt-8 text-center text-sm text-gray-500">
  結果発表日: <%= l(@contest.results_announced_at, format: :long) %>
</div>
