<!-- Page Header -->
<div class="mb-8 text-center">
  <%= link_to contest_path(@contest), class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700 mb-4" do %>
    <svg class="mr-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
    </svg>
    <%= t('results.show.back_to_contest') %>
  <% end %>
  <h1 class="text-3xl font-bold text-gray-900"><%= @contest.title %></h1>
  <p class="mt-2 text-lg text-gray-600"><%= t('results.show.subtitle') %></p>
</div>

<!-- My Result (for logged in participants) -->
<% if @my_ranking %>
  <div class="mb-8 max-w-2xl mx-auto">
    <div class="bg-gradient-to-r from-indigo-500 to-purple-600 rounded-xl shadow-lg p-6 text-white">
      <h2 class="text-lg font-semibold mb-2"><%= t('results.show.my_result') %></h2>
      <div class="flex items-center justify-between">
        <div class="flex items-center">
          <div class="w-16 h-16 rounded-full flex items-center justify-center bg-white/20 text-3xl font-bold">
            <%= @my_ranking.rank %>
          </div>
          <div class="ml-4">
            <p class="text-xl font-semibold">
              <% if @my_ranking.prize? %>
                <%= rank_label(@my_ranking.rank) %>
              <% else %>
                <%= t('results.show.rank_position', rank: @my_ranking.rank) %>
              <% end %>
            </p>
            <p class="text-white/80"><%= t('results.show.total_score', score: number_with_precision(@my_ranking.total_score, precision: 2)) %></p>
          </div>
        </div>
        <% if @my_ranking.prize? %>
          <%= render "shared/share_buttons", share_data: {
            url: contest_results_url(@contest),
            title: t('results.show.share_title', contest_title: @contest.title, rank_label: rank_label(@my_ranking.rank)),
            description: t('results.show.share_description', contest_title: @contest.title, rank: @my_ranking.rank)
          } %>
        <% end %>
      </div>
      <% if @contest.show_detailed_scores && (@contest.judging_judge_only? || @contest.judging_hybrid?) %>
        <div class="mt-4 pt-4 border-t border-white/20">
          <p class="text-sm text-white/80">
            <%= t('results.show.judge_score', score: number_with_precision(@my_ranking.judge_score, precision: 2)) %> |
            <%= t('results.show.vote_count', count: @my_ranking.vote_count) %>
          </p>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<!-- Top 3 Winners -->
<% if @prize_rankings.any? %>
  <div class="mb-12">
    <h2 class="text-2xl font-bold text-center text-gray-900 mb-8"><%= t('results.show.winners_title') %></h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      <% @prize_rankings.limit(3).each do |ranking| %>
        <% entry = ranking.entry %>
        <div class="<%= ranking.rank == 1 ? 'md:col-span-3 md:max-w-2xl md:mx-auto' : '' %>">
          <div class="bg-white rounded-xl shadow-lg overflow-hidden border-2 <%=
            case ranking.rank
            when 1 then 'border-yellow-400'
            when 2 then 'border-gray-400'
            when 3 then 'border-amber-600'
            else 'border-transparent'
            end
          %>">
            <!-- Rank Badge -->
            <div class="relative">
              <div class="absolute top-4 left-4 z-10">
                <div class="w-12 h-12 rounded-full flex items-center justify-center shadow-lg <%=
                  case ranking.rank
                  when 1 then 'bg-yellow-400 text-yellow-900'
                  when 2 then 'bg-gray-300 text-gray-700'
                  when 3 then 'bg-amber-600 text-white'
                  else 'bg-gray-200 text-gray-600'
                  end
                %>">
                  <span class="text-lg font-bold"><%= ranking.rank %></span>
                </div>
              </div>

              <!-- Prize Label -->
              <div class="absolute top-4 right-4 z-10">
                <span class="px-3 py-1 rounded-full text-sm font-semibold <%=
                  case ranking.rank
                  when 1 then 'bg-yellow-100 text-yellow-800'
                  when 2 then 'bg-gray-100 text-gray-800'
                  when 3 then 'bg-amber-100 text-amber-800'
                  else 'bg-blue-100 text-blue-800'
                  end
                %>">
                  <%= rank_label(ranking.rank) %>
                </span>
              </div>

              <!-- Image -->
              <div class="aspect-[4/3] bg-gray-100">
                <% if entry.photo.attached? %>
                  <%= link_to entry_path(entry) do %>
                    <%= image_tag entry.photo, alt: entry.title.presence || t('results.show.entry_image_alt'), class: "w-full h-full object-cover hover:opacity-90 transition-opacity", loading: "lazy" %>
                  <% end %>
                <% else %>
                  <div class="w-full h-full flex items-center justify-center">
                    <svg class="h-16 w-16 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                  </div>
                <% end %>
              </div>
            </div>

            <!-- Entry Info -->
            <div class="p-4">
              <h3 class="font-semibold text-gray-900 <%= ranking.rank == 1 ? 'text-xl' : 'text-lg' %>">
                <%= link_to entry.title.presence || t('results.show.untitled'), entry_path(entry), class: "hover:text-indigo-600 transition-colors" %>
              </h3>
              <p class="text-sm text-gray-500 mt-1">by <%= entry.user.name.presence || entry.user.email %></p>
              <div class="flex items-center justify-between mt-3 text-sm text-gray-600">
                <div class="flex items-center">
                  <svg class="h-5 w-5 text-red-500 mr-1" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                  </svg>
                  <span class="font-medium"><%= ranking.vote_count %></span>
                  <span class="ml-1"><%= t('results.show.votes') %></span>
                </div>
                <span class="text-gray-400"><%= t('results.show.score', score: number_with_precision(ranking.total_score, precision: 1)) %></span>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<!-- Slideshow -->
<% if @all_rankings.any? %>
  <div class="mb-8 text-center" data-controller="slideshow" data-slideshow-entries-value="<%= slideshow_entries_json(@all_rankings.map(&:entry)) %>" data-slideshow-interval-value="5000">
    <button data-action="slideshow#open" class="inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-indigo-600 rounded-lg hover:bg-indigo-700 transition-colors">
      <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <%= t('results.show.slideshow') %>
    </button>

    <!-- Slideshow Overlay -->
    <div data-slideshow-target="container" class="hidden fixed inset-0 z-50 bg-black/90 flex flex-col items-center justify-center" data-action="click->slideshow#backdropClick">
      <button data-action="slideshow#close" class="absolute top-4 right-4 text-white hover:text-gray-300 text-3xl">&times;</button>
      <div class="flex items-center justify-center flex-1 w-full px-4" onclick="event.stopPropagation()">
        <button data-action="slideshow#prev" class="text-white hover:text-gray-300 text-4xl px-4">&lsaquo;</button>
        <div class="flex flex-col items-center max-w-4xl">
          <img data-slideshow-target="image" src="" alt="" class="max-h-[70vh] max-w-full object-contain rounded-lg">
          <div class="mt-4 text-center">
            <h3 data-slideshow-target="title" class="text-xl font-semibold text-white"></h3>
            <p data-slideshow-target="author" class="text-sm text-gray-300 mt-1"></p>
          </div>
        </div>
        <button data-action="slideshow#next" class="text-white hover:text-gray-300 text-4xl px-4">&rsaquo;</button>
      </div>
      <div class="pb-6 flex items-center space-x-4">
        <span data-slideshow-target="counter" class="text-white text-sm"></span>
        <button data-slideshow-target="playButton" data-action="slideshow#togglePlay" class="text-white hover:text-gray-300 text-xl">&#9654;</button>
      </div>
    </div>
  </div>
<% end %>

<!-- Comparison Viewer -->
<% if @all_rankings.size >= 2 %>
  <div class="mb-8 max-w-5xl mx-auto" data-controller="comparison">
    <h2 class="text-xl font-bold text-gray-900 mb-4 text-center"><%= t('results.show.comparison.title') %></h2>

    <!-- Entry Thumbnails for Selection -->
    <div class="grid grid-cols-4 sm:grid-cols-6 md:grid-cols-8 gap-2 mb-4">
      <% @all_rankings.each do |ranking| %>
        <% entry = ranking.entry %>
        <% if entry.photo.attached? %>
          <button data-action="click->comparison#selectEntry"
                  data-entry-json="<%= comparison_entry_data(entry).to_json %>"
                  class="aspect-square rounded-lg overflow-hidden border-2 border-transparent hover:border-indigo-500 transition-colors focus:outline-none focus:ring-2 focus:ring-indigo-500">
            <%= image_tag entry.photo.variant(resize_to_fill: [100, 100]), alt: entry.title.presence || t('results.show.untitled'), class: "w-full h-full object-cover", loading: "lazy" %>
          </button>
        <% end %>
      <% end %>
    </div>

    <!-- Comparison Container -->
    <div class="relative bg-gray-100 rounded-xl overflow-hidden" style="min-height: 300px;">
      <div data-comparison-target="container" class="flex items-center justify-center h-full" style="min-height: 300px;">
        <div class="flex-1 flex flex-col items-center p-4">
          <img data-comparison-target="leftImage" src="" alt="" class="max-h-[400px] max-w-full object-contain rounded-lg hidden">
          <p data-comparison-target="leftTitle" class="mt-2 text-sm font-medium text-gray-700"></p>
          <p class="text-xs text-gray-500" data-comparison-target="leftPlaceholder"><%= t('results.show.comparison.select_left') %></p>
        </div>
        <div data-comparison-target="slider" class="hidden w-1 bg-indigo-600 cursor-col-resize self-stretch mx-2" data-action="mousedown->comparison#startDrag touchstart->comparison#startDrag"></div>
        <div class="flex-1 flex flex-col items-center p-4">
          <img data-comparison-target="rightImage" src="" alt="" class="max-h-[400px] max-w-full object-contain rounded-lg hidden">
          <p data-comparison-target="rightTitle" class="mt-2 text-sm font-medium text-gray-700"></p>
          <p class="text-xs text-gray-500" data-comparison-target="rightPlaceholder"><%= t('results.show.comparison.select_right') %></p>
        </div>
      </div>
    </div>

    <!-- Mode Toggle -->
    <div class="mt-4 flex justify-center space-x-2">
      <button data-action="comparison#setModeSideBySide" class="px-3 py-1 text-sm rounded-lg bg-indigo-100 text-indigo-700 hover:bg-indigo-200 transition-colors">
        <%= t('results.show.comparison.side_by_side') %>
      </button>
      <button data-action="comparison#setModeSlider" class="px-3 py-1 text-sm rounded-lg bg-gray-100 text-gray-700 hover:bg-gray-200 transition-colors">
        <%= t('results.show.comparison.slider') %>
      </button>
    </div>
  </div>
<% end %>

<!-- All Rankings -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden max-w-4xl mx-auto">
  <div class="px-6 py-4 border-b border-gray-100">
    <h2 class="text-lg font-semibold text-gray-900"><%= t('results.show.all_rankings') %></h2>
  </div>

  <% if @all_rankings.any? %>
    <div class="divide-y divide-gray-100">
      <% @all_rankings.each do |ranking| %>
        <% entry = ranking.entry %>
        <div class="p-4 flex items-center hover:bg-gray-50 transition-colors <%= ranking.rank <= @contest.effective_prize_count ? 'bg-yellow-50' : '' %>">
          <!-- Rank -->
          <div class="w-12 text-center">
            <% if ranking.rank <= 3 %>
              <span class="inline-flex items-center justify-center w-8 h-8 rounded-full <%= rank_badge_class(ranking.rank) %>">
                <span class="font-bold"><%= ranking.rank %></span>
              </span>
            <% else %>
              <span class="text-gray-500 font-medium"><%= ranking.rank %></span>
            <% end %>
          </div>

          <!-- Thumbnail -->
          <div class="w-16 h-16 rounded-lg overflow-hidden bg-gray-100 flex-shrink-0 ml-2">
            <% if entry.photo.attached? %>
              <%= link_to entry_path(entry) do %>
                <%= image_tag entry.photo.variant(resize_to_fill: [64, 64]), alt: entry.title.presence || t('results.show.entry_image_alt'), class: "w-full h-full object-cover", loading: "lazy" %>
              <% end %>
            <% else %>
              <div class="w-full h-full flex items-center justify-center">
                <svg class="h-6 w-6 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
            <% end %>
          </div>

          <!-- Entry Info -->
          <div class="flex-1 ml-4 min-w-0">
            <h3 class="font-medium text-gray-900 truncate">
              <%= link_to entry.title.presence || t('results.show.untitled'), entry_path(entry), class: "hover:text-indigo-600 transition-colors" %>
              <% if ranking.prize? %>
                <span class="ml-2 px-2 py-0.5 text-xs rounded <%= rank_badge_class(ranking.rank) %>"><%= rank_label(ranking.rank) %></span>
              <% end %>
            </h3>
            <p class="text-sm text-gray-500">by <%= entry.user.name.presence || entry.user.email %></p>
          </div>

          <!-- Score -->
          <div class="flex items-center text-gray-600 ml-4 space-x-4">
            <% if @contest.judging_vote_only? || @contest.judging_hybrid? %>
              <div class="flex items-center">
                <svg class="h-5 w-5 text-red-500 mr-1" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                </svg>
                <span class="font-medium"><%= ranking.vote_count %></span>
              </div>
            <% end %>
            <span class="text-sm text-gray-400"><%= number_with_precision(ranking.total_score, precision: 1) %>pt</span>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="p-8 text-center">
      <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
      <p class="mt-4 text-gray-500"><%= t('results.show.no_entries') %></p>
    </div>
  <% end %>
</div>

<!-- Discovery Ranking -->
<div class="mt-8 max-w-4xl mx-auto">
  <%= render "contests/discovery_ranking", contest: @contest %>
</div>

<!-- Results Announcement Date -->
<div class="mt-8 text-center text-sm text-gray-500">
  <%= t('results.show.announced_at', date: l(@contest.results_announced_at, format: :long)) %>
</div>
