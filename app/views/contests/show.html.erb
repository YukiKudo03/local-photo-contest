<div class="container mx-auto max-w-4xl px-4 py-8">
  <!-- Back Link -->
  <%= link_to contests_path, class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700 mb-4" do %>
    <svg class="mr-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
    </svg>
    コンテスト一覧に戻る
  <% end %>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <!-- Thumbnail -->
    <div class="aspect-video bg-gray-100 flex items-center justify-center">
      <% if @contest.thumbnail.attached? %>
        <%= image_tag @contest.thumbnail, class: "w-full h-full object-cover" %>
      <% else %>
        <div class="text-center">
          <svg class="mx-auto h-16 w-16 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
      <% end %>
    </div>

    <div class="p-6">
      <!-- Status Badge -->
      <div class="mb-4">
        <% if @contest.accepting_entries? %>
          <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
            <span class="flex h-2 w-2 relative mr-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
            </span>
            応募受付中
          </span>
        <% elsif @contest.finished? %>
          <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-gray-100 text-gray-800">
            終了
          </span>
        <% else %>
          <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-yellow-100 text-yellow-800">
            応募期間外
          </span>
        <% end %>
      </div>

      <!-- Title -->
      <h1 class="text-2xl font-bold text-gray-900"><%= @contest.title %></h1>

      <!-- Theme -->
      <% if @contest.theme.present? %>
        <p class="mt-2 text-lg text-indigo-600"><%= @contest.theme %></p>
      <% end %>

      <!-- Description -->
      <% if @contest.description.present? %>
        <div class="mt-6 prose prose-indigo max-w-none">
          <h3 class="text-lg font-semibold text-gray-900">コンテスト詳細</h3>
          <p class="text-gray-700 whitespace-pre-wrap"><%= @contest.description %></p>
        </div>
      <% end %>

      <!-- Entry Period -->
      <div class="mt-6 p-4 bg-gray-50 rounded-lg">
        <h3 class="text-sm font-semibold text-gray-900 mb-2">応募期間</h3>
        <div class="flex items-center text-gray-700">
          <svg class="mr-2 h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <% if @contest.entry_start_at.present? || @contest.entry_end_at.present? %>
            <span>
              <% if @contest.entry_start_at.present? %>
                <%= @contest.entry_start_at.strftime('%Y年%m月%d日 %H:%M') %>
              <% else %>
                開始日時なし
              <% end %>
              〜
              <% if @contest.entry_end_at.present? %>
                <%= @contest.entry_end_at.strftime('%Y年%m月%d日 %H:%M') %>
              <% else %>
                終了日時なし
              <% end %>
            </span>
          <% else %>
            <span>期間制限なし</span>
          <% end %>
        </div>
      </div>

      <!-- Area & Spots Map -->
      <% if @contest.area.present? || @contest.spots.any? %>
        <div class="mt-6 p-4 bg-teal-50 rounded-lg">
          <h3 class="text-sm font-semibold text-gray-900 mb-3 flex items-center">
            <svg class="mr-2 h-5 w-5 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            撮影エリア・スポット
          </h3>

          <% if @contest.area.present? %>
            <div class="mb-3">
              <p class="text-sm text-teal-800">
                <span class="font-medium"><%= @contest.area.name %></span>
                <% if @contest.area.full_address.present? %>
                  <span class="text-teal-600">（<%= @contest.area.full_address %>）</span>
                <% end %>
              </p>
            </div>
          <% end %>

          <% if @contest.spots.any? %>
            <div class="mb-3">
              <p class="text-sm text-teal-700">
                <span class="font-medium"><%= @contest.spots.count %></span> 件の撮影スポット
                <% if @contest.require_spot %>
                  <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-amber-100 text-amber-800">
                    スポット選択必須
                  </span>
                <% end %>
              </p>
            </div>
          <% end %>

          <%
            # Map center and data
            area = @contest.area
            spots = @contest.spots.with_coordinates
            has_map_data = (area&.latitude.present? && area&.longitude.present?) || spots.any?

            if has_map_data
              center_lat = area&.latitude || spots.first&.latitude || 35.6812
              center_lng = area&.longitude || spots.first&.longitude || 139.7671
              spots_data = spots.map { |s|
                {
                  lat: s.latitude&.to_f,
                  lng: s.longitude&.to_f,
                  popup: { title: s.name, subtitle: s.category_name },
                  icon: s.category.to_s
                }
              }
            end
          %>

          <% if has_map_data %>
            <div data-controller="map"
                 data-map-latitude-value="<%= center_lat %>"
                 data-map-longitude-value="<%= center_lng %>"
                 data-map-zoom-value="14"
                 data-map-interactive-value="true"
                 <% if area&.boundary_geojson.present? %>data-map-boundary-geojson-value="<%= area.boundary_geojson %>"<% end %>
                 <% if spots_data.any? %>data-map-markers-value="<%= spots_data.to_json %>"<% end %>>
              <div data-map-target="container" class="map-container rounded-lg"></div>
            </div>

            <% if @contest.spots.any? %>
              <div class="mt-3">
                <p class="text-xs text-teal-600 mb-2">撮影スポット一覧:</p>
                <div class="flex flex-wrap gap-2">
                  <% @contest.spots.ordered.each do |spot| %>
                    <span class="inline-flex items-center px-2 py-1 rounded text-xs bg-white border border-teal-200 text-teal-800">
                      <%= spot.name %>
                      <span class="ml-1 text-teal-500">(<%= spot.category_name %>)</span>
                    </span>
                  <% end %>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
      <% end %>

      <!-- Entry Button -->
      <div class="mt-8" data-tutorial="submit-button">
        <% if @contest.accepting_entries? %>
          <% if user_signed_in? %>
            <%= link_to new_contest_entry_path(@contest), class: "inline-flex items-center justify-center w-full sm:w-auto px-8 py-4 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-lg transition-colors shadow-lg hover:shadow-xl" do %>
              <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              このコンテストに応募する
            <% end %>
          <% else %>
            <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg">
              <p class="text-sm text-yellow-800">
                応募するにはログインが必要です。
                <%= link_to "ログイン", new_user_session_path, class: "font-semibold text-indigo-600 hover:text-indigo-700" %>
                または
                <%= link_to "新規登録", new_user_registration_path, class: "font-semibold text-indigo-600 hover:text-indigo-700" %>
                してください。
              </p>
            </div>
          <% end %>
        <% elsif @contest.finished? %>
          <% if @contest.results_announced? %>
            <div class="space-y-4">
              <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-center">
                <p class="text-yellow-800 font-medium">結果が発表されました！</p>
              </div>
              <%= link_to contest_results_path(@contest), class: "inline-flex items-center justify-center w-full sm:w-auto px-8 py-4 bg-yellow-500 hover:bg-yellow-600 text-white font-semibold rounded-lg transition-colors shadow-lg hover:shadow-xl" do %>
                <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
                </svg>
                結果を見る
              <% end %>
            </div>
          <% else %>
            <div class="p-4 bg-gray-100 rounded-lg text-center">
              <p class="text-gray-600">このコンテストは終了しました</p>
            </div>
          <% end %>
        <% else %>
          <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-center">
            <p class="text-yellow-800">現在応募期間外です</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Entries Gallery -->
  <% visible_entries = @contest.entries.visible %>
  <% if visible_entries.any? %>
    <div class="mt-8">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold text-gray-900">応募作品</h2>
        <span class="text-sm text-gray-500"><%= visible_entries.count %>作品</span>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        <% visible_entries.includes(:user, :votes, photo_attachment: :blob).recent.each do |entry| %>
          <%= link_to entry_path(entry), class: "block group" do %>
            <div class="bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow">
              <!-- Photo Thumbnail -->
              <div class="aspect-square bg-gray-100 relative">
                <% if entry.photo.attached? %>
                  <%= image_tag entry.photo.variant(resize_to_fill: [300, 300]), class: "w-full h-full object-cover" %>
                <% end %>

                <!-- Vote Count Overlay -->
                <div class="absolute bottom-2 right-2 bg-white/90 backdrop-blur-sm rounded-full px-2 py-1 flex items-center space-x-1">
                  <svg class="h-4 w-4 <%= entry.votes_count > 0 ? 'text-pink-500 fill-current' : 'text-gray-400' %>" viewBox="0 0 24 24" <%= entry.votes_count > 0 ? '' : 'fill="none" stroke="currentColor"' %>>
                    <path <%= entry.votes_count > 0 ? '' : 'stroke-linecap="round" stroke-linejoin="round" stroke-width="2"' %> d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                  </svg>
                  <span class="text-xs font-medium text-gray-700"><%= entry.votes_count %></span>
                </div>
              </div>

              <!-- Entry Info -->
              <div class="p-3">
                <% if entry.title.present? %>
                  <h3 class="text-sm font-medium text-gray-900 line-clamp-1 group-hover:text-indigo-600 transition-colors"><%= entry.title %></h3>
                <% else %>
                  <h3 class="text-sm font-medium text-gray-400 line-clamp-1">無題</h3>
                <% end %>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
