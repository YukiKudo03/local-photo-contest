<%# チュートリアル: 参加者オンボーディング %>
<% if user_signed_in? && current_user.participant? %>
  <%= render "tutorials/welcome_modal", tutorial_type: "participant_onboarding" if should_show_tutorial?("participant_onboarding") %>
  <%= render "tutorials/tutorial_container", tutorial_type: "participant_onboarding", auto_start: false %>
<% end %>

<div class="container mx-auto max-w-6xl px-4 py-8">
  <!-- Page Header -->
  <div class="mb-8 text-center">
    <h1 class="text-3xl font-bold text-gray-900">フォトコンテスト</h1>
    <p class="mt-2 text-gray-500">現在応募受付中のコンテストをご覧いただけます</p>
  </div>

  <!-- Contest Grid -->
  <% if @contests.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" data-tutorial="contests-list">
      <% @contests.each do |contest| %>
        <%= link_to contest_path(contest), class: "block bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow" do %>
          <!-- Thumbnail -->
          <div class="aspect-video bg-gray-100 flex items-center justify-center">
            <% if contest.thumbnail.attached? %>
              <%= image_tag contest.thumbnail, alt: contest.title, class: "w-full h-full object-cover" %>
            <% else %>
              <svg class="h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            <% end %>
          </div>

          <div class="p-4">
            <!-- Status Badge -->
            <div class="mb-2">
              <% if contest.accepting_entries? %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                  応募受付中
                </span>
              <% end %>
            </div>

            <!-- Title -->
            <h3 class="text-lg font-semibold text-gray-900 line-clamp-1"><%= contest.title %></h3>

            <!-- Theme -->
            <% if contest.theme.present? %>
              <p class="mt-1 text-sm text-gray-500 line-clamp-1"><%= contest.theme %></p>
            <% end %>

            <!-- Entry Period -->
            <div class="mt-3 text-xs text-gray-400">
              <% if contest.entry_start_at.present? || contest.entry_end_at.present? %>
                <span class="flex items-center">
                  <svg class="mr-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                  <% if contest.entry_end_at.present? %>
                    〜 <%= contest.entry_end_at.strftime('%Y/%m/%d') %>
                  <% else %>
                    期間制限なし
                  <% end %>
                </span>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <!-- Empty State -->
    <div class="text-center py-12 bg-white rounded-xl shadow-sm border border-gray-100">
      <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
      <h3 class="mt-4 text-lg font-medium text-gray-900">現在応募可能なコンテストはありません</h3>
      <p class="mt-2 text-sm text-gray-500">新しいコンテストが開催されるまでお待ちください</p>
    </div>
  <% end %>
</div>
