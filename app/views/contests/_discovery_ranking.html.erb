<%# Discovery Ranking Partial %>
<% discovery_ranking = DiscoverySpotService.discovery_ranking(contest, limit: 10) %>
<% if discovery_ranking.any? %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
      <h2 class="text-lg font-semibold text-gray-900">
        <svg class="inline-block w-5 h-5 mr-2 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        発掘ランキング
      </h2>
      <span class="text-sm text-gray-500">認定スポット数順</span>
    </div>

    <div class="divide-y divide-gray-100">
      <% discovery_ranking.each_with_index do |user, index| %>
        <div class="p-4 flex items-center hover:bg-gray-50 transition-colors">
          <!-- Rank -->
          <div class="w-12 text-center">
            <% if index < 3 %>
              <span class="inline-flex items-center justify-center w-8 h-8 rounded-full <%=
                case index
                when 0 then 'bg-yellow-100 text-yellow-800'
                when 1 then 'bg-gray-200 text-gray-700'
                when 2 then 'bg-amber-100 text-amber-800'
                end
              %>">
                <span class="font-bold"><%= index + 1 %></span>
              </span>
            <% else %>
              <span class="text-gray-500 font-medium"><%= index + 1 %></span>
            <% end %>
          </div>

          <!-- User Avatar -->
          <div class="w-10 h-10 rounded-full overflow-hidden bg-gray-100 flex-shrink-0 ml-2 flex items-center justify-center">
            <% if user.respond_to?(:avatar) && user.avatar.attached? %>
              <%= image_tag user.avatar.variant(resize_to_fill: [40, 40]), alt: "プロフィール画像", class: "w-full h-full object-cover", loading: "lazy" %>
            <% else %>
              <span class="text-gray-500 text-lg font-medium"><%= user.name&.first || user.email.first.upcase %></span>
            <% end %>
          </div>

          <!-- User Info -->
          <div class="flex-1 ml-4 min-w-0">
            <h3 class="font-medium text-gray-900 truncate">
              <%= user.name.presence || user.email.split('@').first %>
            </h3>
            <% badges = user.discovery_badges.where(contest: contest) %>
            <% if badges.any? %>
              <div class="flex items-center gap-1 mt-1">
                <% badges.each do |badge| %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%=
                    case badge.badge_type
                    when 'pioneer' then 'bg-blue-100 text-blue-800'
                    when 'explorer' then 'bg-green-100 text-green-800'
                    when 'curator' then 'bg-purple-100 text-purple-800'
                    when 'master' then 'bg-yellow-100 text-yellow-800'
                    end
                  %>">
                    <%= badge.badge_name %>
                  </span>
                <% end %>
              </div>
            <% end %>
          </div>

          <!-- Certified Count -->
          <div class="flex items-center text-gray-600 ml-4">
            <svg class="w-5 h-5 text-green-500 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="font-semibold"><%= user.certified_count %></span>
            <span class="ml-1 text-sm text-gray-500">スポット</span>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
