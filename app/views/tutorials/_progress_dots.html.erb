<%# steps: TutorialStep[], current_index: Integer %>
<% steps ||= [] %>
<% current_index ||= 0 %>

<% progress_state = ->(index, current) {
  if index < current
    'completed'
  elsif index == current
    'current'
  else
    'pending'
  end
} %>

<div class="tutorial-progress-dots" aria-label="<%= t('tutorials.progress_dots.label', current: current_index + 1, total: steps.count) %>">
  <% steps.each_with_index do |step, index| %>
    <span class="tutorial-dot tutorial-dot--<%= progress_state.call(index, current_index) %>"
          aria-hidden="true"></span>
  <% end %>
</div>
