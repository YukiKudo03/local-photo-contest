<%# ヘルプボタン（チュートリアル再開用） %>
<%# 使用例: <%= render 'tutorials/help_button', tutorial_type: 'contest_creation' %> %>

<% tutorial_type ||= nil %>

<% if current_user&.tutorial_enabled? && tutorial_type.present? %>
  <button type="button"
          data-controller="tutorial"
          data-tutorial-tutorial-type-value="<%= tutorial_type %>"
          data-action="tutorial#start"
          class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm text-indigo-600 hover:text-indigo-800 hover:bg-indigo-50 rounded-lg transition-colors"
          title="ヘルプを表示">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    <span>ヘルプ</span>
  </button>
<% end %>
