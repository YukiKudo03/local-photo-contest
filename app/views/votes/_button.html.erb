<div id="vote_button_<%= entry.id %>" class="flex items-center space-x-2">
  <% if user_signed_in? %>
    <% if entry.voted_by?(current_user) %>
      <%= button_to entry_vote_path(entry), method: :delete, class: "inline-flex items-center px-4 py-2 bg-pink-500 hover:bg-pink-600 text-white font-medium rounded-lg transition-colors", data: { turbo_frame: "_top" } do %>
        <svg class="h-5 w-5 mr-1 fill-current" viewBox="0 0 24 24">
          <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
        </svg>
        <%= t('votes.button.unvote') %>
      <% end %>
    <% elsif entry.owned_by?(current_user) %>
      <span class="inline-flex items-center px-4 py-2 bg-gray-200 text-gray-500 font-medium rounded-lg cursor-not-allowed">
        <svg class="h-5 w-5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
        </svg>
        <%= t('votes.button.cannot_vote_own') %>
      </span>
    <% elsif entry.contest.accepting_entries? %>
      <%= button_to entry_vote_path(entry), method: :post, class: "inline-flex items-center px-4 py-2 bg-gray-100 hover:bg-pink-100 text-gray-700 hover:text-pink-600 font-medium rounded-lg transition-colors border border-gray-200 hover:border-pink-300", data: { turbo_frame: "_top" } do %>
        <svg class="h-5 w-5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
        </svg>
        <%= t('votes.button.vote') %>
      <% end %>
    <% else %>
      <span class="inline-flex items-center px-4 py-2 bg-gray-100 text-gray-500 font-medium rounded-lg">
        <svg class="h-5 w-5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
        </svg>
        <%= t('votes.voting_closed') %>
      </span>
    <% end %>
  <% else %>
    <span class="inline-flex items-center px-4 py-2 bg-gray-100 text-gray-500 font-medium rounded-lg">
      <svg class="h-5 w-5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
      </svg>
      <%= link_to t('votes.button.login_required'), new_user_session_path, class: "hover:text-pink-600" %>
    </span>
  <% end %>
</div>
