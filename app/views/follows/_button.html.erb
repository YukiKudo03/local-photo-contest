<%= turbo_frame_tag "follow_button_#{user.id}" do %>
  <% if current_user && current_user != user %>
    <% if current_user.following?(user) %>
      <%= button_to user_follow_path(user), method: :delete, class: "inline-flex items-center px-4 py-2 border border-gray-300 text-gray-700 font-medium rounded-lg hover:bg-gray-100 transition-colors text-sm" do %>
        <svg class="mr-1.5 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        <%= t('social.follows.following') %>
      <% end %>
    <% else %>
      <%= button_to user_follow_path(user), method: :post, class: "inline-flex items-center px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg transition-colors text-sm" do %>
        <svg class="mr-1.5 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
        </svg>
        <%= t('social.follows.follow') %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
