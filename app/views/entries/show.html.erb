<% content_for :title, "#{@entry.title.presence || t('entries.show.untitled')} - #{@entry.contest.title}" %>

<div class="container mx-auto max-w-4xl px-4 py-8">
  <!-- Back Link -->
  <% if user_signed_in? && @entry.owned_by?(current_user) %>
    <%= link_to my_entries_path, class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700 mb-4" do %>
      <svg class="mr-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      <%= t('entries.show.back_to_my_entries') %>
    <% end %>
  <% else %>
    <%= link_to contest_path(@entry.contest), class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700 mb-4" do %>
      <svg class="mr-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      <%= t('entries.show.back_to_contest') %>
    <% end %>
  <% end %>

  <!-- Moderation Notice for Entry Owner -->
  <% if user_signed_in? && @entry.owned_by?(current_user) %>
    <% if @entry.moderation_hidden? %>
      <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded-lg">
        <div class="flex items-start">
          <svg class="h-5 w-5 text-red-600 mr-3 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
          <div>
            <h3 class="text-sm font-semibold text-red-800"><%= t('entries.show.hidden_notice') %></h3>
            <p class="mt-1 text-sm text-red-700">
              <%= t('entries.show.hidden_detail') %>
            </p>
          </div>
        </div>
      </div>
    <% elsif @entry.moderation_requires_review? %>
      <div class="mb-4 p-4 bg-orange-50 border border-orange-200 rounded-lg">
        <div class="flex items-start">
          <svg class="h-5 w-5 text-orange-600 mr-3 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <div>
            <h3 class="text-sm font-semibold text-orange-800"><%= t('entries.show.pending_notice') %></h3>
            <p class="mt-1 text-sm text-orange-700">
              <%= t('entries.show.pending_detail') %>
            </p>
          </div>
        </div>
      </div>
    <% elsif @entry.moderation_pending? && @entry.contest&.moderation_enabled? %>
      <div class="mb-4 p-4 bg-yellow-50 border border-yellow-200 rounded-lg">
        <div class="flex items-start">
          <svg class="h-5 w-5 text-yellow-600 mr-3 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <div>
            <h3 class="text-sm font-semibold text-yellow-800"><%= t('entries.show.auto_review_notice') %></h3>
            <p class="mt-1 text-sm text-yellow-700">
              <%= t('entries.show.auto_review_detail') %>
            </p>
          </div>
        </div>
      </div>
    <% end %>
  <% end %>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <!-- Photo -->
    <div class="bg-gray-100">
      <% if @entry.photo.attached? %>
        <%= responsive_entry_image(@entry, size: :large, class: "w-full max-h-[600px] object-contain") %>
      <% end %>
    </div>

    <div class="p-6">
      <!-- Contest Info -->
      <div class="mb-4 p-3 bg-indigo-50 rounded-lg">
        <p class="text-sm text-indigo-600">
          <%= link_to @entry.contest.title, contest_path(@entry.contest), class: "font-medium hover:underline" %>
          <%= t('entries.show.submitted_to') %>
        </p>
      </div>

      <!-- Title -->
      <% if @entry.title.present? %>
        <h1 class="text-2xl font-bold text-gray-900"><%= @entry.title %></h1>
      <% else %>
        <h1 class="text-2xl font-bold text-gray-400"><%= t('entries.show.untitled') %></h1>
      <% end %>

      <!-- Description -->
      <% if @entry.description.present? %>
        <div class="mt-4">
          <p class="text-gray-700 whitespace-pre-wrap"><%= @entry.description %></p>
        </div>
      <% end %>

      <!-- Photo Details -->
      <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <% if @entry.location.present? %>
          <div class="flex items-center text-gray-600">
            <svg class="mr-2 h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span><%= @entry.location %></span>
          </div>
        <% end %>

        <% if @entry.taken_at.present? %>
          <div class="flex items-center text-gray-600">
            <svg class="mr-2 h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span><%= l(@entry.taken_at, format: :default) %> <%= t('entries.show.taken_on') %></span>
          </div>
        <% end %>
      </div>

      <!-- Spot Info -->
      <% if @entry.spot.present? %>
        <div class="mt-6 p-4 bg-teal-50 rounded-lg">
          <div class="flex items-center">
            <svg class="h-5 w-5 text-teal-600 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-teal-800 font-medium"><%= @entry.spot.name %></span>
            <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-teal-100 text-teal-800">
              <%= @entry.spot.category_name %>
            </span>
          </div>
          <% if @entry.spot.address.present? %>
            <p class="mt-1 text-sm text-teal-700 ml-7"><%= @entry.spot.address %></p>
          <% end %>

          <% if @entry.spot.coordinates %>
            <div class="mt-3">
              <div data-controller="map"
                   data-map-latitude-value="<%= @entry.spot.latitude %>"
                   data-map-longitude-value="<%= @entry.spot.longitude %>"
                   data-map-zoom-value="15"
                   data-map-interactive-value="false">
                <div data-map-target="container" class="map-container h-32 rounded-lg"></div>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>

      <!-- Vote Section -->
      <div class="mt-6 pt-6 border-t border-gray-100" data-tutorial="vote-section">
        <div class="flex flex-wrap items-center justify-between gap-4">
          <div class="flex items-center space-x-4" data-tutorial="vote-button">
            <%= render "votes/button", entry: @entry %>
            <span class="text-sm text-gray-500">
              <% if @entry.votes_count > 0 %>
                <%= t('entries.show.votes_count', count: @entry.votes_count) %>
              <% else %>
                <%= t('entries.show.no_votes') %>
              <% end %>
            </span>
          </div>

          <!-- Share Buttons -->
          <%= render "shared/share_buttons", share_data: entry_share_data(@entry) %>
        </div>
      </div>

      <!-- Metadata -->
      <div class="mt-6 pt-6 border-t border-gray-100 text-sm text-gray-500">
        <p><%= t('entries.show.submitted_at') %> <%= l(@entry.created_at, format: :default) %></p>
      </div>

      <!-- Action Buttons -->
      <% if user_signed_in? && @entry.owned_by?(current_user) %>
        <div class="mt-6 flex items-center space-x-4">
          <% if @entry.editable? %>
            <%= link_to edit_entry_path(@entry), class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-lg text-gray-700 font-medium hover:bg-gray-50 transition-colors" do %>
              <svg class="mr-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
              </svg>
              <%= t('entries.show.edit') %>
            <% end %>
          <% end %>

          <% if @entry.deletable? %>
            <%= button_to entry_path(@entry), method: :delete, data: { turbo_confirm: t('entries.show.delete_confirm') }, class: "inline-flex items-center px-4 py-2 border border-red-300 rounded-lg text-red-700 font-medium hover:bg-red-50 transition-colors" do %>
              <svg class="mr-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
              </svg>
              <%= t('entries.show.delete') %>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Comments Section -->
  <div class="mt-8 bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100">
      <h2 class="text-lg font-semibold text-gray-900">
        <%= t('entries.show.comments_section') %>
        <span class="ml-2 text-sm font-normal text-gray-500">(<span id="comments_count"><%= @entry.comments.count %></span>)</span>
      </h2>
    </div>

    <div class="p-6">
      <!-- Comment Form -->
      <% if user_signed_in? %>
        <%= render "comments/form", entry: @entry, comment: nil %>
      <% else %>
        <div class="p-4 bg-gray-50 rounded-lg text-center">
          <p class="text-sm text-gray-600">
            <%= t('entries.show.login_to_comment') %>
          </p>
        </div>
      <% end %>

      <!-- Comments List -->
      <div id="comments" class="mt-6 divide-y divide-gray-100">
        <% @entry.comments.oldest.includes(:user).each do |comment| %>
          <%= render comment %>
        <% end %>
      </div>

      <% if @entry.comments.empty? %>
        <p class="mt-4 text-center text-sm text-gray-500"><%= t('entries.show.no_comments') %></p>
      <% end %>
    </div>
  </div>
</div>
