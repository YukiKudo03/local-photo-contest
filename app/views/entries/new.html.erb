<%# チュートリアル: 写真投稿 %>
<%= render "tutorials/tutorial_container", tutorial_type: "photo_submission", auto_start: should_show_tutorial?("photo_submission") if defined?(should_show_tutorial?) %>

<div class="container mx-auto max-w-2xl px-4 py-8">
  <!-- Back Link -->
  <%= link_to contest_path(@contest), class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700 mb-4" do %>
    <svg class="mr-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
    </svg>
    <%= t('entries.new.back_to_contest') %>
  <% end %>

  <!-- Page Header -->
  <div class="mb-8 flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900"><%= t('entries.new.title') %></h1>
      <p class="mt-1 text-gray-500"><%= @contest.title %></p>
    </div>
    <%= render "tutorials/help_button", tutorial_type: "photo_submission" %>
  </div>

  <%= render "form", contest: @contest, entry: @entry %>
</div>
