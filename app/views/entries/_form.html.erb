<%= form_with model: entry.persisted? ? entry : [contest, entry], class: "space-y-6" do |f| %>
  <% if entry.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <div class="flex">
        <svg class="h-5 w-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            <%= t('entries.form.errors_title') %>
          </h3>
          <ul class="mt-2 text-sm text-red-700 list-disc list-inside">
            <% entry.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden" data-tutorial="photo-upload">
    <div class="px-6 py-4 border-b border-gray-100">
      <h2 class="text-lg font-semibold text-gray-900"><%= t('entries.form.upload_photo') %></h2>
      <p class="mt-1 text-sm text-gray-500"><%= t('entries.form.upload_hint') %></p>
    </div>
    <div class="p-6">
      <% if entry.persisted? && entry.photo.attached? %>
        <div class="mb-4">
          <p class="text-sm text-gray-500 mb-2"><%= t('entries.form.current_photo') %></p>
          <%= image_tag entry.photo, alt: entry.title.presence || t('entries.form.entry_alt'), class: "max-w-md rounded-lg" %>
        </div>
      <% end %>

      <%= f.label :photo, class: "block cursor-pointer" do %>
        <div class="flex items-center justify-center w-full h-48 border-2 border-gray-300 border-dashed rounded-lg hover:bg-gray-50 transition-colors" id="drop-zone">
          <div class="text-center">
            <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
            </svg>
            <p class="mt-2 text-sm text-gray-500"><%= t('entries.form.click_to_select') %></p>
            <p class="text-xs text-gray-400"><%= t('entries.form.or_drag_drop') %></p>
          </div>
        </div>
        <%= f.file_field :photo, accept: "image/jpeg,image/png,image/gif", class: "hidden", required: !entry.persisted? %>
      <% end %>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden" data-tutorial="entry-info">
    <div class="px-6 py-4 border-b border-gray-100">
      <h2 class="text-lg font-semibold text-gray-900"><%= t('entries.form.work_info') %></h2>
      <p class="mt-1 text-sm text-gray-500"><%= t('entries.form.optional') %></p>
    </div>
    <div class="p-6 space-y-6">
      <!-- Title -->
      <div data-tutorial="entry-title">
        <%= f.label :title, t('entries.form.title_label'), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :title, placeholder: t('entries.form.title_placeholder'), class: "w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors" %>
        <p class="mt-1 text-xs text-gray-500"><%= t('entries.form.title_hint') %></p>
      </div>

      <!-- Description -->
      <div>
        <%= f.label :description, t('entries.form.description_label'), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_area :description, rows: 4, placeholder: t('entries.form.description_placeholder'), class: "w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors resize-none" %>
      </div>

      <!-- Location -->
      <div>
        <%= f.label :location, t('entries.form.location_label'), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :location, placeholder: t('entries.form.location_placeholder'), class: "w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors" %>
      </div>

      <!-- Area -->
      <% if @areas&.any? %>
        <div>
          <%= f.label :area_id, t('entries.form.area_label'), class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.select :area_id,
            options_for_select(
              [[t('entries.form.area_placeholder'), ""]] + @areas.map { |a| [a.name, a.id] },
              entry.area_id
            ),
            {},
            class: "w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors"
          %>
          <p class="mt-1 text-xs text-gray-500"><%= t('entries.form.area_hint') %></p>
        </div>
      <% end %>

      <!-- Spot Selection -->
      <%
        spots_json = (@spots || []).map { |s|
          {
            id: s.id,
            name: s.name,
            category_name: s.category_name,
            latitude: s.latitude&.to_f,
            longitude: s.longitude&.to_f
          }
        }
        area = contest.area
      %>
      <div data-controller="spot-picker" data-tutorial="spot-select"
           data-spot-picker-spots-value="<%= spots_json.to_json %>"
           <% if area&.latitude %>data-spot-picker-area-latitude-value="<%= area.latitude %>"<% end %>
           <% if area&.longitude %>data-spot-picker-area-longitude-value="<%= area.longitude %>"<% end %>
           <% if area&.boundary_geojson %>data-spot-picker-area-boundary-value="<%= area.boundary_geojson %>"<% end %>>

        <!-- New Spot Toggle -->
        <div class="mb-4">
          <label class="flex items-center gap-2 cursor-pointer">
            <%= f.check_box :discover_new_spot,
                { checked: entry.try(:discover_new_spot),
                  class: "h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500",
                  data: { spot_picker_target: "discoverCheckbox", action: "change->spot-picker#toggleDiscoverMode" } },
                "1", "0" %>
            <span class="text-sm font-medium text-gray-700"><%= t('entries.form.discover_new_spot') %></span>
          </label>
          <p class="mt-1 ml-6 text-xs text-gray-500"><%= t('entries.form.discover_hint') %></p>
        </div>

        <!-- Existing Spot Selection (shown when not discovering) -->
        <div data-spot-picker-target="existingSpotSection">
          <% if @spots&.any? %>
            <div>
              <%= f.label :spot_id, t('entries.form.spot_label'), class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.select :spot_id,
                options_for_select(
                  [[contest.require_spot ? t('entries.form.spot_placeholder_required') : t('entries.form.spot_placeholder_optional'), ""]] + @spots.map { |s| ["#{s.name}（#{s.category_name}）", s.id] },
                  entry.spot_id
                ),
                {},
                class: "w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors",
                data: { spot_picker_target: "select", action: "change->spot-picker#selectChanged" },
                required: contest.require_spot
              %>
              <% if contest.require_spot %>
                <p class="mt-1 text-xs text-amber-600"><%= t('entries.form.spot_required_hint') %></p>
              <% else %>
                <p class="mt-1 text-xs text-gray-500"><%= t('entries.form.spot_map_hint') %></p>
              <% end %>
            </div>
          <% end %>
        </div>

        <!-- New Spot Fields (shown when discovering) -->
        <div data-spot-picker-target="newSpotSection" class="hidden space-y-4">
          <div class="p-4 bg-amber-50 rounded-lg border border-amber-200">
            <div class="flex items-start">
              <svg class="h-5 w-5 text-amber-500 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div class="ml-3">
                <p class="text-sm text-amber-800">
                  <%= t('entries.form.discovery_spot_notice') %>
                </p>
              </div>
            </div>
          </div>

          <div>
            <%= f.label :new_spot_name, t('entries.form.spot_name_label'), class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_field :new_spot_name, placeholder: t('entries.form.spot_name_placeholder'), class: "w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors", data: { spot_picker_target: "newSpotName" } %>
            <p class="mt-1 text-xs text-gray-500"><%= t('entries.form.title_hint') %></p>
          </div>

          <div>
            <%= f.label :new_spot_category, t('entries.form.category_label'), class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.select :new_spot_category,
              options_for_select([
                [t('entries.form.category_other'), "other"],
                [t('entries.form.category_restaurant'), "restaurant"],
                [t('entries.form.category_retail'), "retail"],
                [t('entries.form.category_service'), "service"],
                [t('entries.form.category_landmark'), "landmark"],
                [t('entries.form.category_public'), "public_facility"],
                [t('entries.form.category_park'), "park"],
                [t('entries.form.category_temple'), "temple_shrine"]
              ], entry.try(:new_spot_category) || "other"),
              {},
              class: "w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors"
            %>
          </div>

          <div>
            <%= f.label :discovery_comment, t('entries.form.discovery_comment_label'), class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_area :discovery_comment, rows: 3, placeholder: t('entries.form.discovery_comment_placeholder'), class: "w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors resize-none" %>
          </div>

          <%= f.hidden_field :new_spot_latitude, data: { spot_picker_target: "newSpotLatitude" } %>
          <%= f.hidden_field :new_spot_longitude, data: { spot_picker_target: "newSpotLongitude" } %>
        </div>

        <!-- Spot Map -->
        <div class="mt-4" data-spot-picker-target="mapWrapper">
          <label class="block text-sm font-medium text-gray-700 mb-2">
            <span data-spot-picker-target="mapLabel"><%= t('entries.form.spot_location') %></span>
          </label>
          <div data-spot-picker-target="mapContainer" class="map-container map-container-sm rounded-lg"></div>
          <p class="mt-1 text-xs text-gray-500" data-spot-picker-target="mapHelp"><%= t('entries.form.spot_click_hint') %></p>
        </div>
      </div>

      <!-- Taken At -->
      <div>
        <%= f.label :taken_at, t('entries.form.taken_at_label'), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.date_field :taken_at, class: "w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors" %>
      </div>
    </div>
  </div>

  <!-- Form Actions -->
  <div class="flex items-center justify-end space-x-4" data-tutorial="entry-submit">
    <% if entry.persisted? %>
      <%= link_to t('entries.form.cancel'), entry_path(entry), class: "px-6 py-3 border border-gray-300 rounded-lg text-gray-700 font-medium hover:bg-gray-50 transition-colors" %>
    <% else %>
      <%= link_to t('entries.form.cancel'), contest_path(contest), class: "px-6 py-3 border border-gray-300 rounded-lg text-gray-700 font-medium hover:bg-gray-50 transition-colors" %>
    <% end %>
    <%= f.submit entry.persisted? ? t('entries.form.submit_update') : t('entries.form.submit_create'), class: "px-6 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg cursor-pointer transition-colors" %>
  </div>
<% end %>
