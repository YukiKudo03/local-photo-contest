<%= form_with model: entry.persisted? ? entry : [contest, entry], class: "space-y-6" do |f| %>
  <% if entry.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <div class="flex">
        <svg class="h-5 w-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            エラーがあります
          </h3>
          <ul class="mt-2 text-sm text-red-700 list-disc list-inside">
            <% entry.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden" data-tutorial="photo-upload">
    <div class="px-6 py-4 border-b border-gray-100">
      <h2 class="text-lg font-semibold text-gray-900">写真をアップロード</h2>
      <p class="mt-1 text-sm text-gray-500">JPEG、PNG、GIF形式（10MB以下）</p>
    </div>
    <div class="p-6">
      <% if entry.persisted? && entry.photo.attached? %>
        <div class="mb-4">
          <p class="text-sm text-gray-500 mb-2">現在の写真：</p>
          <%= image_tag entry.photo, class: "max-w-md rounded-lg" %>
        </div>
      <% end %>

      <%= f.label :photo, class: "block cursor-pointer" do %>
        <div class="flex items-center justify-center w-full h-48 border-2 border-gray-300 border-dashed rounded-lg hover:bg-gray-50 transition-colors" id="drop-zone">
          <div class="text-center">
            <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
            </svg>
            <p class="mt-2 text-sm text-gray-500">クリックして写真を選択</p>
            <p class="text-xs text-gray-400">またはドラッグ＆ドロップ</p>
          </div>
        </div>
        <%= f.file_field :photo, accept: "image/jpeg,image/png,image/gif", class: "hidden", required: !entry.persisted? %>
      <% end %>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden" data-tutorial="entry-info">
    <div class="px-6 py-4 border-b border-gray-100">
      <h2 class="text-lg font-semibold text-gray-900">作品情報</h2>
      <p class="mt-1 text-sm text-gray-500">任意入力</p>
    </div>
    <div class="p-6 space-y-6">
      <!-- Title -->
      <div data-tutorial="entry-title">
        <%= f.label :title, "タイトル", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :title, placeholder: "作品のタイトル（任意）", class: "w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors" %>
        <p class="mt-1 text-xs text-gray-500">100文字以内</p>
      </div>

      <!-- Description -->
      <div>
        <%= f.label :description, "説明", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_area :description, rows: 4, placeholder: "写真についての説明（任意）", class: "w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors resize-none" %>
      </div>

      <!-- Location -->
      <div>
        <%= f.label :location, "撮影場所", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :location, placeholder: "例：東京都渋谷区", class: "w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors" %>
      </div>

      <!-- Area -->
      <% if @areas&.any? %>
        <div>
          <%= f.label :area_id, "地域", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.select :area_id,
            options_for_select(
              [["地域を選択（任意）", ""]] + @areas.map { |a| [a.name, a.id] },
              entry.area_id
            ),
            {},
            class: "w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors"
          %>
          <p class="mt-1 text-xs text-gray-500">撮影した地域を選択してください</p>
        </div>
      <% end %>

      <!-- Spot Selection -->
      <%
        spots_json = (@spots || []).map { |s|
          {
            id: s.id,
            name: s.name,
            category_name: s.category_name,
            latitude: s.latitude&.to_f,
            longitude: s.longitude&.to_f
          }
        }
        area = contest.area
      %>
      <div data-controller="spot-picker" data-tutorial="spot-select"
           data-spot-picker-spots-value="<%= spots_json.to_json %>"
           <% if area&.latitude %>data-spot-picker-area-latitude-value="<%= area.latitude %>"<% end %>
           <% if area&.longitude %>data-spot-picker-area-longitude-value="<%= area.longitude %>"<% end %>
           <% if area&.boundary_geojson %>data-spot-picker-area-boundary-value="<%= area.boundary_geojson %>"<% end %>>

        <!-- New Spot Toggle -->
        <div class="mb-4">
          <label class="flex items-center gap-2 cursor-pointer">
            <%= f.check_box :discover_new_spot,
                { checked: entry.try(:discover_new_spot),
                  class: "h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500",
                  data: { spot_picker_target: "discoverCheckbox", action: "change->spot-picker#toggleDiscoverMode" } },
                "1", "0" %>
            <span class="text-sm font-medium text-gray-700">新しいスポットを発掘して登録する</span>
          </label>
          <p class="mt-1 ml-6 text-xs text-gray-500">まだ登録されていない隠れた名所を発掘して投稿できます</p>
        </div>

        <!-- Existing Spot Selection (shown when not discovering) -->
        <div data-spot-picker-target="existingSpotSection">
          <% if @spots&.any? %>
            <div>
              <%= f.label :spot_id, "撮影スポット", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.select :spot_id,
                options_for_select(
                  [["スポットを選択#{contest.require_spot ? '（必須）' : '（任意）'}", ""]] + @spots.map { |s| ["#{s.name}（#{s.category_name}）", s.id] },
                  entry.spot_id
                ),
                {},
                class: "w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors",
                data: { spot_picker_target: "select", action: "change->spot-picker#selectChanged" },
                required: contest.require_spot
              %>
              <% if contest.require_spot %>
                <p class="mt-1 text-xs text-amber-600">このコンテストではスポットの選択が必須です</p>
              <% else %>
                <p class="mt-1 text-xs text-gray-500">地図をクリックするか、ドロップダウンから選択してください</p>
              <% end %>
            </div>
          <% end %>
        </div>

        <!-- New Spot Fields (shown when discovering) -->
        <div data-spot-picker-target="newSpotSection" class="hidden space-y-4">
          <div class="p-4 bg-amber-50 rounded-lg border border-amber-200">
            <div class="flex items-start">
              <svg class="h-5 w-5 text-amber-500 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div class="ml-3">
                <p class="text-sm text-amber-800">
                  <strong>発掘スポット</strong>として登録すると、主催者の審査後に正式なスポットとして認定されます。
                </p>
              </div>
            </div>
          </div>

          <div>
            <%= f.label :new_spot_name, "スポット名", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_field :new_spot_name, placeholder: "発掘したスポットの名前", class: "w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors", data: { spot_picker_target: "newSpotName" } %>
            <p class="mt-1 text-xs text-gray-500">100文字以内</p>
          </div>

          <div>
            <%= f.label :new_spot_category, "カテゴリ", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.select :new_spot_category,
              options_for_select([
                ["その他", "other"],
                ["飲食店", "restaurant"],
                ["小売店", "retail"],
                ["サービス業", "service"],
                ["名所・ランドマーク", "landmark"],
                ["公共施設", "public_facility"],
                ["公園・広場", "park"],
                ["寺社仏閣", "temple_shrine"]
              ], entry.try(:new_spot_category) || "other"),
              {},
              class: "w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors"
            %>
          </div>

          <div>
            <%= f.label :discovery_comment, "発見コメント", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_area :discovery_comment, rows: 3, placeholder: "このスポットを発掘した理由や魅力を教えてください...", class: "w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors resize-none" %>
          </div>

          <%= f.hidden_field :new_spot_latitude, data: { spot_picker_target: "newSpotLatitude" } %>
          <%= f.hidden_field :new_spot_longitude, data: { spot_picker_target: "newSpotLongitude" } %>
        </div>

        <!-- Spot Map -->
        <div class="mt-4" data-spot-picker-target="mapWrapper">
          <label class="block text-sm font-medium text-gray-700 mb-2">
            <span data-spot-picker-target="mapLabel">スポット位置</span>
          </label>
          <div data-spot-picker-target="mapContainer" class="map-container map-container-sm rounded-lg"></div>
          <p class="mt-1 text-xs text-gray-500" data-spot-picker-target="mapHelp">マーカーをクリックしてスポットを選択できます</p>
        </div>
      </div>

      <!-- Taken At -->
      <div>
        <%= f.label :taken_at, "撮影日", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.date_field :taken_at, class: "w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors" %>
      </div>
    </div>
  </div>

  <!-- Form Actions -->
  <div class="flex items-center justify-end space-x-4" data-tutorial="entry-submit">
    <% if entry.persisted? %>
      <%= link_to "キャンセル", entry_path(entry), class: "px-6 py-3 border border-gray-300 rounded-lg text-gray-700 font-medium hover:bg-gray-50 transition-colors" %>
    <% else %>
      <%= link_to "キャンセル", contest_path(contest), class: "px-6 py-3 border border-gray-300 rounded-lg text-gray-700 font-medium hover:bg-gray-50 transition-colors" %>
    <% end %>
    <%= f.submit entry.persisted? ? "更新する" : "応募する", class: "px-6 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg cursor-pointer transition-colors" %>
  </div>
<% end %>
