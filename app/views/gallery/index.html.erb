<div class="container mx-auto max-w-7xl px-4 py-8">
  <!-- Page Header -->
  <div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div class="text-center sm:text-left">
      <h1 class="text-3xl font-bold text-gray-900">フォトギャラリー</h1>
      <p class="mt-2 text-gray-500">すべてのコンテスト作品をご覧いただけます</p>
    </div>
    <div class="flex justify-center sm:justify-end">
      <%= link_to map_gallery_index_path, class: "inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-indigo-600 rounded-lg hover:bg-indigo-700 transition-colors" do %>
        <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
        </svg>
        マップで見る
      <% end %>
    </div>
  </div>

  <!-- Filters -->
  <div class="mb-8 bg-white rounded-xl shadow-sm border border-gray-100 p-4">
    <%= form_with url: gallery_index_path, method: :get, data: { turbo_frame: "_top" }, class: "space-y-4" do |f| %>
      <div class="flex flex-wrap items-end gap-4">
        <!-- Contest Filter -->
        <div class="flex-1 min-w-[180px]">
          <label for="contest_id" class="block text-xs font-medium text-gray-500 mb-1">コンテスト</label>
          <%= select_tag :contest_id,
            options_for_select(
              [["すべて", ""]] + @contests.map { |c| [c.title, c.id] },
              params[:contest_id]
            ),
            class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm"
          %>
        </div>

        <!-- Category Filter -->
        <% if @categories.any? %>
          <div class="flex-1 min-w-[150px]">
            <label for="category_id" class="block text-xs font-medium text-gray-500 mb-1">カテゴリ</label>
            <%= select_tag :category_id,
              options_for_select(
                [["すべて", ""]] + @categories.map { |c| [c.name, c.id] },
                params[:category_id]
              ),
              class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm"
            %>
          </div>
        <% end %>

        <!-- Area Filter -->
        <% if @areas.any? %>
          <div class="flex-1 min-w-[150px]">
            <label for="area_id" class="block text-xs font-medium text-gray-500 mb-1">地域</label>
            <%= select_tag :area_id,
              options_for_select(
                [["すべて", ""]] + @areas.map { |a| [a.name, a.id] },
                params[:area_id]
              ),
              class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm"
            %>
          </div>
        <% end %>

        <!-- Sort -->
        <div class="flex-1 min-w-[130px]">
          <label for="sort" class="block text-xs font-medium text-gray-500 mb-1">並び順</label>
          <%= select_tag :sort,
            options_for_select(
              [
                ["新着順", "newest"],
                ["人気順", "popular"],
                ["古い順", "oldest"]
              ],
              params[:sort] || "newest"
            ),
            class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm"
          %>
        </div>

        <!-- Submit -->
        <div class="flex-shrink-0">
          <%= f.submit "絞り込む", class: "px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium rounded-lg transition-colors cursor-pointer" %>
        </div>

        <!-- Clear Filters -->
        <% if params[:contest_id].present? || params[:category_id].present? || params[:area_id].present? || params[:sort].present? %>
          <div class="flex-shrink-0">
            <%= link_to "クリア", gallery_index_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Results Count & Active Filters -->
  <div class="mb-4 flex flex-wrap items-center gap-2">
    <p class="text-sm text-gray-500"><%= @entries.total_count %>作品</p>

    <% if params[:contest_id].present? || params[:category_id].present? || params[:area_id].present? %>
      <span class="text-sm text-gray-400">|</span>
      <div class="flex flex-wrap items-center gap-2">
        <% if params[:category_id].present? %>
          <% category = @categories.find { |c| c.id.to_s == params[:category_id] } %>
          <% if category %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
              <%= category.name %>
            </span>
          <% end %>
        <% end %>

        <% if params[:area_id].present? %>
          <% area = @areas.find { |a| a.id.to_s == params[:area_id] } %>
          <% if area %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
              <%= area.name %>
            </span>
          <% end %>
        <% end %>

        <% if params[:contest_id].present? %>
          <% contest = @contests.find { |c| c.id.to_s == params[:contest_id] } %>
          <% if contest %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
              <%= contest.title %>
            </span>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Gallery Grid -->
  <% if @entries.any? %>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
      <% @entries.each do |entry| %>
        <%= link_to entry_path(entry), class: "block group" do %>
          <div class="bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden hover:shadow-lg transition-all hover:-translate-y-1">
            <!-- Photo -->
            <div class="aspect-square bg-gray-100 relative overflow-hidden">
              <% if entry.photo.attached? %>
                <%= image_tag entry.photo.variant(resize_to_fill: [300, 300]),
                  class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-300",
                  loading: "lazy"
                %>
              <% else %>
                <div class="w-full h-full flex items-center justify-center">
                  <svg class="h-8 w-8 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                </div>
              <% end %>

              <!-- Vote Count Badge -->
              <div class="absolute bottom-2 right-2 bg-white/90 backdrop-blur-sm rounded-full px-2 py-1 flex items-center space-x-1 shadow-sm">
                <svg class="h-3.5 w-3.5 <%= entry.votes_count > 0 ? 'text-pink-500 fill-current' : 'text-gray-400' %>" viewBox="0 0 24 24" <%= entry.votes_count > 0 ? '' : 'fill="none" stroke="currentColor"' %>>
                  <path <%= entry.votes_count > 0 ? '' : 'stroke-linecap="round" stroke-linejoin="round" stroke-width="2"' %> d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                </svg>
                <span class="text-xs font-medium text-gray-700"><%= entry.votes_count %></span>
              </div>
            </div>

            <!-- Entry Info -->
            <div class="p-2">
              <h3 class="text-xs font-medium text-gray-900 line-clamp-1 group-hover:text-indigo-600 transition-colors">
                <%= entry.title.presence || "無題" %>
              </h3>
              <div class="flex items-center gap-1 mt-0.5">
                <p class="text-xs text-gray-400 line-clamp-1 flex-1">
                  <%= entry.contest.title %>
                </p>
                <% if entry.area.present? %>
                  <span class="flex-shrink-0 inline-block px-1 py-0.5 text-[10px] font-medium bg-green-50 text-green-700 rounded">
                    <%= entry.area.name %>
                  </span>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>

    <!-- Pagination -->
    <div class="mt-8">
      <%= paginate @entries, theme: 'tailwind' %>
    </div>
  <% else %>
    <!-- Empty State -->
    <div class="text-center py-16 bg-white rounded-xl shadow-sm border border-gray-100">
      <svg class="mx-auto h-16 w-16 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
      <h3 class="mt-4 text-lg font-medium text-gray-900">作品がありません</h3>
      <p class="mt-2 text-sm text-gray-500">
        <% if params[:contest_id].present? %>
          このコンテストにはまだ応募作品がありません
        <% else %>
          まだ応募作品がありません
        <% end %>
      </p>
      <div class="mt-6">
        <%= link_to contests_path, class: "inline-flex items-center px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium rounded-lg transition-colors" do %>
          コンテスト一覧を見る
        <% end %>
      </div>
    </div>
  <% end %>
</div>
