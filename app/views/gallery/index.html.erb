<%# チュートリアル: 投票 %>
<%= render "tutorials/tutorial_container", tutorial_type: "voting", auto_start: should_show_tutorial?("voting") if defined?(should_show_tutorial?) %>

<div class="container mx-auto max-w-7xl px-4 py-8" data-controller="slideshow" data-slideshow-entries-value="[]" data-slideshow-interval-value="5000">
  <!-- Page Header -->
  <div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div class="text-center sm:text-left">
      <h1 class="text-3xl font-bold text-gray-900"><%= t('gallery.index.title') %></h1>
      <p class="mt-2 text-gray-500"><%= t('gallery.index.subtitle') %></p>
    </div>
    <div class="flex justify-center sm:justify-end gap-2">
      <button id="gallery-slideshow-btn" data-action="slideshow#open" class="inline-flex items-center px-4 py-2 text-sm font-medium text-indigo-600 bg-white border border-indigo-600 rounded-lg hover:bg-indigo-50 transition-colors">
        <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <%= t('gallery.index.slideshow') %>
      </button>
      <%= link_to map_gallery_index_path, class: "inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-indigo-600 rounded-lg hover:bg-indigo-700 transition-colors" do %>
        <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
        </svg>
        <%= t('gallery.index.view_on_map') %>
      <% end %>
    </div>
  </div>

  <!-- Filters -->
  <div class="mb-8 bg-white rounded-xl shadow-sm border border-gray-100 p-4">
    <%= form_with url: gallery_index_path, method: :get, data: { turbo_frame: "_top" }, class: "space-y-4" do |f| %>
      <div class="flex flex-wrap items-end gap-4">
        <!-- Text Search -->
        <div class="flex-1 min-w-[200px]">
          <label for="q" class="block text-xs font-medium text-gray-500 mb-1"><%= t('gallery.index.keyword') %></label>
          <input type="text" name="q" id="q" value="<%= params[:q] %>"
                 placeholder="<%= t('gallery.index.keyword_placeholder') %>"
                 class="block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm">
        </div>

        <!-- Contest Filter -->
        <div class="flex-1 min-w-[180px]">
          <label for="contest_id" class="block text-xs font-medium text-gray-500 mb-1"><%= t('gallery.index.contest_filter') %></label>
          <%= select_tag :contest_id,
            options_for_select(
              [[t('gallery.index.all'), ""]] + @contests.map { |c| [c.title, c.id] },
              params[:contest_id]
            ),
            class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm"
          %>
        </div>

        <!-- Category Filter -->
        <% if @categories.any? %>
          <div class="flex-1 min-w-[150px]">
            <label for="category_id" class="block text-xs font-medium text-gray-500 mb-1"><%= t('gallery.index.category_filter') %></label>
            <%= select_tag :category_id,
              options_for_select(
                [[t('gallery.index.all'), ""]] + @categories.map { |c| [c.name, c.id] },
                params[:category_id]
              ),
              class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm"
            %>
          </div>
        <% end %>

        <!-- Area Filter -->
        <% if @areas.any? %>
          <div class="flex-1 min-w-[150px]">
            <label for="area_id" class="block text-xs font-medium text-gray-500 mb-1"><%= t('gallery.index.area_filter') %></label>
            <%= select_tag :area_id,
              options_for_select(
                [[t('gallery.index.all'), ""]] + @areas.map { |a| [a.name, a.id] },
                params[:area_id]
              ),
              class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm"
            %>
          </div>
        <% end %>

        <!-- Camera Make Filter -->
        <% if @camera_makes&.any? %>
          <div class="flex-1 min-w-[150px]">
            <label for="camera_make" class="block text-xs font-medium text-gray-500 mb-1"><%= t('gallery.index.camera_filter') %></label>
            <%= select_tag :camera_make,
              options_for_select(
                [[t('gallery.index.all'), ""]] + @camera_makes.map { |m| [m, m] },
                params[:camera_make]
              ),
              class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm"
            %>
          </div>
        <% end %>

        <!-- Tag Filter -->
        <% if @tags&.any? %>
          <div class="flex-1 min-w-[150px]">
            <label for="tag_id" class="block text-xs font-medium text-gray-500 mb-1"><%= t('gallery.index.tag_filter') %></label>
            <%= select_tag :tag_id,
              options_for_select(
                [[t('gallery.index.all'), ""]] + @tags.map { |t| [t.name, t.id] },
                params[:tag_id]
              ),
              class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm"
            %>
          </div>
        <% end %>

        <!-- Sort -->
        <div class="flex-1 min-w-[130px]">
          <label for="sort" class="block text-xs font-medium text-gray-500 mb-1"><%= t('gallery.index.sort_label') %></label>
          <%= select_tag :sort,
            options_for_select(
              [
                [t('gallery.index.sort_newest'), "newest"],
                [t('gallery.index.sort_popular'), "popular"],
                [t('gallery.index.sort_quality'), "quality"],
                [t('gallery.index.sort_oldest'), "oldest"]
              ],
              params[:sort] || "newest"
            ),
            class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm"
          %>
        </div>

        <!-- Submit -->
        <div class="flex-shrink-0">
          <%= f.submit t('gallery.index.submit_filter'), class: "px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium rounded-lg transition-colors cursor-pointer" %>
        </div>

        <!-- Clear Filters -->
        <% if params[:q].present? || params[:contest_id].present? || params[:category_id].present? || params[:area_id].present? || params[:camera_make].present? || params[:tag_id].present? || params[:sort].present? %>
          <div class="flex-shrink-0">
            <%= link_to t('gallery.index.clear_filter'), gallery_index_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Results Count & Active Filters -->
  <div class="mb-4 flex flex-wrap items-center gap-2">
    <p class="text-sm text-gray-500"><%= t('gallery.index.works_count', count: @entries.total_count) %></p>

    <% if params[:contest_id].present? || params[:category_id].present? || params[:area_id].present? || params[:camera_make].present? || params[:tag_id].present? %>
      <span class="text-sm text-gray-400">|</span>
      <div class="flex flex-wrap items-center gap-2">
        <% if params[:category_id].present? %>
          <% category = @categories.find { |c| c.id.to_s == params[:category_id] } %>
          <% if category %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
              <%= category.name %>
            </span>
          <% end %>
        <% end %>

        <% if params[:area_id].present? %>
          <% area = @areas.find { |a| a.id.to_s == params[:area_id] } %>
          <% if area %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
              <%= area.name %>
            </span>
          <% end %>
        <% end %>

        <% if params[:contest_id].present? %>
          <% contest = @contests.find { |c| c.id.to_s == params[:contest_id] } %>
          <% if contest %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
              <%= contest.title %>
            </span>
          <% end %>
        <% end %>

        <% if params[:camera_make].present? %>
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-orange-100 text-orange-800">
            <%= params[:camera_make] %>
          </span>
        <% end %>

        <% if params[:tag_id].present? %>
          <% tag = @tags&.find { |t| t.id.to_s == params[:tag_id] } %>
          <% if tag %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-cyan-100 text-cyan-800">
              <%= tag.name %>
            </span>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Gallery Grid -->
  <% if @entries.any? %>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4" data-tutorial="gallery-grid">
      <%= render "gallery/entries" %>
    </div>
  <% else %>
    <!-- Empty State -->
    <div class="text-center py-16 bg-white rounded-xl shadow-sm border border-gray-100">
      <svg class="mx-auto h-16 w-16 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
      <h3 class="mt-4 text-lg font-medium text-gray-900"><%= t('gallery.index.empty.title') %></h3>
      <p class="mt-2 text-sm text-gray-500">
        <% if params[:contest_id].present? %>
          <%= t('gallery.index.empty.no_entries_for_contest') %>
        <% else %>
          <%= t('gallery.index.empty.no_entries') %>
        <% end %>
      </p>
      <div class="mt-6">
        <%= link_to contests_path, class: "inline-flex items-center px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium rounded-lg transition-colors" do %>
          <%= t('gallery.index.empty.browse_contests') %>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Slideshow Overlay -->
  <div data-slideshow-target="container" class="hidden fixed inset-0 z-50 bg-black/90 flex flex-col items-center justify-center" data-action="click->slideshow#backdropClick">
    <button data-action="slideshow#close" class="absolute top-4 right-4 text-white hover:text-gray-300 text-3xl">&times;</button>
    <div class="flex items-center justify-center flex-1 w-full px-4" onclick="event.stopPropagation()">
      <button data-action="slideshow#prev" class="text-white hover:text-gray-300 text-4xl px-4">&lsaquo;</button>
      <div class="flex flex-col items-center max-w-4xl">
        <img data-slideshow-target="image" src="" alt="" class="max-h-[70vh] max-w-full object-contain rounded-lg">
        <div class="mt-4 text-center">
          <h3 data-slideshow-target="title" class="text-xl font-semibold text-white"></h3>
          <p data-slideshow-target="author" class="text-sm text-gray-300 mt-1"></p>
        </div>
      </div>
      <button data-action="slideshow#next" class="text-white hover:text-gray-300 text-4xl px-4">&rsaquo;</button>
    </div>
    <div class="pb-6 flex items-center space-x-4">
      <span data-slideshow-target="counter" class="text-white text-sm"></span>
      <button data-slideshow-target="playButton" data-action="slideshow#togglePlay" class="text-white hover:text-gray-300 text-xl">&#9654;</button>
    </div>
  </div>
</div>
