<% content_for :title, "マップギャラリー" %>

<style>
  /* Map Container */
  .map-gallery-container {
    display: flex;
    height: calc(100vh - 64px);
  }

  .map-container {
    flex: 1;
    min-height: 400px;
  }

  /* Custom Marker Styles */
  .custom-marker {
    background: transparent;
    border: none;
  }

  .marker-pin {
    position: relative;
    width: 50px;
    height: 60px;
  }

  .marker-pin::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 0;
    border-left: 10px solid transparent;
    border-right: 10px solid transparent;
    border-top: 12px solid #4f46e5;
  }

  .marker-photo {
    width: 46px;
    height: 46px;
    border-radius: 8px;
    object-fit: cover;
    border: 3px solid #4f46e5;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
  }

  .marker-placeholder {
    width: 46px;
    height: 46px;
    border-radius: 8px;
    background: #e5e7eb;
    border: 3px solid #4f46e5;
  }

  /* Discovery Status Marker Colors */
  .marker-pin.discovery-certified::after {
    border-top-color: #10b981; /* green */
  }

  .marker-pin.discovery-certified .marker-photo,
  .marker-pin.discovery-certified .marker-placeholder {
    border-color: #10b981;
  }

  .marker-pin.discovery-discovered::after {
    border-top-color: #f59e0b; /* amber */
  }

  .marker-pin.discovery-discovered .marker-photo,
  .marker-pin.discovery-discovered .marker-placeholder {
    border-color: #f59e0b;
  }

  .marker-pin.discovery-mine::after {
    border-top-color: #3b82f6; /* blue */
  }

  .marker-pin.discovery-mine .marker-photo,
  .marker-pin.discovery-mine .marker-placeholder {
    border-color: #3b82f6;
  }

  .marker-pin.discovery-organizer::after {
    border-top-color: #4f46e5; /* indigo - default */
  }

  .marker-pin.discovery-organizer .marker-photo,
  .marker-pin.discovery-organizer .marker-placeholder {
    border-color: #4f46e5;
  }

  .marker-count {
    position: absolute;
    top: -8px;
    right: -8px;
    background: #ef4444;
    color: white;
    font-size: 11px;
    font-weight: 600;
    min-width: 20px;
    height: 20px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 4px;
  }

  /* Cluster Styles */
  .marker-cluster {
    background: rgba(79, 70, 229, 0.6);
    border-radius: 50%;
  }

  .marker-cluster div {
    width: 30px;
    height: 30px;
    margin: 5px;
    background: #4f46e5;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .marker-cluster span {
    color: white;
    font-size: 12px;
    font-weight: 600;
  }

  .marker-cluster-small {
    width: 40px;
    height: 40px;
  }

  .marker-cluster-medium {
    width: 50px;
    height: 50px;
  }

  .marker-cluster-large {
    width: 60px;
    height: 60px;
  }

  /* Popup Styles */
  .map-popup {
    min-width: 200px;
  }

  .popup-title {
    font-size: 14px;
    font-weight: 600;
    color: #1f2937;
    margin: 0 0 4px 0;
  }

  .popup-count {
    font-size: 12px;
    color: #6b7280;
    margin: 0 0 8px 0;
  }

  .popup-image-link {
    display: block;
    margin-bottom: 8px;
  }

  .popup-image {
    width: 100%;
    height: 120px;
    object-fit: cover;
    border-radius: 6px;
  }

  .popup-entry-title {
    font-size: 13px;
    color: #374151;
    margin: 0 0 8px 0;
  }

  .popup-link {
    display: inline-block;
    font-size: 12px;
    color: #4f46e5;
    text-decoration: none;
  }

  .popup-link:hover {
    text-decoration: underline;
  }

  /* Spot Panel */
  .spot-panel {
    position: absolute;
    top: 0;
    right: 0;
    width: 320px;
    height: 100%;
    background: white;
    box-shadow: -2px 0 8px rgba(0,0,0,0.1);
    transform: translateX(100%);
    transition: transform 0.3s ease;
    overflow-y: auto;
    z-index: 1000;
  }

  .spot-panel.active {
    transform: translateX(0);
  }

  .spot-panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px;
    border-bottom: 1px solid #e5e7eb;
    position: sticky;
    top: 0;
    background: white;
  }

  .spot-panel-header h3 {
    font-size: 16px;
    font-weight: 600;
    color: #1f2937;
    margin: 0;
  }

  .spot-panel-header .close-btn {
    background: none;
    border: none;
    font-size: 24px;
    color: #9ca3af;
    cursor: pointer;
    padding: 0;
    line-height: 1;
  }

  .spot-panel-header .close-btn:hover {
    color: #4b5563;
  }

  .spot-panel-count {
    padding: 8px 16px;
    font-size: 13px;
    color: #6b7280;
    margin: 0;
    background: #f9fafb;
  }

  .spot-panel-entries {
    padding: 8px;
  }

  .spot-entry {
    display: flex;
    gap: 12px;
    padding: 12px;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.15s;
  }

  .spot-entry:hover {
    background: #f3f4f6;
  }

  .spot-entry-photo {
    width: 64px;
    height: 64px;
    border-radius: 6px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .spot-entry-placeholder {
    width: 64px;
    height: 64px;
    border-radius: 6px;
    background: #e5e7eb;
    flex-shrink: 0;
  }

  .spot-entry-info {
    flex: 1;
    min-width: 0;
  }

  .spot-entry-title {
    font-size: 13px;
    font-weight: 500;
    color: #1f2937;
    margin: 0 0 4px 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .spot-entry-meta {
    font-size: 11px;
    color: #6b7280;
    margin: 0 0 4px 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .spot-entry-votes {
    font-size: 11px;
    color: #ec4899;
    margin: 0;
  }

  /* Sidebar */
  .map-sidebar {
    width: 300px;
    background: white;
    border-left: 1px solid #e5e7eb;
    overflow-y: auto;
    padding: 16px;
  }

  @media (max-width: 768px) {
    .map-gallery-container {
      flex-direction: column;
      height: auto;
    }

    .map-container {
      height: 60vh;
    }

    .map-sidebar {
      width: 100%;
      border-left: none;
      border-top: 1px solid #e5e7eb;
    }

    .spot-panel {
      width: 100%;
      height: 60%;
      top: auto;
      bottom: 0;
      transform: translateY(100%);
    }

    .spot-panel.active {
      transform: translateY(0);
    }
  }
</style>

<div class="container mx-auto max-w-7xl px-4 py-4">
  <!-- Page Header -->
  <div class="mb-4 flex flex-wrap items-center justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">マップギャラリー</h1>
      <p class="text-sm text-gray-500">地図上で作品を探索できます</p>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to gallery_index_path, class: "inline-flex items-center px-3 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50" do %>
        <svg class="w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
        </svg>
        グリッド表示
      <% end %>
    </div>
  </div>
</div>

<div class="map-gallery-container"
     data-controller="gallery-map"
     data-gallery-map-data-url-value="<%= map_data_gallery_index_path %>"
     data-gallery-map-contest-id-value="<%= params[:contest_id] %>"
     data-gallery-map-area-id-value="<%= params[:area_id] %>"
     data-gallery-map-discovery-status-value="<%= params[:discovery_status] %>"
     data-gallery-map-initial-lat-value="35.6762"
     data-gallery-map-initial-lng-value="139.6503"
     data-gallery-map-initial-zoom-value="10">

  <!-- Map -->
  <div class="map-container" data-gallery-map-target="mapContainer"></div>

  <!-- Spot Panel (slides in from right) -->
  <div class="spot-panel" data-gallery-map-target="spotPanel"></div>

  <!-- Sidebar -->
  <div class="map-sidebar">
    <!-- Filters -->
    <div class="mb-6">
      <h2 class="text-sm font-semibold text-gray-900 mb-3">絞り込み</h2>

      <div class="space-y-3">
        <!-- Contest Filter -->
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1">コンテスト</label>
          <select data-action="change->gallery-map#filterByContest"
                  class="block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm">
            <option value="">すべて</option>
            <% @contests.each do |contest| %>
              <option value="<%= contest.id %>" <%= 'selected' if params[:contest_id].to_s == contest.id.to_s %>><%= contest.title %></option>
            <% end %>
          </select>
        </div>

        <!-- Area Filter -->
        <% if @areas.any? %>
          <div>
            <label class="block text-xs font-medium text-gray-500 mb-1">地域</label>
            <select data-action="change->gallery-map#filterByArea"
                    class="block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm">
              <option value="">すべて</option>
              <% @areas.each do |area| %>
                <option value="<%= area.id %>" <%= 'selected' if params[:area_id].to_s == area.id.to_s %>><%= area.name %></option>
              <% end %>
            </select>
          </div>
        <% end %>

        <!-- Discovery Status Filter -->
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1">発掘ステータス</label>
          <select data-action="change->gallery-map#filterByDiscoveryStatus"
                  class="block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm">
            <option value="">すべて</option>
            <option value="organizer" <%= 'selected' if params[:discovery_status] == 'organizer' %>>主催者作成</option>
            <option value="certified" <%= 'selected' if params[:discovery_status] == 'certified' %>>認定済み発掘</option>
            <option value="discovered" <%= 'selected' if params[:discovery_status] == 'discovered' %>>審査中</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Stats -->
    <div class="mb-6 p-4 bg-indigo-50 rounded-lg">
      <p class="text-sm text-indigo-900">
        <span class="font-semibold" data-gallery-map-target="entryCount"><%= @entries_with_location.count %></span>
        件の位置情報付き作品
      </p>
    </div>

    <!-- Discovery Status Legend -->
    <div class="mb-6">
      <h2 class="text-sm font-semibold text-gray-900 mb-3">マーカー凡例</h2>
      <div class="space-y-2 text-xs">
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-indigo-500"></span>
          <span class="text-gray-700">主催者作成スポット</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-green-500"></span>
          <span class="text-gray-700">認定済み発掘スポット</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-amber-500"></span>
          <span class="text-gray-700">審査中スポット</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-blue-500"></span>
          <span class="text-gray-700">自分が発掘したスポット</span>
        </div>
      </div>
    </div>

    <!-- Entries without location -->
    <% if @entries_without_location.any? %>
      <div>
        <h2 class="text-sm font-semibold text-gray-900 mb-3">位置情報なしの作品</h2>
        <div class="space-y-2">
          <% @entries_without_location.limit(10).each do |entry| %>
            <%= link_to entry_path(entry), class: "flex items-center gap-3 p-2 rounded-lg hover:bg-gray-50" do %>
              <div class="w-12 h-12 rounded overflow-hidden flex-shrink-0 bg-gray-100">
                <% if entry.photo.attached? %>
                  <%= image_tag entry.photo.variant(resize_to_fill: [48, 48]), alt: entry.title.presence || "フォトコンテスト応募作品", class: "w-full h-full object-cover" %>
                <% end %>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-gray-900 truncate"><%= entry.title.presence || "無題" %></p>
                <p class="text-xs text-gray-500 truncate"><%= entry.contest.title %></p>
              </div>
            <% end %>
          <% end %>
        </div>
        <% if @entries_without_location.count > 10 %>
          <p class="mt-3 text-xs text-gray-500 text-center">
            他 <%= @entries_without_location.count - 10 %> 件
          </p>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
