<%= turbo_frame_tag "gallery-entries", data: { turbo_action: "advance" } do %>
  <% @entries.each do |entry| %>
    <%= link_to entry_path(entry), class: "block group", data: { lightbox_target: "trigger", entry_id: entry.id } do %>
      <div class="bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden hover:shadow-lg transition-all hover:-translate-y-1">
        <!-- Photo -->
        <div class="aspect-square bg-gray-100 relative overflow-hidden">
          <% if entry.photo.attached? %>
            <%= image_tag entry.photo.variant(resize_to_fill: [300, 300]),
              class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-300",
              loading: "lazy",
              data: { full_url: url_for(entry.photo.variant(resize_to_limit: [1200, 1200])) }
            %>
          <% else %>
            <div class="w-full h-full flex items-center justify-center">
              <svg class="h-8 w-8 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
          <% end %>

          <!-- Vote Count Badge -->
          <div class="absolute bottom-2 right-2 bg-white/90 backdrop-blur-sm rounded-full px-2 py-1 flex items-center space-x-1 shadow-sm">
            <svg class="h-3.5 w-3.5 <%= entry.votes_count > 0 ? 'text-pink-500 fill-current' : 'text-gray-400' %>" viewBox="0 0 24 24" <%= entry.votes_count > 0 ? '' : 'fill="none" stroke="currentColor"' %>>
              <path <%= entry.votes_count > 0 ? '' : 'stroke-linecap="round" stroke-linejoin="round" stroke-width="2"' %> d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
            </svg>
            <span class="text-xs font-medium text-gray-700"><%= entry.votes_count %></span>
          </div>
        </div>

        <!-- Entry Info -->
        <div class="p-2">
          <h3 class="text-xs font-medium text-gray-900 line-clamp-1 group-hover:text-indigo-600 transition-colors">
            <%= entry.title.presence || "無題" %>
          </h3>
          <div class="flex items-center gap-1 mt-0.5">
            <p class="text-xs text-gray-400 line-clamp-1 flex-1">
              <%= entry.contest.title %>
            </p>
            <% if entry.area.present? %>
              <span class="flex-shrink-0 inline-block px-1 py-0.5 text-[10px] font-medium bg-green-50 text-green-700 rounded">
                <%= entry.area.name %>
              </span>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  <% end %>

  <!-- Infinite scroll trigger -->
  <% if @entries.next_page %>
    <div data-controller="infinite-scroll"
         data-infinite-scroll-root-margin-value="200px">
      <%= turbo_frame_tag "gallery-entries",
        src: gallery_index_path(page: @entries.next_page, **request.query_parameters.except("page")),
        loading: :lazy,
        class: "col-span-full" do %>
        <div class="col-span-full flex justify-center py-8">
          <div class="flex items-center space-x-2 text-gray-500">
            <svg class="animate-spin h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            <span class="text-sm">読み込み中...</span>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
<% end %>
