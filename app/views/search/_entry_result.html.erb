<%= link_to entry_path(entry), class: "group block" do %>
  <div class="aspect-square rounded-lg overflow-hidden bg-gray-100">
    <% if entry.photo.attached? %>
      <%= image_tag entry.photo.variant(resize_to_fill: [300, 300]),
                    class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-200",
                    alt: entry.title.presence || "応募作品",
                    loading: "lazy" %>
    <% else %>
      <div class="w-full h-full flex items-center justify-center text-gray-400">
        <svg class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </div>
    <% end %>
  </div>
  <div class="mt-2">
    <h3 class="text-sm font-medium text-gray-900 truncate"><%= entry.title.presence || "無題" %></h3>
    <p class="text-xs text-gray-500 truncate"><%= entry.contest.title %></p>
    <div class="mt-1 flex items-center gap-2 text-xs text-gray-500">
      <span class="flex items-center gap-0.5">
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
        </svg>
        <%= entry.votes.size %>
      </span>
    </div>
  </div>
<% end %>
