<div class="container mx-auto max-w-4xl px-4 py-8">
  <!-- Profile Header -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="p-6 bg-gradient-to-r from-indigo-500 to-purple-600">
      <div class="flex items-center justify-between">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <% if @user.avatar.attached? %>
              <%= image_tag @user.avatar.variant(resize_to_fill: [120, 120]), alt: @user.display_name, class: "w-24 h-24 rounded-full border-4 border-white shadow-lg object-cover", loading: "lazy" %>
            <% else %>
              <div class="w-24 h-24 bg-white rounded-full border-4 border-white shadow-lg flex items-center justify-center">
                <span class="text-3xl font-bold text-indigo-600"><%= @user.initial %></span>
              </div>
            <% end %>
          </div>
          <div class="ml-6">
            <h1 class="text-2xl font-bold text-white"><%= @user.display_name %></h1>
            <% if @user.bio.present? %>
              <p class="mt-1 text-indigo-100 max-w-md"><%= @user.bio %></p>
            <% end %>
          </div>
        </div>
        <div>
          <%= render "follows/button", user: @user %>
        </div>
      </div>
    </div>

    <!-- Stats -->
    <div class="p-6 border-b border-gray-100">
      <div class="grid grid-cols-2 sm:grid-cols-5 gap-4 text-center">
        <div class="bg-gray-50 rounded-lg p-3">
          <div class="text-xl font-bold text-indigo-600"><%= @stats[:entries_count] %></div>
          <div class="text-xs text-gray-500"><%= t('social.profile.entries') %></div>
        </div>
        <div class="bg-gray-50 rounded-lg p-3">
          <div class="text-xl font-bold text-purple-600"><%= @stats[:followers_count] %></div>
          <div class="text-xs text-gray-500"><%= t('social.follows.followers') %></div>
        </div>
        <div class="bg-gray-50 rounded-lg p-3">
          <div class="text-xl font-bold text-pink-500"><%= @stats[:following_count] %></div>
          <div class="text-xs text-gray-500"><%= t('social.follows.following_count') %></div>
        </div>
        <div class="bg-gray-50 rounded-lg p-3">
          <div class="text-xl font-bold text-red-500"><%= @stats[:total_likes_received] %></div>
          <div class="text-xs text-gray-500"><%= t('social.profile.likes_received') %></div>
        </div>
        <div class="bg-gray-50 rounded-lg p-3">
          <div class="text-xl font-bold text-yellow-500"><%= @stats[:prizes_won] %></div>
          <div class="text-xs text-gray-500"><%= t('social.profile.prizes_won') %></div>
        </div>
      </div>
    </div>

    <!-- Portfolio -->
    <div class="p-6 border-b border-gray-100">
      <h2 class="text-lg font-semibold text-gray-900 mb-4"><%= t('social.profile.portfolio_title') %></h2>
      <% if @portfolio.any? %>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
          <% @portfolio.each do |entry| %>
            <%= link_to entry_path(entry), class: "group relative rounded-lg overflow-hidden aspect-square" do %>
              <% if entry.photo.attached? %>
                <%= image_tag entry.photo.variant(resize_to_fill: [300, 300]), alt: entry.title, class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-200", loading: "lazy" %>
              <% end %>
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity">
                <div class="absolute bottom-2 left-2 right-2">
                  <p class="text-white text-sm font-medium truncate"><%= entry.title.presence || t('common.untitled') %></p>
                  <p class="text-white/80 text-xs"><%= entry.contest.title %></p>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-400"><%= t('social.profile.no_portfolio') %></p>
      <% end %>
    </div>

    <!-- Award History -->
    <div class="p-6 border-b border-gray-100">
      <h2 class="text-lg font-semibold text-gray-900 mb-4"><%= t('social.profile.award_history_title') %></h2>
      <% if @award_history.any? %>
        <div class="space-y-3">
          <% @award_history.each do |ranking| %>
            <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
              <div class="flex items-center gap-3">
                <span class="inline-flex items-center justify-center w-8 h-8 rounded-full text-sm font-bold
                  <%= case ranking.rank
                      when 1 then 'bg-yellow-100 text-yellow-700'
                      when 2 then 'bg-gray-100 text-gray-700'
                      when 3 then 'bg-amber-100 text-amber-700'
                      else 'bg-blue-100 text-blue-700'
                      end %>">
                  <%= ranking.rank %>
                </span>
                <div>
                  <p class="text-sm font-medium text-gray-900"><%= ranking.entry.contest.title %></p>
                  <p class="text-xs text-gray-500"><%= ranking.prize_label %></p>
                </div>
              </div>
              <span class="text-xs text-gray-400"><%= l(ranking.calculated_at, format: :short) if ranking.calculated_at %></span>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-400"><%= t('social.profile.no_awards') %></p>
      <% end %>
    </div>

    <!-- Achievements -->
    <% if @achievements.any? %>
      <div class="p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4"><%= t('gamification.profile.achievements_title') %></h2>
        <div class="flex flex-wrap gap-2">
          <% @achievements.each do |milestone| %>
            <% badge = milestone.badge_info %>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-<%= badge[:color] %>-100 text-<%= badge[:color] %>-800">
              <%= badge[:name] %>
            </span>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
