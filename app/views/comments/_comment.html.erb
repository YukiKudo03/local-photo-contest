<%= turbo_frame_tag dom_id(comment) do %>
  <div class="flex space-x-3 py-4">
    <!-- Avatar -->
    <div class="flex-shrink-0">
      <div class="w-10 h-10 bg-indigo-100 rounded-full flex items-center justify-center">
        <span class="text-indigo-600 font-medium text-sm">
          <%= (comment.user.name.presence || comment.user.email).first.upcase %>
        </span>
      </div>
    </div>

    <!-- Content -->
    <div class="flex-1 min-w-0">
      <div class="flex items-center justify-between">
        <div>
          <span class="text-sm font-medium text-gray-900"><%= comment.user.name.presence || comment.user.email %></span>
          <span class="text-sm text-gray-500 ml-2"><%= t('comments.comment.time_ago', time: time_ago_in_words(comment.created_at)) %></span>
        </div>
        <% if user_signed_in? && (comment.user == current_user || comment.entry.user == current_user) %>
          <%= button_to entry_comment_path(comment.entry, comment),
              method: :delete,
              data: { turbo_confirm: t('comments.comment.delete_confirm') },
              class: "inline-flex items-center text-sm text-gray-400 hover:text-red-500 transition-colors" do %>
            <svg class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
            </svg>
            <%= t('comments.comment.delete') %>
          <% end %>
        <% end %>
      </div>
      <p class="mt-1 text-sm text-gray-700 whitespace-pre-wrap"><%= comment.body %></p>
    </div>
  </div>
<% end %>
