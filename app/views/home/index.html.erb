<!-- Hero Section -->
<div class="relative bg-gradient-to-r from-indigo-600 to-purple-600 rounded-2xl overflow-hidden">
  <div class="absolute inset-0 bg-black opacity-10"></div>
  <div class="relative px-6 py-16 sm:px-12 sm:py-24 lg:py-32">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white tracking-tight">
        Local Photo Contest
      </h1>
      <p class="mt-6 text-xl text-indigo-100 max-w-2xl mx-auto">
        <%= t('home.hero.tagline') %>
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <% if user_signed_in? %>
          <% if current_user.organizer? %>
            <%= link_to organizers_dashboard_path, class: "inline-flex items-center justify-center px-8 py-3 border border-transparent text-base font-medium rounded-lg text-indigo-600 bg-white hover:bg-indigo-50 shadow-lg transition-all duration-200" do %>
              <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
              </svg>
              <%= t('home.hero.go_to_dashboard') %>
            <% end %>
          <% end %>
        <% else %>
          <%= link_to new_user_registration_path, class: "inline-flex items-center justify-center px-8 py-3 border border-transparent text-base font-medium rounded-lg text-indigo-600 bg-white hover:bg-indigo-50 shadow-lg transition-all duration-200" do %>
            <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
            </svg>
            <%= t('home.hero.register_as_organizer') %>
          <% end %>
          <%= link_to new_user_session_path, class: "inline-flex items-center justify-center px-8 py-3 border-2 border-white text-base font-medium rounded-lg text-white hover:bg-white hover:bg-opacity-10 transition-all duration-200" do %>
            <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" />
            </svg>
            <%= t('home.hero.login') %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Features Section -->
<div class="mt-16">
  <h2 class="text-2xl font-bold text-gray-900 text-center mb-12"><%= t('home.features.title') %></h2>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
      <div class="w-12 h-12 bg-indigo-100 rounded-lg flex items-center justify-center mb-4">
        <svg class="h-6 w-6 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 mb-2"><%= t('home.features.easy_management.title') %></h3>
      <p class="text-gray-600 text-sm"><%= t('home.features.easy_management.description') %></p>
    </div>

    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
      <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mb-4">
        <svg class="h-6 w-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 mb-2"><%= t('home.features.security.title') %></h3>
      <p class="text-gray-600 text-sm"><%= t('home.features.security.description') %></p>
    </div>

    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
      <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center mb-4">
        <svg class="h-6 w-6 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
        </svg>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 mb-2"><%= t('home.features.community.title') %></h3>
      <p class="text-gray-600 text-sm"><%= t('home.features.community.description') %></p>
    </div>
  </div>
</div>

<!-- CTA Section -->
<% unless user_signed_in? %>
  <div class="mt-16 bg-gray-900 rounded-2xl overflow-hidden">
    <div class="px-6 py-12 sm:px-12 text-center">
      <h2 class="text-2xl font-bold text-white mb-4"><%= t('home.cta.title') %></h2>
      <p class="text-gray-400 mb-8 max-w-xl mx-auto">
        <%= t('home.cta.description') %>
      </p>
      <%= link_to new_user_registration_path, class: "inline-flex items-center justify-center px-8 py-3 border border-transparent text-base font-medium rounded-lg text-gray-900 bg-white hover:bg-gray-100 transition-colors" do %>
        <%= t('home.cta.register_free') %>
        <svg class="ml-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      <% end %>
    </div>
  </div>
<% end %>
