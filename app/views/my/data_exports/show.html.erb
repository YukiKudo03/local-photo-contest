<% content_for :title, t('gdpr.data_export.title') %>

<div class="max-w-2xl mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold text-gray-900 mb-6"><%= t('gdpr.data_export.title') %></h1>

  <div class="bg-white rounded-lg border border-gray-200 p-6">
    <div class="flex items-center gap-3 mb-4">
      <% case @export_request.status %>
      <% when "pending" %>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
          <%= t('gdpr.data_export.status.pending') %>
        </span>
      <% when "processing" %>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
          <%= t('gdpr.data_export.status.processing') %>
        </span>
      <% when "completed" %>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
          <%= t('gdpr.data_export.status.completed') %>
        </span>
      <% when "expired" %>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
          <%= t('gdpr.data_export.status.expired') %>
        </span>
      <% end %>
    </div>

    <p class="text-sm text-gray-600 mb-4">
      <%= t('gdpr.data_export.requested_at', time: l(@export_request.requested_at, format: :long)) %>
    </p>

    <% if @export_request.completed? && !@export_request.expired? && @export_request.file.attached? %>
      <div class="mt-4">
        <%= link_to t('gdpr.data_export.download_button'),
              download_my_data_export_path(@export_request),
              class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-md hover:bg-indigo-500" %>
        <p class="mt-2 text-xs text-gray-500">
          <%= t('gdpr.data_export.expires_at', time: l(@export_request.expires_at, format: :long)) %>
        </p>
      </div>
    <% end %>
  </div>

  <div class="mt-6">
    <%= link_to t('gdpr.data_export.back_to_profile'), my_profile_path, class: "text-sm text-indigo-600 hover:text-indigo-500" %>
  </div>
</div>
