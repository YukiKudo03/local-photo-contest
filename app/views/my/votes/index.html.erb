<div class="container mx-auto max-w-6xl px-4 py-8" data-tutorial="my-votes-page">
  <!-- Page Header -->
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900">投票した作品</h1>
    <p class="mt-1 text-gray-500">あなたが投票した作品の一覧です</p>
  </div>

  <!-- Votes Grid -->
  <% if @votes.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" data-tutorial="my-votes-list">
      <% @votes.each do |vote| %>
        <% entry = vote.entry %>
        <%= link_to entry_path(entry), class: "block bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow" do %>
          <!-- Photo Thumbnail -->
          <div class="aspect-square bg-gray-100 flex items-center justify-center">
            <% if entry.photo.attached? %>
              <%= image_tag entry.photo.variant(resize_to_fill: [400, 400]), class: "w-full h-full object-cover" %>
            <% else %>
              <svg class="h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            <% end %>
          </div>

          <div class="p-4">
            <!-- Title -->
            <% if entry.title.present? %>
              <h3 class="text-lg font-semibold text-gray-900 line-clamp-1"><%= entry.title %></h3>
            <% else %>
              <h3 class="text-lg font-semibold text-gray-400">無題</h3>
            <% end %>

            <!-- Contest Name -->
            <p class="mt-1 text-sm text-indigo-600 line-clamp-1"><%= entry.contest.title %></p>

            <!-- Vote Info -->
            <div class="mt-2 flex items-center justify-between">
              <p class="text-xs text-gray-400">
                <%= vote.created_at.strftime('%Y/%m/%d %H:%M') %> に投票
              </p>
              <span class="inline-flex items-center text-pink-500">
                <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24">
                  <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                </svg>
                <span class="ml-1 text-sm font-medium"><%= entry.votes_count %></span>
              </span>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <!-- Empty State -->
    <div class="text-center py-12 bg-white rounded-xl shadow-sm border border-gray-100">
      <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
      </svg>
      <h3 class="mt-4 text-lg font-medium text-gray-900">投票した作品がありません</h3>
      <p class="mt-2 text-sm text-gray-500">気に入った作品に投票してみましょう</p>
      <div class="mt-6">
        <%= link_to contests_path, class: "inline-flex items-center px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg transition-colors" do %>
          コンテストを見る
        <% end %>
      </div>
    </div>
  <% end %>
</div>
