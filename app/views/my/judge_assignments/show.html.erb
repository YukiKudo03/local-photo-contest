<% content_for :title, "#{@contest.title} - 審査" %>

<!-- Breadcrumb -->
<div class="mb-6">
  <%= link_to my_judge_assignments_path, class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700" do %>
    <svg class="mr-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
    </svg>
    審査担当コンテスト一覧に戻る
  <% end %>
</div>

<!-- Contest Header -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-6">
  <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between">
    <div class="flex-1">
      <h1 class="text-2xl font-bold text-gray-900 mb-2"><%= @contest.title %></h1>
      <p class="text-gray-600 mb-4"><%= @contest.theme %></p>

      <!-- Contest Status -->
      <div class="flex flex-wrap gap-2 mb-4">
        <% if @contest.results_announced_at.present? %>
          <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-gray-100 text-gray-800">
            <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            結果発表済み
          </span>
        <% elsif @contest.finished? %>
          <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800">
            審査期間中
          </span>
        <% else %>
          <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
            応募受付中
          </span>
        <% end %>
      </div>
    </div>

    <!-- Progress Stats -->
    <div class="lg:ml-8 mt-4 lg:mt-0">
      <div class="bg-gray-50 rounded-lg p-4 min-w-[200px]">
        <p class="text-sm text-gray-500 mb-2">評価進捗</p>
        <div class="flex items-end gap-2 mb-2">
          <span class="text-3xl font-bold <%= @contest_judge.evaluation_progress == 100 ? 'text-green-600' : 'text-indigo-600' %>">
            <%= @contest_judge.evaluation_progress %>%
          </span>
          <span class="text-sm text-gray-500 pb-1">完了</span>
        </div>
        <div class="w-full bg-gray-200 rounded-full h-2">
          <div class="h-2 rounded-full <%= @contest_judge.evaluation_progress == 100 ? 'bg-green-500' : 'bg-indigo-500' %>"
               style="width: <%= @contest_judge.evaluation_progress %>%"></div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Evaluation Criteria Info -->
<% if @criteria.any? %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-6" data-tutorial="evaluation-criteria">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">評価基準</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <% @criteria.each do |criterion| %>
        <div class="bg-gray-50 rounded-lg p-4">
          <div class="flex items-center justify-between mb-1">
            <h3 class="font-medium text-gray-900"><%= criterion.name %></h3>
            <span class="text-sm text-gray-500">最大 <%= criterion.max_score %> 点</span>
          </div>
          <% if criterion.description.present? %>
            <p class="text-sm text-gray-600"><%= criterion.description %></p>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<!-- Entries List -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
  <div class="p-6 border-b border-gray-100">
    <div class="flex items-center justify-between">
      <h2 class="text-lg font-semibold text-gray-900">応募作品一覧</h2>
      <span class="text-sm text-gray-500"><%= @entries.count %> 件</span>
    </div>
  </div>

  <% if @entries.any? %>
    <div class="divide-y divide-gray-100">
      <% @entries.each do |entry| %>
        <% is_own_entry = entry.user == current_user %>
        <% is_evaluated = @contest_judge.fully_evaluated_entry?(entry) %>

        <div class="p-4 hover:bg-gray-50 transition-colors <%= is_own_entry ? 'bg-gray-50 opacity-60' : '' %>">
          <div class="flex items-center gap-4">
            <!-- Thumbnail -->
            <div class="flex-shrink-0 w-20 h-20 rounded-lg overflow-hidden bg-gray-100">
              <% if entry.photo.attached? %>
                <%= image_tag entry.photo.variant(resize_to_fill: [160, 160]),
                              alt: entry.title.presence || "フォトコンテスト応募作品",
                              class: "w-full h-full object-cover",
                              loading: "lazy" %>
              <% else %>
                <div class="w-full h-full flex items-center justify-center">
                  <svg class="w-8 h-8 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                </div>
              <% end %>
            </div>

            <!-- Entry Info -->
            <div class="flex-1 min-w-0">
              <h3 class="font-medium text-gray-900 truncate">
                <%= entry.title.presence || "無題" %>
              </h3>
              <p class="text-sm text-gray-500">
                投稿者: <%= entry.user.display_name %>
              </p>
              <% if entry.location.present? %>
                <p class="text-sm text-gray-400 truncate">
                  <svg class="inline w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  </svg>
                  <%= entry.location %>
                </p>
              <% end %>
            </div>

            <!-- Status & Action -->
            <div class="flex-shrink-0 flex items-center gap-3">
              <% if is_own_entry %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-200 text-gray-600">
                  自分の作品
                </span>
              <% elsif is_evaluated %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                  <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                  評価済み
                </span>
              <% else %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800">
                  未評価
                </span>
              <% end %>

              <% unless is_own_entry %>
                <%= link_to my_judge_assignment_evaluation_path(@contest_judge, entry),
                            class: "inline-flex items-center px-3 py-1.5 text-sm font-medium rounded-lg #{is_evaluated ? 'text-gray-700 bg-gray-100 hover:bg-gray-200' : 'text-white bg-indigo-600 hover:bg-indigo-700'} transition-colors" do %>
                  <% if is_evaluated %>
                    <% if @contest.results_announced_at.present? %>
                      確認
                    <% else %>
                      編集
                    <% end %>
                  <% else %>
                    評価する
                  <% end %>
                <% end %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="p-12 text-center">
      <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
      <h3 class="mt-4 text-lg font-medium text-gray-900">まだ応募作品がありません</h3>
      <p class="mt-2 text-sm text-gray-500">応募が開始されると、ここに作品が表示されます</p>
    </div>
  <% end %>
</div>
