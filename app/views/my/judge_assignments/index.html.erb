<% content_for :title, "審査担当コンテスト" %>

<%# チュートリアル: 審査員オンボーディング %>
<%= render "tutorials/welcome_modal", tutorial_type: "judge_onboarding" if should_show_tutorial?("judge_onboarding") %>
<%= render "tutorials/tutorial_container", tutorial_type: "judge_onboarding", auto_start: false %>

<!-- Page Header -->
<div class="mb-8 flex items-center justify-between">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">審査担当コンテスト</h1>
    <p class="mt-1 text-sm text-gray-500">あなたが審査員として割り当てられているコンテストの一覧です</p>
  </div>
  <div class="flex items-center gap-3">
    <%= link_to help_guide_path(:judge), class: "inline-flex items-center px-3 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors" do %>
      <svg class="w-4 h-4 mr-2 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      審査員ガイド
    <% end %>
    <%= render "tutorials/help_button", tutorial_type: "judge_onboarding" %>
  </div>
</div>

<% if @assignments.any? %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" data-tutorial="judge-assignments">
    <% @assignments.each do |assignment| %>
      <% contest = assignment.contest %>
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow">
        <!-- Contest Image or Placeholder -->
        <div class="h-40 bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center">
          <% if contest.thumbnail.attached? %>
            <%= image_tag contest.thumbnail.variant(resize_to_fill: [400, 160]), class: "w-full h-full object-cover" %>
          <% else %>
            <svg class="h-16 w-16 text-white/50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          <% end %>
        </div>

        <div class="p-5">
          <!-- Contest Info -->
          <div class="mb-4">
            <h3 class="text-lg font-semibold text-gray-900 mb-1"><%= contest.title %></h3>
            <p class="text-sm text-gray-500"><%= contest.theme %></p>
          </div>

          <!-- Stats -->
          <div class="grid grid-cols-2 gap-4 mb-4">
            <div class="text-center p-3 bg-gray-50 rounded-lg">
              <p class="text-2xl font-bold text-indigo-600"><%= contest.entries.count %></p>
              <p class="text-xs text-gray-500">応募作品</p>
            </div>
            <div class="text-center p-3 bg-gray-50 rounded-lg">
              <p class="text-2xl font-bold <%= assignment.evaluation_progress == 100 ? 'text-green-600' : 'text-amber-600' %>">
                <%= assignment.evaluation_progress %>%
              </p>
              <p class="text-xs text-gray-500">評価進捗</p>
            </div>
          </div>

          <!-- Progress Bar -->
          <div class="mb-4">
            <div class="w-full bg-gray-200 rounded-full h-2">
              <div class="h-2 rounded-full <%= assignment.evaluation_progress == 100 ? 'bg-green-500' : 'bg-indigo-500' %>"
                   style="width: <%= assignment.evaluation_progress %>%"></div>
            </div>
          </div>

          <!-- Status Badge -->
          <div class="flex items-center justify-between mb-4">
            <% if contest.results_announced_at.present? %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                結果発表済み
              </span>
            <% elsif contest.finished? %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                審査中
              </span>
            <% else %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                応募受付中
              </span>
            <% end %>

            <% if assignment.evaluation_progress == 100 %>
              <span class="inline-flex items-center text-green-600 text-sm">
                <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                評価完了
              </span>
            <% end %>
          </div>

          <!-- Action Button -->
          <%= link_to my_judge_assignment_path(assignment),
                      class: "block w-full text-center px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition-colors font-medium" do %>
            <% if contest.results_announced_at.present? %>
              評価を確認
            <% else %>
              作品を評価する
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <!-- Empty State -->
  <div class="text-center py-16 bg-white rounded-xl shadow-sm border border-gray-100">
    <svg class="mx-auto h-16 w-16 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
    </svg>
    <h3 class="mt-4 text-lg font-medium text-gray-900">審査担当のコンテストがありません</h3>
    <p class="mt-2 text-sm text-gray-500">コンテスト主催者から審査員として招待されると、ここに表示されます</p>
  </div>
<% end %>
