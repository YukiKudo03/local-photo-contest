<div class="container mx-auto max-w-2xl px-4 py-8">
  <!-- Page Header -->
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900">マイプロフィール</h1>
    <p class="mt-1 text-sm text-gray-500">あなたのプロフィール情報</p>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <!-- Profile Header -->
    <div class="p-6 bg-gradient-to-r from-indigo-500 to-purple-600">
      <div class="flex items-center">
        <!-- Avatar -->
        <div class="flex-shrink-0">
          <% if @user.avatar.attached? %>
            <%= image_tag @user.avatar.variant(resize_to_fill: [120, 120]), class: "w-24 h-24 rounded-full border-4 border-white shadow-lg object-cover" %>
          <% else %>
            <div class="w-24 h-24 bg-white rounded-full border-4 border-white shadow-lg flex items-center justify-center">
              <span class="text-3xl font-bold text-indigo-600"><%= @user.initial %></span>
            </div>
          <% end %>
        </div>

        <!-- Name -->
        <div class="ml-6">
          <h2 class="text-2xl font-bold text-white"><%= @user.display_name %></h2>
          <p class="text-indigo-100"><%= @user.email %></p>
        </div>
      </div>
    </div>

    <!-- Profile Details -->
    <div class="p-6 space-y-6">
      <!-- Bio -->
      <div>
        <dt class="text-sm font-medium text-gray-500">自己紹介</dt>
        <dd class="mt-1 text-gray-900">
          <% if @user.bio.present? %>
            <p class="whitespace-pre-wrap"><%= @user.bio %></p>
          <% else %>
            <p class="text-gray-400">自己紹介が設定されていません</p>
          <% end %>
        </dd>
      </div>

      <!-- Stats -->
      <div class="pt-6 border-t border-gray-100">
        <h3 class="text-sm font-medium text-gray-500 mb-4">活動情報</h3>
        <div class="grid grid-cols-3 gap-4 text-center">
          <div class="bg-gray-50 rounded-lg p-4">
            <div class="text-2xl font-bold text-indigo-600"><%= @user.entries.count %></div>
            <div class="text-sm text-gray-500">応募作品</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4">
            <div class="text-2xl font-bold text-pink-500"><%= @user.votes.count %></div>
            <div class="text-sm text-gray-500">投票</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4">
            <div class="text-2xl font-bold text-green-500"><%= @user.comments.count %></div>
            <div class="text-sm text-gray-500">コメント</div>
          </div>
        </div>
      </div>

      <!-- Discovery Stats -->
      <%= render "my/profiles/discovery_stats", user: @user %>

      <!-- Account Info -->
      <div class="pt-6 border-t border-gray-100">
        <h3 class="text-sm font-medium text-gray-500 mb-4">アカウント情報</h3>
        <dl class="space-y-3">
          <div class="flex justify-between">
            <dt class="text-sm text-gray-500">登録日</dt>
            <dd class="text-sm text-gray-900"><%= @user.created_at.strftime('%Y年%m月%d日') %></dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-sm text-gray-500">最終ログイン</dt>
            <dd class="text-sm text-gray-900">
              <% if @user.current_sign_in_at %>
                <%= @user.current_sign_in_at.strftime('%Y年%m月%d日 %H:%M') %>
              <% else %>
                -
              <% end %>
            </dd>
          </div>
        </dl>
      </div>
    </div>

    <!-- Actions -->
    <div class="px-6 py-4 bg-gray-50 border-t border-gray-100">
      <%= link_to edit_my_profile_path, class: "inline-flex items-center px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg transition-colors" do %>
        <svg class="mr-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
        </svg>
        プロフィールを編集
      <% end %>
    </div>
  </div>
</div>
