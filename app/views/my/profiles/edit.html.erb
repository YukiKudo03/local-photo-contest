<div class="container mx-auto max-w-2xl px-4 py-8">
  <!-- Page Header -->
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900"><%= t('my.profile.edit.title') %></h1>
    <p class="mt-1 text-sm text-gray-500"><%= t('my.profile.edit.subtitle') %></p>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <%= form_with model: @user, url: my_profile_path, method: :patch, class: "p-6 space-y-6" do |f| %>
      <!-- Avatar Upload -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2"><%= t('my.profile.edit.avatar_label') %></label>
        <div class="flex items-center space-x-6">
          <!-- Current Avatar Preview -->
          <div class="flex-shrink-0">
            <% if @user.avatar.attached? %>
              <%= image_tag @user.avatar.variant(resize_to_fill: [96, 96]), alt: t('my.profile.edit.avatar_label'), class: "w-24 h-24 rounded-full object-cover border-2 border-gray-200", id: "avatar-preview" %>
            <% else %>
              <div class="w-24 h-24 bg-indigo-100 rounded-full border-2 border-gray-200 flex items-center justify-center" id="avatar-placeholder">
                <span class="text-2xl font-bold text-indigo-600"><%= @user.initial %></span>
              </div>
            <% end %>
          </div>

          <!-- Upload Button -->
          <div class="flex-1">
            <div class="flex items-center">
              <label class="cursor-pointer inline-flex items-center px-4 py-2 bg-white border border-gray-300 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">
                <svg class="mr-2 h-4 w-4 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <%= t('my.profile.edit.avatar_select') %>
                <%= f.file_field :avatar, accept: "image/jpeg,image/png,image/gif", class: "sr-only", id: "avatar-input" %>
              </label>
            </div>
            <p class="mt-2 text-xs text-gray-500"><%= t('my.profile.edit.avatar_hint') %></p>
            <% if @user.errors[:avatar].present? %>
              <p class="mt-1 text-sm text-red-600"><%= @user.errors[:avatar].first %></p>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Name -->
      <div>
        <label for="user_name" class="block text-sm font-medium text-gray-700 mb-1"><%= t('my.profile.edit.name_label') %></label>
        <%= f.text_field :name,
          class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 #{@user.errors[:name].present? ? 'border-red-300' : ''}",
          placeholder: t('my.profile.edit.name_placeholder')
        %>
        <p class="mt-1 text-xs text-gray-500"><%= t('my.profile.edit.name_hint') %></p>
        <% if @user.errors[:name].present? %>
          <p class="mt-1 text-sm text-red-600"><%= @user.errors[:name].first %></p>
        <% end %>
      </div>

      <!-- Bio -->
      <div>
        <label for="user_bio" class="block text-sm font-medium text-gray-700 mb-1"><%= t('my.profile.edit.bio_label') %></label>
        <%= f.text_area :bio,
          rows: 4,
          class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 #{@user.errors[:bio].present? ? 'border-red-300' : ''}",
          placeholder: t('my.profile.edit.bio_placeholder')
        %>
        <p class="mt-1 text-xs text-gray-500"><%= t('my.profile.edit.bio_hint') %></p>
        <% if @user.errors[:bio].present? %>
          <p class="mt-1 text-sm text-red-600"><%= @user.errors[:bio].first %></p>
        <% end %>
      </div>

      <!-- Email (Read-only) -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1"><%= t('my.profile.edit.email_label') %></label>
        <div class="block w-full px-3 py-2 bg-gray-50 rounded-lg border border-gray-200 text-gray-500">
          <%= @user.email %>
        </div>
        <p class="mt-1 text-xs text-gray-500"><%= t('my.profile.edit.email_hint') %></p>
      </div>

      <!-- Actions -->
      <div class="flex items-center justify-between pt-4 border-t border-gray-100">
        <%= link_to my_profile_path, class: "text-gray-600 hover:text-gray-900 text-sm font-medium" do %>
          <%= t('my.profile.edit.cancel') %>
        <% end %>

        <%= f.submit t('my.profile.edit.submit'), class: "inline-flex items-center px-6 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg transition-colors cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
