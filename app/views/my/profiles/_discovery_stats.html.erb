<%# Discovery Stats Partial for User Profile %>
<% discovered_spots = user.discovered_spots %>
<% certified_spots = discovered_spots.where(discovery_status: :certified) %>
<% pending_spots = discovered_spots.where(discovery_status: :discovered) %>
<% badges = user.discovery_badges %>

<% if discovered_spots.any? || badges.any? %>
  <div class="pt-6 border-t border-gray-100">
    <h3 class="text-sm font-medium text-gray-500 mb-4">
      <svg class="inline-block w-4 h-4 mr-1 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      <%= t('my.profile.show.discovery_title') %>
    </h3>

    <!-- Discovery Stats Grid -->
    <div class="grid grid-cols-3 gap-4 text-center mb-4">
      <div class="bg-green-50 rounded-lg p-4">
        <div class="text-2xl font-bold text-green-600"><%= certified_spots.count %></div>
        <div class="text-sm text-gray-500"><%= t('my.profile.show.certified_spots') %></div>
      </div>
      <div class="bg-amber-50 rounded-lg p-4">
        <div class="text-2xl font-bold text-amber-600"><%= pending_spots.count %></div>
        <div class="text-sm text-gray-500"><%= t('my.profile.show.pending_review') %></div>
      </div>
      <div class="bg-blue-50 rounded-lg p-4">
        <div class="text-2xl font-bold text-blue-600"><%= user.spot_votes.count %></div>
        <div class="text-sm text-gray-500"><%= t('my.profile.show.spot_votes') %></div>
      </div>
    </div>

    <!-- Badges -->
    <% if badges.any? %>
      <div class="mt-4">
        <p class="text-sm text-gray-500 mb-2"><%= t('my.profile.show.earned_badges') %></p>
        <div class="flex flex-wrap gap-2">
          <% badges.includes(:contest).each do |badge| %>
            <div class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium <%=
              case badge.badge_type
              when 'pioneer' then 'bg-blue-100 text-blue-800'
              when 'explorer' then 'bg-green-100 text-green-800'
              when 'curator' then 'bg-purple-100 text-purple-800'
              when 'master' then 'bg-yellow-100 text-yellow-800'
              end
            %>" title="<%= badge.contest.title %>">
              <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <%= badge.badge_name %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Recent Discoveries -->
    <% recent_certified = certified_spots.order(certified_at: :desc).limit(3) %>
    <% if recent_certified.any? %>
      <div class="mt-4">
        <p class="text-sm text-gray-500 mb-2"><%= t('my.profile.show.recent_certifications') %></p>
        <div class="space-y-2">
          <% recent_certified.each do |spot| %>
            <div class="flex items-center justify-between p-2 bg-gray-50 rounded-lg">
              <div class="flex items-center min-w-0">
                <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span class="ml-2 text-sm text-gray-900 truncate"><%= spot.name %></span>
              </div>
              <span class="text-xs text-gray-500 flex-shrink-0 ml-2"><%= spot.contest.title.truncate(15) %></span>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
