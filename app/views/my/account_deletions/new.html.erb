<% content_for :title, t('gdpr.account_deletion.title') %>

<div class="max-w-2xl mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold text-gray-900 mb-6"><%= t('gdpr.account_deletion.title') %></h1>

  <% if @deletion_requested %>
    <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-6 mb-6">
      <h2 class="text-lg font-semibold text-yellow-800 mb-2"><%= t('gdpr.account_deletion.pending_title') %></h2>
      <p class="text-yellow-700 mb-4">
        <%= t('gdpr.account_deletion.pending_body', days: current_user.days_until_deletion) %>
      </p>
      <%= button_to t('gdpr.account_deletion.cancel_button'),
            my_account_deletion_path,
            method: :delete,
            class: "inline-flex items-center px-4 py-2 bg-green-600 text-white text-sm font-medium rounded-md hover:bg-green-500" %>
    </div>
  <% else %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-6 mb-6">
      <h2 class="text-lg font-semibold text-red-800 mb-2"><%= t('gdpr.account_deletion.warning_title') %></h2>
      <ul class="list-disc list-inside text-red-700 space-y-1 mb-4">
        <li><%= t('gdpr.account_deletion.warning_1') %></li>
        <li><%= t('gdpr.account_deletion.warning_2') %></li>
        <li><%= t('gdpr.account_deletion.warning_3') %></li>
      </ul>
    </div>

    <%= form_with url: my_account_deletion_path, method: :post, class: "space-y-4" do |f| %>
      <div>
        <label for="password" class="block text-sm font-medium text-gray-700 mb-1">
          <%= t('gdpr.account_deletion.password_label') %>
        </label>
        <input type="password" name="password" id="password" required
               class="block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm">
      </div>
      <div>
        <%= f.submit t('gdpr.account_deletion.submit_button'),
              class: "inline-flex items-center px-4 py-2 bg-red-600 text-white text-sm font-medium rounded-md hover:bg-red-500",
              data: { confirm: t('gdpr.account_deletion.confirm') } %>
      </div>
    <% end %>
  <% end %>

  <div class="mt-6">
    <%= link_to t('gdpr.account_deletion.back_to_profile'), my_profile_path, class: "text-sm text-indigo-600 hover:text-indigo-500" %>
  </div>
</div>
