<div class="container mx-auto max-w-4xl px-4 py-8">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900"><%= t('my.api_tokens.index.title') %></h1>
    <p class="mt-1 text-gray-500"><%= t('my.api_tokens.index.description') %></p>
  </div>

  <%# Show newly created token value %>
  <% if flash[:api_token_value].present? %>
    <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-lg">
      <p class="text-sm font-medium text-green-800"><%= t('my.api_tokens.index.token_created') %></p>
      <code class="mt-2 block p-2 bg-white rounded text-sm font-mono break-all"><%= flash[:api_token_value] %></code>
      <p class="mt-2 text-xs text-green-600"><%= t('my.api_tokens.index.token_warning') %></p>
    </div>
  <% end %>

  <%# Create new token form %>
  <div class="mb-8 p-4 bg-white rounded-xl shadow-sm border border-gray-100">
    <h2 class="text-lg font-semibold text-gray-900 mb-4"><%= t('my.api_tokens.index.new_token') %></h2>
    <%= form_with(model: ApiToken.new, url: my_api_tokens_path, class: "flex items-end gap-4") do |f| %>
      <div class="flex-1">
        <%= f.label :name, t('my.api_tokens.index.token_name'), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :name, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500", placeholder: t('my.api_tokens.index.name_placeholder') %>
      </div>
      <%= f.submit t('my.api_tokens.index.create'), class: "px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg transition-colors cursor-pointer" %>
    <% end %>
  </div>

  <%# Token list %>
  <% if @api_tokens.any? %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t('my.api_tokens.index.name_header') %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t('my.api_tokens.index.last_used') %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t('my.api_tokens.index.created') %></th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase"><%= t('my.api_tokens.index.actions') %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @api_tokens.each do |token| %>
            <tr>
              <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= token.name %></td>
              <td class="px-6 py-4 text-sm text-gray-500">
                <%= token.last_used_at ? l(token.last_used_at, format: :short) : t('my.api_tokens.index.never_used') %>
              </td>
              <td class="px-6 py-4 text-sm text-gray-500"><%= l(token.created_at, format: :short) %></td>
              <td class="px-6 py-4 text-right">
                <%= button_to t('my.api_tokens.index.revoke'), my_api_token_path(token), method: :delete,
                    class: "text-red-600 hover:text-red-800 text-sm font-medium",
                    data: { turbo_confirm: t('my.api_tokens.index.revoke_confirm') } %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="text-center py-12 bg-white rounded-xl shadow-sm border border-gray-100">
      <h3 class="text-lg font-medium text-gray-900"><%= t('my.api_tokens.index.no_tokens') %></h3>
      <p class="mt-2 text-sm text-gray-500"><%= t('my.api_tokens.index.create_first') %></p>
    </div>
  <% end %>
</div>
