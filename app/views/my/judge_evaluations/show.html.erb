<% content_for :title, "#{@entry.title.presence || '作品'} - 評価" %>

<!-- Breadcrumb -->
<div class="mb-6">
  <%= link_to my_judge_assignment_path(@contest_judge), class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700" do %>
    <svg class="mr-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
    </svg>
    作品一覧に戻る
  <% end %>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <!-- Left Column: Photo and Details -->
  <div class="space-y-6">
    <!-- Photo -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="aspect-square bg-gray-100">
        <% if @entry.photo.attached? %>
          <%= image_tag @entry.photo.variant(resize_to_limit: [800, 800]),
                        class: "w-full h-full object-contain cursor-zoom-in",
                        data: { action: "click->lightbox#open" },
                        id: "entry-photo" %>
        <% else %>
          <div class="w-full h-full flex items-center justify-center">
            <svg class="w-16 h-16 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Entry Details -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
      <h2 class="text-xl font-bold text-gray-900 mb-4"><%= @entry.title.presence || "無題" %></h2>

      <dl class="space-y-3">
        <div>
          <dt class="text-sm text-gray-500">投稿者</dt>
          <dd class="text-gray-900"><%= @entry.user.display_name %></dd>
        </div>

        <% if @entry.description.present? %>
          <div>
            <dt class="text-sm text-gray-500">説明</dt>
            <dd class="text-gray-900"><%= @entry.description %></dd>
          </div>
        <% end %>

        <% if @entry.location.present? %>
          <div>
            <dt class="text-sm text-gray-500">撮影場所</dt>
            <dd class="text-gray-900 flex items-center">
              <svg class="w-4 h-4 mr-1 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              </svg>
              <%= @entry.location %>
            </dd>
          </div>
        <% end %>

        <% if @entry.taken_at.present? %>
          <div>
            <dt class="text-sm text-gray-500">撮影日</dt>
            <dd class="text-gray-900"><%= @entry.taken_at.strftime("%Y年%m月%d日") %></dd>
          </div>
        <% end %>

        <div>
          <dt class="text-sm text-gray-500">投稿日時</dt>
          <dd class="text-gray-900"><%= @entry.created_at.strftime("%Y年%m月%d日 %H:%M") %></dd>
        </div>
      </dl>
    </div>
  </div>

  <!-- Right Column: Evaluation Form -->
  <div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-lg font-semibold text-gray-900">評価フォーム</h2>
        <% if @contest.results_announced_at.present? %>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">
            結果発表済み（編集不可）
          </span>
        <% end %>
      </div>

      <% is_readonly = @contest.results_announced_at.present? %>
      <% has_existing_evaluations = @evaluations.any? %>

      <%= form_with url: (has_existing_evaluations ? my_judge_assignment_evaluation_path(@contest_judge, @entry) : my_judge_assignment_evaluations_path(@contest_judge)),
                    method: (has_existing_evaluations ? :patch : :post),
                    local: true,
                    class: "space-y-6" do |form| %>

        <%= hidden_field_tag :entry_id, @entry.id %>

        <!-- Criteria Scores -->
        <div class="space-y-6">
          <% @criteria.each do |criterion| %>
            <% evaluation = @evaluations[criterion.id] %>
            <div class="border border-gray-200 rounded-lg p-4">
              <div class="flex items-start justify-between mb-3">
                <div>
                  <label class="block font-medium text-gray-900"><%= criterion.name %></label>
                  <% if criterion.description.present? %>
                    <p class="text-sm text-gray-500 mt-1"><%= criterion.description %></p>
                  <% end %>
                </div>
                <span class="text-sm text-gray-400">1 〜 <%= criterion.max_score %> 点</span>
              </div>

              <div class="flex items-center gap-4">
                <% if is_readonly %>
                  <div class="flex-1">
                    <div class="flex items-center gap-2">
                      <span class="text-2xl font-bold text-indigo-600"><%= evaluation&.score || "-" %></span>
                      <span class="text-gray-400">/ <%= criterion.max_score %></span>
                    </div>
                  </div>
                <% else %>
                  <input type="range"
                         name="evaluations[<%= criterion.id %>]"
                         min="1"
                         max="<%= criterion.max_score %>"
                         value="<%= evaluation&.score || (criterion.max_score / 2) %>"
                         class="flex-1 h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-indigo-600"
                         data-controller="range-display"
                         data-range-display-target="slider"
                         data-action="input->range-display#update">
                  <div class="w-16 text-center">
                    <span class="text-2xl font-bold text-indigo-600" data-range-display-target="value">
                      <%= evaluation&.score || (criterion.max_score / 2) %>
                    </span>
                    <span class="text-gray-400">/ <%= criterion.max_score %></span>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>

        <!-- Comment -->
        <div>
          <label for="comment" class="block font-medium text-gray-900 mb-2">コメント（任意）</label>
          <% if is_readonly %>
            <div class="bg-gray-50 rounded-lg p-4 text-gray-700">
              <%= @comment.comment.presence || "コメントなし" %>
            </div>
          <% else %>
            <textarea name="comment"
                      id="comment"
                      rows="4"
                      placeholder="作品に対するフィードバックを入力してください..."
                      class="w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 resize-none"><%= @comment.comment %></textarea>
            <p class="mt-1 text-sm text-gray-500">2000文字以内</p>
          <% end %>
        </div>

        <!-- Submit Button -->
        <% unless is_readonly %>
          <div class="flex items-center justify-between pt-4 border-t border-gray-100">
            <%= link_to "キャンセル", my_judge_assignment_path(@contest_judge),
                        class: "px-4 py-2 text-gray-700 hover:text-gray-900 transition-colors" %>
            <button type="submit"
                    class="px-6 py-2.5 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 transition-colors">
              <% if has_existing_evaluations %>
                評価を更新
              <% else %>
                評価を保存
              <% end %>
            </button>
          </div>
        <% else %>
          <div class="pt-4 border-t border-gray-100">
            <%= link_to "作品一覧に戻る", my_judge_assignment_path(@contest_judge),
                        class: "block w-full text-center px-4 py-2 bg-gray-100 text-gray-700 font-medium rounded-lg hover:bg-gray-200 transition-colors" %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>

<!-- Lightbox Modal -->
<div id="lightbox" class="fixed inset-0 z-50 hidden bg-black/90 flex items-center justify-center" data-controller="lightbox">
  <button type="button" class="absolute top-4 right-4 text-white hover:text-gray-300" data-action="click->lightbox#close">
    <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>
  <% if @entry.photo.attached? %>
    <%= image_tag @entry.photo, class: "max-w-full max-h-full object-contain", data: { lightbox_target: "image" } %>
  <% end %>
</div>
