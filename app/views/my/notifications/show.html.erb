<div class="container mx-auto max-w-3xl px-4 py-8">
  <!-- Back Link -->
  <%= link_to my_notifications_path, class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700 mb-4" do %>
    <svg class="mr-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
    </svg>
    通知一覧に戻る
  <% end %>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="p-6">
      <!-- Notification Header -->
      <div class="flex items-start">
        <!-- Icon -->
        <div class="flex-shrink-0">
          <% if @notification.notification_type == "entry_ranked" %>
            <div class="w-12 h-12 bg-yellow-100 rounded-full flex items-center justify-center">
              <svg class="h-6 w-6 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
              </svg>
            </div>
          <% else %>
            <div class="w-12 h-12 bg-indigo-100 rounded-full flex items-center justify-center">
              <svg class="h-6 w-6 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
              </svg>
            </div>
          <% end %>
        </div>

        <!-- Content -->
        <div class="ml-4 flex-1">
          <h1 class="text-xl font-bold text-gray-900"><%= @notification.title %></h1>
          <p class="mt-1 text-sm text-gray-500">
            <%= @notification.created_at.strftime('%Y年%m月%d日 %H:%M') %>
          </p>
        </div>
      </div>

      <!-- Body -->
      <% if @notification.body.present? %>
        <div class="mt-6 p-4 bg-gray-50 rounded-lg">
          <p class="text-gray-700 whitespace-pre-wrap"><%= @notification.body %></p>
        </div>
      <% end %>

      <!-- Link -->
      <% link_path = notification_link_path(@notification) %>
      <% if link_path.present? %>
        <div class="mt-6">
          <%= link_to link_path, class: "inline-flex items-center px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg transition-colors" do %>
            <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
            </svg>
            リンク先を開く
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
